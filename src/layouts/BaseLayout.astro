---
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CustomerIntakeForm from '../components/CustomerIntakeForm.tsx';
import GetStartedQuote from '../components/GetStartedQuote.tsx';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  schema?: Record<string, any> | Record<string, any>[];
  /**
   * Paint fixed-position gradient overlays at the top and bottom of the
   * viewport so content softly fades into the body color near the edges.
   * Use for storytelling pages that want a "focus on the middle of the
   * viewport" feel without hard section boundaries.
   */
  focusOverlay?: boolean;
}

const {
  title,
  description,
  canonicalPath = '',
  ogImage = `${import.meta.env.BASE_URL}images/pool-cleaning.jpg`,
  schema,
  focusOverlay = false,
} = Astro.props;

const siteUrl = 'https://perfectpoolscleaning.com';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="base-url" content={import.meta.env.BASE_URL} />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Google Fonts: Plus Jakarta Sans (Azure Equilibrium) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:site_name" content="Perfect Pools" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />

  <!-- Schema / JSON-LD -->
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(Array.isArray(schema) ? schema : schema)} />
  )}
</head>
<body class={focusOverlay ? 'has-focus-overlay' : ''}>
  <TopBar />
  <Header />
  <main id="main-content">
    <slot />
  </main>
  {focusOverlay && (
    <>
      <div class="focus-overlay focus-overlay--top" aria-hidden="true"></div>
      <div class="focus-overlay focus-overlay--bottom" aria-hidden="true"></div>
    </>
  )}
  <Footer />

  <!-- Customer Intake Form (Preact island) -->
  <CustomerIntakeForm client:load />

  <!-- Get Started Quote Modal (Preact island) -->
  <GetStartedQuote client:load basePath={import.meta.env.BASE_URL} />

  <!-- Lenis smooth scroll + GSAP sync -->
  <script>
    import Lenis from 'lenis';
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { initScrollReveals } from '../utils/scroll-reveals';

    gsap.registerPlugin(ScrollTrigger);

    const lenis = new Lenis({
      duration: 1.2,
      touchMultiplier: 2,
    });

    // Sync Lenis scroll position → ScrollTrigger
    lenis.on('scroll', ScrollTrigger.update);

    // Drive Lenis from GSAP's ticker (one unified RAF loop)
    gsap.ticker.add((time) => {
      lenis.raf(time * 1000);
    });
    gsap.ticker.lagSmoothing(0);

    // Expose for modal stop/start
    (window as any).__lenis = lenis;

    // Initialize [data-reveal] scroll animations after all resources have
    // loaded so layout is settled and trigger positions are correct.
    function runReveals() {
      initScrollReveals();
    }
    // setTimeout(0) — fires after current microtask queue drains, more
    // reliable than rAF when the Lenis ticker is already hooked up.
    if (document.readyState === 'complete') {
      setTimeout(runReveals, 0);
    } else {
      window.addEventListener('load', () => setTimeout(runReveals, 0), { once: true });
    }
  </script>

  <!-- Intake form trigger + Get Started trigger + Mobile menu script -->
  <script>
    // Quote form trigger delegation — all quote/get-started buttons open the new GetStartedQuote modal
    document.addEventListener('click', (e) => {
      const trigger = (e.target as HTMLElement).closest('[data-open-intake], [data-open-get-started]');
      if (trigger) {
        e.preventDefault();
        window.dispatchEvent(new CustomEvent('openGetStarted'));
      }
    });

    const toggle = document.getElementById('mobile-menu-toggle');
    const nav = document.getElementById('main-nav');

    if (toggle && nav) {
      toggle.addEventListener('click', () => {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!isOpen));
        nav.classList.toggle('is-open');
        document.body.style.overflow = isOpen ? '' : 'hidden';
      });

      // Handle dropdown toggles on mobile
      const dropdownItems = nav.querySelectorAll('.has-dropdown');
      dropdownItems.forEach((item) => {
        const link = item.querySelector('.nav-link');
        if (link && window.innerWidth < 1024) {
          link.addEventListener('click', (e) => {
            if (window.innerWidth < 1024) {
              e.preventDefault();
              item.classList.toggle('is-open');
            }
          });
        }
      });
    }

    // FAQ accordion
    document.querySelectorAll('.faq-question').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        if (item) {
          const wasActive = item.classList.contains('active');
          // Close all in same section
          item.parentElement?.querySelectorAll('.faq-item').forEach((i) => i.classList.remove('active'));
          if (!wasActive) item.classList.add('active');
        }
      });
    });
  </script>
</body>
</html>
