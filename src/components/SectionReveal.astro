---
/**
 * SectionReveal — a storytelling-friendly <section> wrapper that applies
 * a scroll-reveal preset without any inline JS.
 *
 * Under the hood it just emits a <section> with the right `data-reveal*`
 * attributes. BaseLayout's global `initScrollReveals()` picks it up on
 * window.load and wires a ScrollTrigger for it.
 *
 * Use this for any section that should fade/slide/scale into view as the
 * user scrolls to it. It's especially useful for creating a consistent
 * narrative rhythm across a page — the preset + timing lives at the page
 * level, not inside each section's component.
 *
 * ── Example ───────────────────────────────────────────────────────────
 *   <SectionReveal id="pricing" preset="blur-in" className="section--alt">
 *     <div class="container">
 *       <h2>Pricing</h2>
 *       ...
 *     </div>
 *   </SectionReveal>
 *
 * ── Pinned sections — CRITICAL RULE ───────────────────────────────────
 * If the section contains a GSAP ScrollTrigger with `pin: ...` (i.e. any
 * of the *Scroll.tsx Preact islands that pin a sticky child), you MUST
 * pass `pinned` on the SectionReveal. Transforms or filters on an
 * ancestor corrupt the pin's start/end measurements.
 *
 * When `pinned` is set, only paint-only presets are allowed:
 *   `fade`         — opacity crossfade (most subtle)
 *   `reveal-down`  — clip-path wipe from the top (default for pinned)
 *   `reveal-up`    — clip-path wipe from the bottom
 *
 * If you request a transform preset (fade-up, scale-in, etc.) with
 * `pinned`, SectionReveal silently downgrades to `reveal-down` so the
 * page still works.
 *
 * ── Notes ─────────────────────────────────────────────────────────────
 *  • The first (above-the-fold) section on a page should normally use a
 *    plain `<section>` instead of SectionReveal — hiding above-the-fold
 *    content behind a reveal looks like a broken page load.
 *  • Presets, modifiers, and reduced-motion handling all live in
 *    src/utils/scroll-reveals.ts. This component is only sugar over the
 *    underlying data-reveal attribute API.
 */

type Preset =
  | 'fade'
  | 'reveal-down'
  | 'reveal-up'
  | 'fade-up'
  | 'fade-down'
  | 'fade-left'
  | 'fade-right'
  | 'scale-in'
  | 'blur-in'
  | 'rise';

/** Presets that are safe on ancestors of a pinned ScrollTrigger. */
const PIN_SAFE: ReadonlySet<Preset> = new Set(['fade', 'reveal-down', 'reveal-up']);

export interface Props {
  /** Which reveal preset to apply (default 'fade-up') */
  preset?: Preset;
  /** DOM id on the rendered <section> */
  id?: string;
  /** Additional class names — merged after `section` */
  className?: string;
  /** Override the ScrollTrigger start string (default 'top 85%') */
  start?: string;
  /** Override the ScrollTrigger end string (default 'top 55%') */
  end?: string;
  /** Stagger direct children instead of animating the wrapper as a whole.
   *  Pass a delay in seconds between children (e.g. 0.12). */
  stagger?: number | string;
  /** Convert from one-shot to scroll-linked. 'tight' | 'loose' | true */
  scrub?: boolean | 'tight' | 'loose';
  /** Pre-reveal delay in seconds (one-shot reveals only) */
  delay?: number;
  /** Set to true if this section contains a pinned GSAP ScrollTrigger
   *  (e.g. any *Scroll.tsx Preact island that pins a sticky child).
   *  When true, the preset is forced to `fade` (opacity-only) because
   *  parent transforms break child pin measurements. */
  pinned?: boolean;
}

const {
  preset: requestedPreset = 'fade-up',
  id,
  className = '',
  start: startOverride,
  end: endOverride,
  stagger,
  scrub: scrubOverride,
  delay,
  pinned = false,
} = Astro.props;

// When `pinned` is set, only paint-only presets (fade / reveal-down /
// reveal-up) are allowed. Transform presets corrupt child pin
// measurements. If the author passed an unsafe preset, default to
// `reveal-down` (the most visible pin-safe transition).
const preset: Preset = pinned
  ? (PIN_SAFE.has(requestedPreset) ? requestedPreset : 'reveal-down')
  : requestedPreset;

// Pinned sections default to a SCRUB-LINKED reveal over a much wider
// range so the wipe follows the user's scroll gesture directly. A
// one-shot reveal on a huge pinned section is barely noticeable — the
// animation finishes in 0.8s regardless of how fast/slow the user
// scrolls. Scrub mode ties the clip-path progression to scroll
// position so the user "feels" the transition as they move through it.
const start = startOverride ?? (pinned ? 'top bottom' : 'top 85%');
const end = endOverride ?? (pinned ? 'top 30%' : 'top 55%');
const scrub = scrubOverride ?? (pinned ? 'tight' : undefined);

const classList = ['section', className].filter(Boolean).join(' ');
---

<section
  id={id}
  class={classList}
  data-reveal={preset}
  data-reveal-start={start}
  data-reveal-end={end}
  data-reveal-stagger={stagger !== undefined ? String(stagger) : undefined}
  data-reveal-scrub={scrub !== undefined ? String(scrub) : undefined}
  data-reveal-delay={delay !== undefined ? String(delay) : undefined}
>
  <slot />
</section>
