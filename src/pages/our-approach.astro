---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Our Approach to Pool Care | Perfect Pools"
  description="Pool care isn't guesswork — it's chemistry, consistency, and accountability. Learn how Perfect Pools keeps your water balanced year-round in coastal Georgia."
  canonicalPath="/our-approach"
>
  <section class="liquid-hero" style={`--hero-bg: url('${base}images/pool-tile-nice.webp')`}>
    <div id="liquid-hero-mount"></div>

    <!-- HTML overlay for interactive elements -->
    <div class="liquid-hero__overlay">
      <p class="liquid-hero__subtitle">
        Why clear water isn't luck — it's science, consistency, and accountability.
      </p>
      <div class="liquid-hero__buttons">
        <a href="/get-started" class="btn btn--cta btn--lg">View Service Plans</a>
        <a href="#pillars" class="btn btn--outline-white btn--lg">See How We Work</a>
      </div>
    </div>

    <div class="liquid-hero__wave">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none" fill="none">
        <path d="M0,60 C240,120 480,0 720,60 C960,120 1200,0 1440,60 L1440,120 L0,120 Z" fill="var(--color-bg)" />
      </svg>
    </div>
  </section>

  <!-- Section 2: Three Pillars Triangle (Interactive) -->
  <section class="section pillars-section" id="pillars">
    <div class="container">
      <div id="pillars-mount"></div>
    </div>
  </section>

  <!-- Section 3: Industry vs Us Comparison (scroll-driven swap) -->
  <section class="section compare-scroll-section">
    <div class="container">
      <div id="compare-mount"></div>
    </div>
  </section>
</BaseLayout>

<script>
  import { render, h } from 'preact';
  import LiquidHero from '../components/LiquidHero.tsx';
  import PillarsScroll from '../components/PillarsScroll.tsx';
  import CompareScroll from '../components/CompareScroll.tsx';

  const mount = document.getElementById('liquid-hero-mount');
  if (mount) {
    render(h(LiquidHero, null), mount);
  }

  const pillarsMount = document.getElementById('pillars-mount');
  if (pillarsMount) {
    render(h(PillarsScroll, null), pillarsMount);
  }

  const compareMount = document.getElementById('compare-mount');
  if (compareMount) {
    render(h(CompareScroll, null), compareMount);
  }
</script>

<style>
  .liquid-hero {
    position: relative;
    min-height: 85vh;
    overflow: hidden;
    background: var(--hero-bg) center center / cover no-repeat;
    background-color: #0369a1;
  }

  #liquid-hero-mount {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .liquid-hero__overlay {
    position: absolute;
    bottom: 14%;
    left: 0;
    right: 0;
    z-index: 2;
    text-align: center;
    padding: 0 var(--container-padding);
  }

  .liquid-hero__subtitle {
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 1.8vw, 1.15rem);
    color: rgba(255, 255, 255, 0.85);
    max-width: 520px;
    margin: 0 auto var(--space-6);
    line-height: 1.6;
    text-shadow: 0 1px 8px rgba(0, 40, 60, 0.3);
  }

  .liquid-hero__buttons {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .liquid-hero__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    z-index: 1;
    line-height: 0;
  }

  .liquid-hero__wave svg {
    width: 100%;
    height: 80px;
  }

  @media (max-width: 768px) {
    .liquid-hero { min-height: 70vh; }
    .liquid-hero__overlay { bottom: 12%; }
    .liquid-hero__wave svg { height: 50px; }
  }

  /* === Comparison Scroll Section === */
  .compare-scroll-section {
    padding-top: var(--space-16);
    padding-bottom: var(--space-12);
  }

  :global(.cs) {
    position: relative;
    margin-top: var(--space-10);
  }

  :global(.cs__sticky) {
    position: sticky;
    top: 100px;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
  }

  :global(.cs__header--mobile) {
    display: block;
    margin-bottom: var(--space-6);
  }

  :global(.cs__header--desktop) {
    display: none;
  }

  :global(.cs__card-stack) {
    position: relative;
  }

  :global(.cs__card) {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    pointer-events: none;
  }

  :global(.cs__card:first-child) {
    position: relative;
  }

  :global(.cs__card[style*="opacity: 1"]) {
    pointer-events: auto;
  }

  /* Each compare side gets ~100vh of scroll distance (2 sides × 100vh = 200vh) */
  :global(.cs__spacer) {
    height: 200vh;
  }

  :global(.compare-card) {
    max-width: 700px;
    margin: 0 auto;
    background: #fff;
    padding: 2.5rem;
    box-shadow: 0 8px 30px rgba(11, 19, 32, 0.06);
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    animation: cardFadeIn 0.35s ease;
  }

  :global(.compare-side__header) {
    margin-bottom: 2.5rem;
  }

  :global(.compare-label) {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
  }

  :global(.compare-label--accent) {
    color: var(--color-cta);
  }

  :global(.compare-title) {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 1.85rem);
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  :global(.compare-title--dark) {
    color: #0B1320;
  }

  :global(.compare-points) {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  :global(.compare-point) {
    display: flex;
    gap: 1.25rem;
  }

  :global(.compare-icon) {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.15rem;
  }

  :global(.compare-icon--bad) {
    border: 1px solid #fecaca;
    background: #fef2f2;
    color: #ef4444;
  }

  :global(.compare-icon--good) {
    border: 1px solid var(--color-cta);
    background: rgba(224, 182, 41, 0.1);
    color: var(--color-cta);
  }

  :global(.compare-point__title) {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
    margin-bottom: 0.35rem;
  }

  :global(.compare-point__desc) {
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--color-text-light);
  }

  :global(.compare-bar) {
    margin-top: 0.85rem;
    height: 0.4rem;
    position: relative;
    background: #e5e7eb;
    overflow: hidden;
  }

  :global(.compare-bar--chaotic span) {
    position: absolute;
    top: 0;
    bottom: 0;
    background: #ef4444;
    opacity: 0.55;
  }

  :global(.compare-bar--gaps) {
    display: flex;
    gap: 3px;
    background: transparent;
  }

  :global(.compare-bar--gaps span) {
    flex: 1;
    height: 0.4rem;
    background: #fca5a5;
  }

  :global(.compare-bar--gaps span.empty) {
    background: transparent;
  }

  :global(.compare-bar--solid) {
    background: linear-gradient(to right, rgba(224, 182, 41, 0.4), rgba(224, 182, 41, 0.8));
  }

  :global(.compare-bar--consistent) {
    display: flex;
    gap: 3px;
    background: transparent;
  }

  :global(.compare-bar--consistent span) {
    flex: 1;
    height: 0.4rem;
    background: rgba(224, 182, 41, 0.6);
  }

  /* === Pillars Section === */
  .pillars-section {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
    background: #fafafa;
  }

  /* === Scroll-Driven Pillars (Preact-rendered, needs :global) === */

  :global(.pillars-interactive__svg) {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.1));
  }

  /* Mobile: stacked layout — diagram on top, cards below, scroll still works */
  :global(.ps) {
    margin-top: var(--space-6);
    position: relative;
  }

  :global(.ps__sticky-col) {
    position: sticky;
    top: 50px;
    z-index: 1;
    background: #fafafa;
    padding-bottom: 1rem;
  }

  /* Mobile: show the non-sticky header, hide the sticky one */
  :global(.ps__header--mobile) {
    display: block;
    margin-bottom: var(--space-6);
  }

  :global(.ps__header--desktop) {
    display: none;
  }

  :global(.ps__content-row) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  :global(.ps__diagram) {
    max-width: 220px;
    width: 100%;
  }

  :global(.ps__card) {
    padding: 1.25rem;
  }

  :global(.ps__card-header) {
    gap: 0.65rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.65rem;
  }

  :global(.ps__card-icon) {
    width: 36px;
    height: 36px;
    padding: 6px;
  }

  :global(.ps__card-title) {
    font-size: 1rem;
  }

  :global(.ps__card-body) {
    font-size: 0.85rem;
  }

  :global(.ps__mobile-diagram) {
    display: none;
  }

  /* Card stack — all cards layered, only active visible via crossfade */
  :global(.ps__card-stack) {
    position: relative;
  }

  :global(.ps__card) {
    background: #fff;
    border-radius: 12px;
    border: 2px solid #e5e7eb;
    padding: 2rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    /* GSAP controls opacity/transform — just set positioning */
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    pointer-events: none;
  }

  :global(.ps__card:first-child) {
    position: relative;
  }

  :global(.ps__card[style*="opacity: 1"]) {
    pointer-events: auto;
  }

  /* Scroll spacer — creates scroll distance for the progress calculation */
  /* Each pillar gets ~100vh of scroll distance (4 pillars × 100vh = 400vh) */
  :global(.ps__spacer) {
    height: 400vh;
  }

  :global(.ps__card-header) {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #f0f0f0;
  }

  :global(.ps__card-icon) {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
  }

  :global(.ps__card-icon img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  :global(.ps__card-title) {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-weight: 600;
    line-height: 1.3;
  }

  :global(.ps__card-body) {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--color-text-light);
  }

  :global(.ps__card-body p) {
    margin-bottom: 0.75rem;
  }

  /* Desktop: sticky left column (diagram + card), invisible scroll track right */
  @media (min-width: 900px) {
    :global(.ps) {
      display: flex;
      align-items: flex-start;
      position: relative;
    }

    :global(.ps__sticky-col) {
      top: 80px;
      background: #fafafa;
    }

    :global(.ps__header--mobile) {
      display: none;
    }

    :global(.ps__header--desktop) {
      display: block;
      margin-bottom: var(--space-8);
    }

    :global(.ps__content-row) {
      flex-direction: row;
      align-items: center;
      gap: 2rem;
    }

    :global(.ps__diagram) {
      flex: 0 0 50%;
      max-width: none;
    }

    :global(.ps__card-stack) {
      flex: 1;
    }

    :global(.cs__header--mobile) {
      display: none;
    }

    :global(.cs__header--desktop) {
      display: block;
      margin-bottom: var(--space-8);
    }
  }

  /* === Mobile overrides for comparison section === */
  @media (max-width: 899px) {
    :global(.cs) {
      margin-top: var(--space-6);
    }

    :global(.cs__sticky) {
      top: 50px;
    }

    /* compare headers already handled by global defaults */

    :global(.compare-card) {
      padding: 1.25rem;
    }

    :global(.compare-points) {
      gap: 1.5rem;
    }

    :global(.compare-point__title) {
      font-size: 0.85rem;
    }

    :global(.compare-point__desc) {
      font-size: 0.8rem;
    }

    :global(.cs__spacer) {
      height: 120vh;
    }
  }

  /* === Mobile overrides for pillar cards (after global card styles) === */
  @media (max-width: 899px) {
    /* ps__header visibility handled by --mobile/--desktop toggle */

    :global(.ps__card) {
      padding: 1.25rem !important;
    }

    :global(.ps__spacer) {
      height: 300vh;
    }

    :global(.ps__card-header) {
      gap: 0.65rem;
      margin-bottom: 0.75rem;
      padding-bottom: 0.65rem;
    }

    :global(.ps__card-icon) {
      width: 36px;
      height: 36px;
      padding: 6px;
    }

    :global(.ps__card-title) {
      font-size: 1rem;
    }

    :global(.ps__card-body) {
      font-size: 0.85rem;
    }

    :global(.ps__card-body p) {
      margin-bottom: 0.5rem;
    }
  }
</style>
