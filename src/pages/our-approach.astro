---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReviewCarousel from '../components/ReviewCarousel.astro';
const base = import.meta.env.BASE_URL;

/**
 * Our Approach — storytelling page.
 *
 * The 5 pinned card-stack sections (Problem / Our Story / Pillars /
 * Compare / Visit) handle their own internal GSAP animations. The page
 * itself is plain <section> flow with alternating backgrounds. The
 * Reviews and final CTA get simple data-reveal entrance animations
 * (see src/utils/scroll-reveals.ts).
 *
 * Section-to-section cohesion (pinned handoffs between sections) is
 * a larger refactor parked for later — it requires rewriting the 5
 * scroll components to expose a shared timeline API instead of
 * self-pinning independently. When that lands, come back here and
 * orchestrate the sequence from one place.
 */
---

<BaseLayout
  title="Our Approach to Pool Care | Perfect Pools"
  description="Pool care isn't guesswork — it's chemistry, consistency, and accountability. Learn how Perfect Pools keeps your water balanced year-round in coastal Georgia."
  canonicalPath="/our-approach"
>
  {/* Section 1 — Problem Statement (cinematic card stack) */}
  <section class="section problem-section oa-section">
    <div class="container">
      <div id="problem-mount"></div>
    </div>
  </section>

  {/* Section 2 — Our Story (company timeline) */}
  <section class="section section--alt oa-section" id="our-story">
    <div class="container">
      <div id="timeline-mount"></div>
    </div>
  </section>

  {/* Section 3 — Three Pillars */}
  <section class="section pillars-section oa-section" id="pillars">
    <div class="container">
      <div id="pillars-mount"></div>
    </div>
  </section>

  {/* Section 4 — Industry vs Us Comparison */}
  <section class="section compare-scroll-section oa-section">
    <div class="container">
      <div id="compare-mount"></div>
    </div>
  </section>

  {/* Section 5 — Anatomy of a Visit */}
  <section class="section visit-section oa-section" id="visit">
    <div class="container">
      <div id="visit-mount"></div>
    </div>
  </section>

  {/* Section 6 — Reviews */}
  <section class="section oa-section" id="reviews">
    <div class="container">
      <div class="section-header" data-reveal="fade-up">
        <span class="section-kicker">WHAT OUR CLIENTS SAY</span>
        <h2>Real Reviews, Real Results.</h2>
      </div>
      <div data-reveal="fade-up" data-reveal-stagger="0.12">
        <ReviewCarousel />
        <div style="text-align: center; margin-top: var(--space-8);">
          <a href="https://g.page/r/CVrU0W_3-NRyEAE/review" target="_blank" rel="noopener" class="btn btn--outline">Read All Reviews on Google</a>
        </div>
      </div>
    </div>
  </section>

  {/* Section 7 — Final CTA */}
  <section class="partnership-cta oa-section">
    <div class="container">
      <div class="partnership-cta__card" data-reveal="scale-in" data-reveal-start="top 85%" data-reveal-end="top 55%">
        <h2>Start Your Aquatic Partnership</h2>
        <p>Experience the difference of architectural-grade maintenance. We are currently accepting new clients for our exclusive service routes.</p>
        <div class="partnership-cta__buttons">
          <a href={`${base}get-started/`} class="btn btn--cta btn--lg">Join Our Route</a>
          <a href={`${base}plans/`} class="btn btn--outline-white btn--lg">View Pricing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { render, h } from 'preact';
  import ProblemScroll from '../components/ProblemScroll.tsx';
  import TimelineScroll from '../components/TimelineScroll.tsx';
  import PillarsScroll from '../components/PillarsScroll.tsx';
  import CompareScroll from '../components/CompareScroll.tsx';
  import VisitScroll from '../components/VisitScroll.tsx';

  const problemMount = document.getElementById('problem-mount');
  if (problemMount) {
    render(h(ProblemScroll, null), problemMount);
  }

  const timelineMount = document.getElementById('timeline-mount');
  if (timelineMount) {
    render(h(TimelineScroll, null), timelineMount);
  }

  const pillarsMount = document.getElementById('pillars-mount');
  if (pillarsMount) {
    render(h(PillarsScroll, null), pillarsMount);
  }

  const visitMount = document.getElementById('visit-mount');
  if (visitMount) {
    render(h(VisitScroll, null), visitMount);
  }

  // Service area carousel
  const track = document.getElementById('area-track');
  const prevBtn = document.getElementById('area-prev');
  const nextBtn = document.getElementById('area-next');
  if (track && prevBtn && nextBtn) {
    let offset = 0;
    const getCardWidth = () => {
      const card = track.querySelector('.coastal-area-card') as HTMLElement;
      if (!card) return 0;
      return card.offsetWidth + 16; // card width + gap
    };
    const getMaxOffset = () => {
      const visibleWidth = (track.parentElement as HTMLElement).offsetWidth;
      const totalWidth = track.scrollWidth;
      return Math.max(0, totalWidth - visibleWidth);
    };
    prevBtn.addEventListener('click', () => {
      offset = Math.max(0, offset - getCardWidth());
      track.style.transform = `translateX(-${offset}px)`;
    });
    nextBtn.addEventListener('click', () => {
      offset = Math.min(getMaxOffset(), offset + getCardWidth());
      track.style.transform = `translateX(-${offset}px)`;
    });
  }

  const compareMount = document.getElementById('compare-mount');
  if (compareMount) {
    render(h(CompareScroll, null), compareMount);
  }

  // After all Preact islands mount + resources load, refresh ScrollTrigger
  // so the scroll-card components see the final page height.
  window.addEventListener('load', () => {
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        import('gsap/ScrollTrigger').then(({ ScrollTrigger }) => {
          ScrollTrigger.sort();
          ScrollTrigger.refresh();
        });
      });
    });
  });
</script>

<style>
  /* === Section Flow === */
  .oa-section {
    position: relative;
  }

  /* GPU compositing hints for scroll-animated cards */
  :global(.prb__card),
  :global(.ps__card),
  :global(.cs__card),
  :global(.vs__card),
  :global(.tl-card) {
    will-change: opacity, transform;
  }

  /* === Problem Scroll Section === */
  :global(.prb) {
    position: relative;
  }

  :global(.prb__header--mobile) { display: block; margin-bottom: var(--space-6); }
  :global(.prb__header--desktop) { display: none; }

  @media (min-width: 900px) {
    :global(.prb__header--mobile) { display: none; }
    :global(.prb__header--desktop) { display: block; margin-bottom: var(--space-8); }
  }

  :global(.prb__sticky) {
    min-height: 60vh;
    display: flex;
    flex-direction: column;
  }

  :global(.prb__card-stack) {
    position: relative;
    flex: 1;
  }

  :global(.prb__card) {
    border-radius: 20px;
    padding: 2.5rem;
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(.prb__card--dark) {
    background: #0B1320;
    color: #fff;
  }

  :global(.prb__card--resolve) {
    background: linear-gradient(135deg, #145BB8 0%, #1E3A5F 100%);
    color: #fff;
  }

  /* Cinematic cards — bold, centered, minimal */
  :global(.prb__cinematic) {
    text-align: center;
    max-width: 640px;
  }

  :global(.prb__cinematic-headline) {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  :global(.prb__cinematic-subline) {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 1.25rem;
  }

  :global(.prb__cinematic-body) {
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.5);
    max-width: 520px;
    margin: 0 auto;
  }

  /* Resolution card — content-rich */
  :global(.prb__resolve) {
    max-width: 560px;
  }

  :global(.prb__resolve-headline) {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  :global(.prb__resolve-body) {
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 1.5rem;
  }

  :global(.prb__resolve-bullets) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  :global(.prb__resolve-bullets li) {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
  }

  :global(.prb__resolve-bullets svg) {
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: #E28D33;
  }

  :global(.prb__spacer) {
    height: 400vh;
  }

  @media (max-width: 899px) {
    :global(.prb__card) {
      padding: 1.5rem;
      min-height: 280px;
    }
    :global(.prb__spacer) {
      height: 300vh;
    }
  }

  /* === Comparison Scroll Section === */
  .compare-scroll-section {
    padding-top: var(--space-16);
    padding-bottom: var(--space-12);
  }

  :global(.cs) {
    position: relative;
    margin-top: var(--space-10);
  }

  :global(.cs__sticky) {
    position: sticky;
    top: 100px;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
  }

  :global(.cs__header--mobile) {
    display: block;
    margin-bottom: var(--space-6);
  }

  :global(.cs__header--desktop) {
    display: none;
  }

  :global(.cs__card-stack) {
    position: relative;
  }

  :global(.cs__card) {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    pointer-events: none;
  }

  :global(.cs__card:first-child) {
    position: relative;
  }

  :global(.cs__card.is-active) {
    pointer-events: auto;
  }

  /* Each compare side gets ~100vh of scroll distance (2 sides × 100vh = 200vh) */
  :global(.cs__spacer) {
    height: 200vh;
  }

  :global(.compare-card) {
    max-width: 700px;
    margin: 0 auto;
    background: #fff;
    padding: 2.5rem;
    box-shadow: var(--shadow-md);
    border: 1px solid #e5e5e5;
    border-radius: var(--radius-lg);
  }

  :global(.compare-side__header) {
    margin-bottom: 2.5rem;
  }

  :global(.compare-label) {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
  }

  :global(.compare-label--accent) {
    color: var(--color-cta);
  }

  :global(.compare-title) {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 1.85rem);
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  :global(.compare-title--dark) {
    color: #0B1320;
  }

  :global(.compare-points) {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  :global(.compare-point) {
    display: flex;
    gap: 1.25rem;
  }

  :global(.compare-icon) {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.15rem;
  }

  :global(.compare-icon--bad) {
    border: 1px solid #fecaca;
    background: #fef2f2;
    color: #ef4444;
  }

  :global(.compare-icon--good) {
    border: 1px solid var(--color-cta);
    background: rgba(224, 182, 41, 0.1);
    color: var(--color-cta);
  }

  :global(.compare-point__title) {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
    margin-bottom: 0.35rem;
  }

  :global(.compare-point__desc) {
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--color-text-light);
  }

  :global(.compare-bar) {
    margin-top: 0.85rem;
    height: 0.4rem;
    position: relative;
    background: #e5e7eb;
    overflow: hidden;
  }

  :global(.compare-bar--chaotic span) {
    position: absolute;
    top: 0;
    bottom: 0;
    background: #ef4444;
    opacity: 0.55;
  }

  :global(.compare-bar--gaps) {
    display: flex;
    gap: 3px;
    background: transparent;
  }

  :global(.compare-bar--gaps span) {
    flex: 1;
    height: 0.4rem;
    background: #fca5a5;
  }

  :global(.compare-bar--gaps span.empty) {
    background: transparent;
  }

  :global(.compare-bar--solid) {
    background: linear-gradient(to right, rgba(224, 182, 41, 0.4), rgba(224, 182, 41, 0.8));
  }

  :global(.compare-bar--consistent) {
    display: flex;
    gap: 3px;
    background: transparent;
  }

  :global(.compare-bar--consistent span) {
    flex: 1;
    height: 0.4rem;
    background: rgba(224, 182, 41, 0.6);
  }

  .pillars-section {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
    background: var(--color-bg-alt);
  }

  /* === Scroll-Driven Pillars (Preact-rendered, needs :global) === */

  :global(.pillars-interactive__svg) {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.1));
  }

  /* Mobile: stacked layout — diagram on top, cards below, scroll still works */
  :global(.ps) {
    margin-top: var(--space-6);
    position: relative;
  }

  :global(.ps__sticky-col) {
    position: sticky;
    top: 50px;
    z-index: 1;
    background: var(--color-bg-alt);
    padding-bottom: 1rem;
  }

  /* Mobile: show the non-sticky header, hide the sticky one */
  :global(.ps__header--mobile) {
    display: block;
    margin-bottom: var(--space-6);
  }

  :global(.ps__header--desktop) {
    display: none;
  }

  :global(.ps__content-row) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  :global(.ps__diagram) {
    max-width: 220px;
    width: 100%;
  }

  :global(.ps__card) {
    padding: 1.25rem;
  }

  :global(.ps__card-header) {
    gap: 0.65rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.65rem;
  }

  :global(.ps__card-icon) {
    width: 36px;
    height: 36px;
    padding: 6px;
  }

  :global(.ps__card-title) {
    font-size: 1rem;
  }

  :global(.ps__card-body) {
    font-size: 0.85rem;
  }

  :global(.ps__mobile-diagram) {
    display: none;
  }

  /* Card stack — all cards layered, only active visible via crossfade */
  :global(.ps__card-stack) {
    position: relative;
  }

  /* Cards no longer have a container background — content sits directly in
     the right column and GSAP crossfades between pillars as the user scrolls. */
  :global(.ps__card) {
    background: transparent;
    border: none;
    padding: 0;
    box-shadow: none;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    pointer-events: none;
    z-index: 1;
  }

  :global(.ps__card:first-child) {
    position: relative;
  }

  /* Active card sits on top of the stack AND receives pointer events,
     so clicks hit it directly without relying on pass-through. */
  :global(.ps__card.is-active) {
    pointer-events: auto;
    z-index: 2;
  }

  /* Scroll spacer — creates scroll distance for the progress calculation */
  /* Each pillar gets ~100vh of scroll distance (4 pillars × 100vh = 400vh) */
  :global(.ps__spacer) {
    height: 400vh;
  }

  :global(.ps__card-header) {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0;
    border-bottom: none;
  }

  :global(.ps__card-icon) {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
  }

  :global(.ps__card-icon img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  :global(.ps__card-title) {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-weight: 600;
    line-height: 1.3;
  }

  :global(.ps__card-body) {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--color-text-light);
  }

  :global(.ps__card-body p) {
    margin-bottom: 0.75rem;
  }

  /* Desktop: sticky left column (diagram + card), invisible scroll track right */
  @media (min-width: 900px) {
    :global(.ps) {
      display: flex;
      align-items: flex-start;
      position: relative;
    }

    :global(.ps__sticky-col) {
      top: 60px;
      background: var(--color-bg-alt);
    }

    :global(.ps__header--mobile) {
      display: none;
    }

    :global(.ps__header--desktop) {
      display: block;
      margin-bottom: var(--space-8);
    }

    :global(.ps__content-row) {
      flex-direction: row;
      align-items: stretch;
      min-height: 480px;
      gap: 2rem;
    }

    :global(.ps__diagram) {
      flex: 0 0 50%;
      max-width: none;
      align-self: center;
    }

    :global(.ps__card-stack) {
      flex: 1;
    }

    :global(.cs__header--mobile) {
      display: none;
    }

    :global(.cs__header--desktop) {
      display: block;
      margin-bottom: var(--space-8);
    }
  }

  /* === Mobile overrides for comparison section === */
  @media (max-width: 899px) {
    :global(.cs) {
      margin-top: var(--space-6);
    }

    :global(.cs__sticky) {
      top: 50px;
    }

    /* compare headers already handled by global defaults */

    :global(.compare-card) {
      padding: 1.25rem;
    }

    :global(.compare-points) {
      gap: 1.5rem;
    }

    :global(.compare-point__title) {
      font-size: 0.85rem;
    }

    :global(.compare-point__desc) {
      font-size: 0.8rem;
    }

    :global(.cs__spacer) {
      height: 120vh;
    }
  }

  /* === Mobile overrides for pillar cards (after global card styles) === */
  @media (max-width: 899px) {
    /* ps__header visibility handled by --mobile/--desktop toggle */

    :global(.ps__card) {
      padding: 1.25rem !important;
    }

    :global(.ps__spacer) {
      height: 300vh;
    }

    :global(.ps__card-header) {
      gap: 0.65rem;
      margin-bottom: 0.75rem;
      padding-bottom: 0.65rem;
    }

    :global(.ps__card-icon) {
      width: 36px;
      height: 36px;
      padding: 6px;
    }

    :global(.ps__card-title) {
      font-size: 1rem;
    }

    :global(.ps__card-body) {
      font-size: 0.85rem;
    }

    :global(.ps__card-body p) {
      margin-bottom: 0.5rem;
    }
  }

  /* ========================================
     Coastal Expertise Section + Service Area Cards
     ======================================== */
  .coastal-wave {
    position: relative;
    z-index: 2;
    line-height: 0;
  }

  .coastal-wave svg {
    width: 100%;
    height: 64px;
    display: block;
  }

  .coastal-wave--top {
    margin-bottom: -1px;
    margin-top: var(--space-8);
  }

  .coastal-wave--bottom {
    margin-top: -1px;
    transform: rotate(180deg);
  }

  .coastal-section {
    background: #1E3A5F;
    color: #fff;
    padding: var(--space-16) 0;
    position: relative;
    z-index: 1;
    overflow: hidden;
  }

  .coastal-layout {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  @media (min-width: 900px) {
    .coastal-layout {
      flex-direction: row;
      gap: 4rem;
    }

    .coastal-wave svg {
      height: 96px;
    }
  }

  @media (min-width: 1100px) {
    .coastal-wave svg {
      height: 120px;
    }
  }

  /* Map graphic */
  .coastal-map {
    flex: 0 0 auto;
    width: 100%;
    max-width: 400px;
    position: relative;
  }

  @media (min-width: 900px) {
    .coastal-map {
      flex: 0 0 45%;
      max-width: none;
    }
  }

  .coastal-map__glow {
    position: absolute;
    inset: -10%;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 50%;
    filter: blur(40px);
  }

  .coastal-map__frame {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
    overflow: hidden;
    border: 3px solid rgba(255, 255, 255, 0.12);
    background: rgba(30, 40, 60, 0.5);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
  }

  .coastal-map__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.9;
    transition: opacity 0.7s ease;
  }

  .coastal-map__frame:hover .coastal-map__img {
    opacity: 0.75;
  }

  .coastal-map__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top right, rgba(30, 58, 95, 0.2), transparent);
  }

  .coastal-map__pin {
    position: absolute;
    top: 42%;
    left: 55%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .coastal-map__pulse {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #E28D33;
    margin-top: 2px;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.5); }
  }

  @media (prefers-reduced-motion: reduce) {
    .coastal-map__pulse {
      animation: none;
    }
  }

  /* Content */
  .coastal-content {
    flex: 1;
  }

  .coastal-content__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: 1rem;
  }

  .coastal-content__desc {
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    line-height: 1.65;
    color: rgba(226, 232, 240, 0.9);
    max-width: 500px;
    margin-bottom: 2rem;
  }

  .coastal-checklist {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .coastal-checklist__item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .coastal-checklist__icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(226, 141, 51, 0.2);
    color: #E28D33;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
    transition: background 200ms ease, color 200ms ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .coastal-checklist__item:hover .coastal-checklist__icon {
      background: #E28D33;
      color: #fff;
    }
  }

  .coastal-checklist__item strong {
    display: block;
    font-size: 1.05rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.2rem;
  }

  .coastal-checklist__item span {
    display: block;
    font-size: 0.85rem;
    color: rgba(203, 213, 225, 0.85);
    line-height: 1.5;
  }

  /* --- Service Area Carousel --- */
  .coastal-areas {
    margin-top: 3.5rem;
  }

  .coastal-areas__title {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 1.25rem;
  }

  .coastal-areas__nav {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .coastal-areas__btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 200ms ease, color 200ms ease, border-color 200ms ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .coastal-areas__btn:hover {
      background: rgba(255, 255, 255, 0.18);
      color: #fff;
      border-color: rgba(226, 141, 51, 0.5);
    }
  }

  .coastal-areas__track-wrapper {
    overflow: hidden;
  }

  .coastal-areas__track {
    display: flex;
    gap: 1rem;
    transition: transform 300ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .coastal-area-card {
    flex: 0 0 calc(50% - 0.5rem);
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: #fff;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  @media (min-width: 600px) {
    .coastal-area-card {
      flex: 0 0 calc(33.333% - 0.67rem);
    }
  }

  @media (min-width: 900px) {
    .coastal-area-card {
      flex: 0 0 calc(25% - 0.75rem);
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .coastal-area-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.35);
      color: #fff;
    }
  }

  .coastal-area-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    .coastal-area-card:hover .coastal-area-card__img {
      transform: scale(1.06);
    }
  }

  .coastal-area-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.1) 50%, transparent 100%);
  }

  .coastal-area-card__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .coastal-area-card__label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #E28D33;
  }

  .coastal-area-card__name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.2;
    color: #fff;
  }

  /* ========================================
     Visit Section — Anatomy of a Visit
     ======================================== */
  .visit-section {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
  }

  :global(.vs) {
    margin-top: var(--space-6);
    position: relative;
  }

  :global(.vs__eyebrow) {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #2563eb;
    margin-bottom: 0.5rem;
  }

  :global(.vs__sticky-col) {
    position: sticky;
    top: 50px;
    z-index: 1;
    padding-bottom: 1rem;
  }

  /* Mobile header visible, desktop hidden */
  :global(.vs__header--mobile) {
    display: block;
    margin-bottom: var(--space-6);
  }

  :global(.vs__header--desktop) {
    display: none;
  }

  :global(.vs__content-row) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* --- Timeline indicator --- */
  :global(.vs__timeline) {
    display: none; /* hidden on mobile */
  }

  /* --- Card stack --- */
  :global(.vs__card-stack) {
    position: relative;
  }

  :global(.vs__card) {
    background: #fff;
    border-radius: var(--radius-lg);
    border: 2px solid #e5e7eb;
    border-left-width: 4px;
    padding: 2rem;
    box-shadow: var(--shadow-md);
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    pointer-events: none;
  }

  :global(.vs__card:first-child) {
    position: relative;
  }

  :global(.vs__card.is-active) {
    pointer-events: auto;
  }

  :global(.vs__card-header) {
    margin-bottom: 1rem;
  }

  :global(.vs__card-badge) {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    border: 1px solid;
    margin-bottom: 0.75rem;
  }

  :global(.vs__card-title) {
    font-family: var(--font-heading);
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text);
  }

  :global(.vs__card-body) {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--color-text-light);
  }

  :global(.vs__card-body p) {
    margin-bottom: 0.75rem;
  }

  :global(.vs__spacer) {
    height: 300vh;
  }

  /* --- Desktop layout --- */
  @media (min-width: 900px) {
    :global(.vs__sticky-col) {
      top: 80px;
    }

    :global(.vs__header--mobile) {
      display: none;
    }

    :global(.vs__header--desktop) {
      display: block;
      margin-bottom: var(--space-8);
    }

    :global(.vs__content-row) {
      flex-direction: row;
      align-items: flex-start;
      gap: 3rem;
    }

    /* Timeline — vertical track with dots */
    :global(.vs__timeline) {
      display: block;
      position: relative;
      flex: 0 0 180px;
      height: 280px;
    }

    :global(.vs__timeline-track) {
      position: absolute;
      left: 15px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: #e5e7eb;
    }

    :global(.vs__timeline-step) {
      position: absolute;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      transform: translateY(-50%);
      transition: color 250ms ease;
    }

    :global(.vs__timeline-dot) {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: #fff;
      border: 2px solid #d1d5db;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #9ca3af;
      transition: background 250ms ease, border-color 250ms ease, color 250ms ease, box-shadow 250ms ease;
      z-index: 1;
      flex-shrink: 0;
    }

    :global(.vs__timeline-step--active .vs__timeline-dot) {
      border-color: var(--step-color);
      background: var(--step-color);
      color: #fff;
      box-shadow: 0 0 0 4px color-mix(in srgb, var(--step-color) 20%, transparent);
    }

    :global(.vs__timeline-label) {
      font-size: 0.75rem;
      font-weight: 600;
      color: #9ca3af;
      white-space: nowrap;
      transition: color 0.3s ease;
    }

    :global(.vs__timeline-step--active .vs__timeline-label) {
      color: var(--step-color);
    }

    :global(.vs__card-stack) {
      flex: 1;
    }
  }

  /* --- Mobile overrides --- */
  @media (max-width: 899px) {
    :global(.vs__card) {
      padding: 1.25rem !important;
    }

    :global(.vs__spacer) {
      height: 200vh;
    }

    :global(.vs__card-title) {
      font-size: 1rem;
    }

    :global(.vs__card-body) {
      font-size: 0.85rem;
    }
  }

  /* --- Partnership CTA --- */
  .partnership-cta {
    padding: var(--space-16) 0;
  }

  .partnership-cta__card {
    background: linear-gradient(135deg, #0B1320 0%, #1E3A5F 50%, #145BB8 100%);
    border-radius: 24px;
    padding: 4rem 3rem;
    text-align: center;
    color: #fff;
  }

  .partnership-cta__card h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
    color: #fff;
  }

  .partnership-cta__card p {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.75);
    max-width: 480px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .partnership-cta__buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .partnership-cta__card {
      padding: 3rem 1.5rem;
    }
  }

  /* ============ LSI Calculator (inside Water Balance pillar card) ============ */
  :global(.lsi-calc) {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    color: var(--color-text);
  }
  :global(.lsi-calc__intro) {
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--color-text);
    font-weight: 600;
    margin: 0;
  }
  :global(.lsi-calc__intro strong) {
    color: var(--color-primary);
    font-weight: 700;
  }

  /* 4×1 horizontal dial row. */
  :global(.lsi-calc__dials) {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
  }

  :global(.lsi-dial) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    min-width: 0;
  }
  :global(.lsi-dial__label) {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  :global(.lsi-dial__wheel) {
    position: relative;
    width: 100%;
    max-width: 110px;
    aspect-ratio: 1 / 1;
    background: linear-gradient(135deg, var(--color-primary), var(--color-cyan));
    border-radius: 50%;
    touch-action: none;
    user-select: none;
    box-shadow: 0 4px 14px rgba(2, 132, 199, 0.28), inset 0 2px 4px rgba(255, 255, 255, 0.15);
    transition: box-shadow 300ms ease, transform 150ms ease;
  }
  /* Per-dial health glow — outer halo changes color based on whether the
     individual reading is ideal (green), acceptable (amber), or bad (red). */
  :global(.lsi-dial__wheel--ideal) {
    box-shadow:
      0 0 0 3px rgba(16, 185, 129, 0.35),
      0 4px 14px rgba(16, 185, 129, 0.3),
      inset 0 2px 4px rgba(255, 255, 255, 0.15);
  }
  :global(.lsi-dial__wheel--ok) {
    box-shadow:
      0 0 0 3px rgba(245, 158, 11, 0.4),
      0 4px 14px rgba(245, 158, 11, 0.3),
      inset 0 2px 4px rgba(255, 255, 255, 0.15);
  }
  :global(.lsi-dial__wheel--bad) {
    box-shadow:
      0 0 0 3px rgba(220, 38, 38, 0.45),
      0 4px 18px rgba(220, 38, 38, 0.4),
      inset 0 2px 4px rgba(255, 255, 255, 0.15);
    animation: lsi-dial-pulse 1.6s ease-in-out infinite;
  }
  @keyframes lsi-dial-pulse {
    0%, 100% {
      box-shadow:
        0 0 0 3px rgba(220, 38, 38, 0.45),
        0 4px 18px rgba(220, 38, 38, 0.4),
        inset 0 2px 4px rgba(255, 255, 255, 0.15);
    }
    50% {
      box-shadow:
        0 0 0 5px rgba(220, 38, 38, 0.55),
        0 6px 24px rgba(220, 38, 38, 0.55),
        inset 0 2px 4px rgba(255, 255, 255, 0.15);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.lsi-dial__wheel--bad) {
      animation: none;
    }
  }
  :global(.lsi-dial__wheel:hover) {
    box-shadow: 0 5px 14px rgba(2, 132, 199, 0.35), inset 0 2px 4px rgba(255, 255, 255, 0.15);
  }
  :global(.lsi-dial__wheel.is-dragging) {
    cursor: grabbing;
    transform: scale(1.03);
  }
  :global(.lsi-dial__svg),
  :global(.lsi-dial__svg *) {
    pointer-events: none;
  }
  :global(.lsi-dial__svg) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }


  /* Indicator dot is rendered as SVG inside .lsi-dial__svg — no DOM handle needed. */
  :global(.lsi-dial__center) {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 60%;
    aspect-ratio: 1 / 1;
    background: #ffffff;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.4), 0 2px 6px rgba(0, 20, 40, 0.15);
    pointer-events: none;
  }
  :global(.lsi-dial__value) {
    font-family: var(--font-heading, inherit);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-gray-900);
    line-height: 1;
    transition: color 200ms ease;
  }
  :global(.lsi-dial__value--ideal) { color: #059669; }
  :global(.lsi-dial__value--ok) { color: #d97706; }
  :global(.lsi-dial__value--bad) { color: #dc2626; }
  :global(.lsi-dial__unit) {
    font-size: 0.55rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-500);
    margin-top: 0.1rem;
  }

  /* Dynamic caption under each dial — changes based on the current reading
     (too low, ideal, too high). Tinted to match the dial's health color. */
  :global(.lsi-dial__why) {
    margin: 0.4rem 0 0 0;
    font-size: 0.62rem;
    line-height: 1.35;
    text-align: center;
    transition: color 300ms ease;
  }
  :global(.lsi-dial__why--ideal) {
    color: var(--color-text-light);
  }
  :global(.lsi-dial__why--ok) {
    color: #b45309;
  }
  :global(.lsi-dial__why--bad) {
    color: #b91c1c;
    font-weight: 600;
  }

  /* Result strip — callouts + single-row LSI/gauge/reset. */
  :global(.lsi-calc__result) {
    padding: 0.6rem 0.75rem;
    border-radius: 10px;
    background: linear-gradient(135deg, rgba(10, 30, 55, 0.03), rgba(6, 182, 212, 0.04));
    border: 1.5px solid rgba(10, 30, 55, 0.08);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: background 300ms ease, border-color 300ms ease;
  }
  :global(.lsi-calc__result--balanced) {
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.08), rgba(6, 182, 212, 0.05));
    border-color: rgba(16, 185, 129, 0.3);
  }
  :global(.lsi-calc__result--corrosive) {
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.08), rgba(251, 146, 60, 0.05));
    border-color: rgba(239, 68, 68, 0.3);
  }
  :global(.lsi-calc__result--scaling) {
    background: linear-gradient(135deg, rgba(251, 191, 36, 0.08), rgba(249, 115, 22, 0.05));
    border-color: rgba(251, 191, 36, 0.35);
  }
  /* Callout row — holds the LSI callout and (optionally) the out-of-range warning.
     When only the callout is present it takes full width; when the warning appears,
     they split the row 50/50. */
  :global(.lsi-calc__callout-row) {
    display: flex;
    gap: 0.5rem;
    align-items: stretch;
  }
  :global(.lsi-calc__callout-row > *) {
    flex: 1;
    min-width: 0;
  }

  /* LSI status callout — changes tone + copy based on current LSI state. */
  :global(.lsi-calc__callout) {
    padding: 0.65rem 0.8rem;
    border-radius: 10px;
    border: 1.5px solid transparent;
    transition: background 300ms ease, border-color 300ms ease;
  }
  :global(.lsi-calc__callout--corrosive),
  :global(.lsi-calc__callout--scaling) {
    background: rgba(239, 68, 68, 0.1);
    border-color: rgba(239, 68, 68, 0.35);
  }
  :global(.lsi-calc__callout--balanced) {
    background: rgba(16, 185, 129, 0.1);
    border-color: rgba(16, 185, 129, 0.4);
  }
  :global(.lsi-calc__callout-label) {
    font-size: 0.78rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
    letter-spacing: 0.01em;
  }
  :global(.lsi-calc__callout--corrosive .lsi-calc__callout-label),
  :global(.lsi-calc__callout--scaling .lsi-calc__callout-label) {
    color: #dc2626;
  }
  :global(.lsi-calc__callout--balanced .lsi-calc__callout-label) {
    color: #059669;
  }
  :global(.lsi-calc__callout-detail) {
    font-size: 0.75rem;
    line-height: 1.55;
    color: var(--color-text-light);
    margin: 0;
  }

  /* Readings callout — right side of the callout row. Green when every dial
     is inside its acceptable band, red when at least one is out of range.
     Matches the visual weight and layout of the LSI callout on the left. */
  :global(.lsi-calc__readings-callout) {
    padding: 0.65rem 0.8rem;
    border-radius: 10px;
    border: 1.5px solid transparent;
    transition: background 300ms ease, border-color 300ms ease;
  }
  :global(.lsi-calc__readings-callout--good) {
    background: rgba(16, 185, 129, 0.1);
    border-color: rgba(16, 185, 129, 0.4);
  }
  :global(.lsi-calc__readings-callout--bad) {
    background: rgba(239, 68, 68, 0.1);
    border-color: rgba(239, 68, 68, 0.4);
  }
  :global(.lsi-calc__readings-callout-label) {
    font-size: 0.78rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
    letter-spacing: 0.01em;
  }
  :global(.lsi-calc__readings-callout--good .lsi-calc__readings-callout-label) {
    color: #059669;
  }
  :global(.lsi-calc__readings-callout--bad .lsi-calc__readings-callout-label) {
    color: #dc2626;
  }
  :global(.lsi-calc__readings-callout-detail) {
    font-size: 0.72rem;
    line-height: 1.5;
    color: var(--color-text-light);
  }

  :global(.lsi-calc__result-top) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  :global(.lsi-calc__lsi) {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  :global(.lsi-calc__lsi-label) {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-600);
  }
  :global(.lsi-calc__lsi-value) {
    font-family: var(--font-heading, inherit);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
  }
  :global(.lsi-calc__status) {
    font-size: 0.8rem;
    font-weight: 700;
    flex: 1;
  }
  :global(.lsi-calc__result--balanced .lsi-calc__status) { color: #059669; }
  :global(.lsi-calc__result--corrosive .lsi-calc__status) { color: #dc2626; }
  :global(.lsi-calc__result--scaling .lsi-calc__status) { color: #d97706; }
  :global(.lsi-calc__reset) {
    background: transparent;
    border: 1px solid rgba(10, 30, 55, 0.2);
    color: var(--color-primary);
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
    font-family: inherit;
    font-size: 0.65rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 150ms ease, border-color 150ms ease;
    flex-shrink: 0;
  }
  :global(.lsi-calc__reset:hover) {
    background: rgba(10, 30, 55, 0.05);
    border-color: rgba(10, 30, 55, 0.35);
  }

  /* Gauge track */
  :global(.lsi-calc__gauge-track) {
    position: relative;
    height: 8px;
    border-radius: 999px;
    overflow: hidden;
    display: flex;
  }
  :global(.lsi-calc__gauge-zone) { height: 100%; }
  :global(.lsi-calc__gauge-zone--corrosive) {
    flex: 4;
    background: linear-gradient(to right, #ef4444, #f87171);
  }
  :global(.lsi-calc__gauge-zone--balanced) {
    flex: 2;
    background: #10b981;
  }
  :global(.lsi-calc__gauge-zone--scaling) {
    flex: 4;
    background: linear-gradient(to right, #fbbf24, #f97316);
  }
  :global(.lsi-calc__gauge-marker) {
    position: absolute;
    top: 50%;
    left: 0;
    width: 14px;
    height: 14px;
    background: #ffffff;
    border: 3px solid var(--color-primary);
    border-radius: 50%;
    /* Use transform instead of animating `left` — translateX skips layout/paint
       and runs on the GPU. --pos is set inline by the component (0–100). */
    transform: translate(calc(var(--pos, 50) * 1% - 50%), -50%);
    box-shadow: 0 2px 5px rgba(0, 20, 40, 0.3);
    transition: transform 300ms cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: transform;
  }
  :global(.lsi-calc__gauge-labels) {
    display: flex;
    justify-content: space-between;
    font-size: 0.58rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-500);
  }

  /* ============ Sanitation pillar: Tesla-style tab switcher ============ */
  /* Pill-shaped segmented control with a sliding indicator that translates
     between tab positions. Inspired by Tesla's in-car drive-mode selector. */
  :global(.sp-tabs) {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  :global(.sp-tabs__switcher) {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: rgba(10, 30, 55, 0.08);
    border-radius: 999px;
    padding: 3px;
    width: 100%;
    max-width: 320px;
    margin: 0 auto;
  }
  :global(.sp-tabs__indicator) {
    position: absolute;
    top: 3px;
    bottom: 3px;
    left: 3px;
    width: calc(50% - 3px);
    background: var(--color-primary);
    border-radius: 999px;
    transition: transform 260ms cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 0;
  }
  :global(.sp-tabs__btn) {
    position: relative;
    z-index: 1;
    padding: 0.42rem 0.75rem;
    background: transparent;
    border: none;
    color: var(--color-gray-600);
    font-family: inherit;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: color 200ms ease;
  }
  :global(.sp-tabs__btn.is-active) {
    color: #ffffff;
  }
  :global(.sp-tabs__panel) {
    /* Panels are hard-swapped (no crossfade), keeping state isolated */
  }

  /* ============ HOCl Waterfall (Sanitation · Tab 1) ============ */
  :global(.hwf) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--color-text);
  }
  :global(.hwf__intro) {
    font-size: 0.7rem;
    line-height: 1.4;
    margin: 0;
    color: var(--color-text);
    font-weight: 500;
  }
  :global(.hwf__intro em) {
    font-style: italic;
    color: var(--color-primary);
    font-weight: 700;
  }
  :global(.hwf__intro strong) {
    color: var(--color-primary);
    font-weight: 800;
  }
  /* Chart wrapper — holds tooltip zone (above) + SVG (below).
     onMouseLeave on the wrapper keeps hover persistent as the cursor
     moves from a bar up into the tooltip zone. */
  :global(.hwf__chart-wrap) {
    position: relative;
    width: 100%;
  }
  :global(.hwf__chart) {
    width: 100%;
    height: auto;
    display: block;
  }
  /* Segment hit areas — subtle hover highlight so it's clear what's
     being hovered without washing out the color coding. */
  :global(.hwf__seg) {
    cursor: help;
    transition: filter 180ms ease;
  }
  :global(.hwf__seg.is-hover) {
    filter: brightness(1.08) drop-shadow(0 0 4px rgba(10, 30, 55, 0.2));
  }

  /* ======= Hover tooltip popovers ======= */
  /* Pinned to the TOP-RIGHT corner of the chart wrapper. Width is capped
     at ~35% of the container so the left edge of the tooltip never
     reaches col1 or col2 — it lives in col3's empty upper area. Height
     is unconstrained; taller tooltips (like Bound with its action button)
     extend DOWN past the chart into the meter area, which the user
     explicitly said is fine ("can overlap other content, not graph content"). */
  :global(.hwf__tip) {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 35%;
    min-width: 140px;
    max-width: 210px;
    padding: 0.42rem 0.55rem 0.5rem;
    background: #ffffff;
    border: 1.5px solid rgba(10, 30, 55, 0.14);
    border-radius: 10px;
    box-shadow: 0 10px 26px rgba(0, 20, 40, 0.2);
    z-index: 10;
    pointer-events: auto;
    opacity: 0;
    animation: hwf-tip-in 180ms ease-out forwards;
  }
  @keyframes hwf-tip-in {
    to { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.hwf__tip) {
      animation: none;
      opacity: 1;
    }
  }
  :global(.hwf__tip-title) {
    margin: 0 0 0.2rem 0;
    font-size: 0.64rem;
    font-weight: 800;
    color: var(--color-primary);
    letter-spacing: 0.01em;
  }
  :global(.hwf__tip-body) {
    margin: 0;
    font-size: 0.6rem;
    line-height: 1.4;
    color: var(--color-gray-700, #334155);
  }
  :global(.hwf__tip-body strong) {
    font-weight: 800;
    color: var(--color-primary);
  }
  :global(.hwf__tip-body em) {
    font-style: italic;
    color: var(--color-primary);
    font-weight: 700;
  }
  :global(.hwf__tip-btn) {
    margin-top: 0.35rem;
    padding: 0.22rem 0.55rem;
    background: var(--color-primary);
    border: none;
    border-radius: 999px;
    color: #ffffff;
    font-family: inherit;
    font-size: 0.55rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 150ms ease-out, transform 150ms ease-out;
  }
  :global(.hwf__tip-btn:hover) {
    background: var(--color-primary-dark, #0a1e37);
    transform: translateX(2px);
  }

  /* Accent bar on the left edge — colors the tooltip by segment identity */
  :global(.hwf__tip--ocl) { border-left: 4px solid #cbd5e1; }
  :global(.hwf__tip--hocl) { border-left: 4px solid #06b6d4; }
  :global(.hwf__tip--bound) { border-left: 4px solid #94a3b8; }
  :global(.hwf__tip--active) { border-left: 4px solid #10b981; }
  /* Zoomed floor meter — shows the tiny Active HOCl value against the
     0.05 ppm algae floor on an auto-scaling 0-to-max scale. */
  :global(.hwf__meter) {
    width: 100%;
    height: auto;
    display: block;
    margin-top: -0.3rem;
  }
  /* Status callout — Protected / Deficient badge + margin to floor */
  :global(.hwf__status) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.65rem;
    border-radius: 10px;
    border: 1.5px solid transparent;
    font-size: 0.7rem;
    line-height: 1.35;
  }
  :global(.hwf__status.is-safe) {
    background: rgba(16, 185, 129, 0.08);
    border-color: rgba(16, 185, 129, 0.35);
    color: #065f46;
  }
  :global(.hwf__status.is-unsafe) {
    background: rgba(239, 68, 68, 0.08);
    border-color: rgba(239, 68, 68, 0.38);
    color: #991b1b;
  }
  /* Animation-running state — blue tint, pulsing badge */
  :global(.hwf__status.is-animating) {
    background: rgba(14, 165, 233, 0.08);
    border-color: rgba(14, 165, 233, 0.38);
    color: #075985;
  }
  :global(.hwf__status.is-animating .hwf__status-badge) {
    background: #0ea5e9;
    color: #ffffff;
    animation: hwf-pulse 1.2s ease-in-out infinite;
  }
  @keyframes hwf-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.55; }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.hwf__status.is-animating .hwf__status-badge) {
      animation: none;
    }
  }
  /* Post-animation "exhausted" state — dark red tint + reset button */
  :global(.hwf__status.is-depleted) {
    background: rgba(127, 29, 29, 0.08);
    border-color: rgba(127, 29, 29, 0.35);
    color: #7f1d1d;
  }
  :global(.hwf__status.is-depleted .hwf__status-badge) {
    background: #7f1d1d;
    color: #ffffff;
  }
  /* Paused mid-playback state — gray tint, reset available */
  :global(.hwf__status.is-stopped) {
    background: rgba(71, 85, 105, 0.08);
    border-color: rgba(71, 85, 105, 0.35);
    color: #334155;
  }
  :global(.hwf__status.is-stopped .hwf__status-badge) {
    background: #475569;
    color: #ffffff;
  }
  /* Inline "crossed the floor" marker — shown during animation and
     preserved in the stopped/depleted states as a remembered moment. */
  :global(.hwf__status-mark) {
    font-weight: 800;
    color: #b91c1c;
  }
  /* Stop button — appears in the animating status, cancels playback */
  :global(.hwf__stop-btn) {
    flex: 0 0 auto;
    padding: 0.2rem 0.6rem;
    background: transparent;
    border: 1.5px solid rgba(14, 165, 233, 0.5);
    border-radius: 999px;
    color: #0369a1;
    font-family: inherit;
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: background 150ms ease, color 150ms ease, border-color 150ms ease;
  }
  :global(.hwf__stop-btn:hover) {
    background: #0ea5e9;
    color: #ffffff;
    border-color: #0ea5e9;
  }
  :global(.hwf__reset-btn) {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: 0.4rem;
    padding: 0.15rem 0.55rem;
    background: transparent;
    border: 1.5px solid rgba(127, 29, 29, 0.6);
    border-radius: 999px;
    color: #7f1d1d;
    font-family: inherit;
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: background 150ms ease, color 150ms ease, border-color 150ms ease;
  }
  :global(.hwf__reset-btn:hover) {
    background: #7f1d1d;
    color: #ffffff;
    border-color: #7f1d1d;
  }
  /* Resume button — pairs with Reset in the stopped state */
  :global(.hwf__resume-btn) {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: 0.4rem;
    padding: 0.18rem 0.6rem;
    background: #10b981;
    border: 1.5px solid #10b981;
    border-radius: 999px;
    color: #ffffff;
    font-family: inherit;
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: background 150ms ease-out, border-color 150ms ease-out, transform 150ms ease-out;
  }
  :global(.hwf__resume-btn:hover) {
    background: #059669;
    border-color: #059669;
    transform: translateX(1px);
  }
  /* Secondary hint text inside the idle status — shows min FC needed */
  :global(.hwf__status-hint) {
    display: inline-block;
    margin-left: 0.1rem;
    padding: 0.06rem 0.38rem;
    background: rgba(245, 158, 11, 0.15);
    border: 1px solid rgba(245, 158, 11, 0.45);
    border-radius: 999px;
    color: #92400e;
    font-size: 0.6rem;
    font-weight: 700;
  }
  :global(.hwf__status-hint strong) {
    font-weight: 800;
    color: #78350f;
  }

  /* ======= Next-step CTA (below protected status) =======
     "Once you know the right level, the next question is whether your
     equipment can maintain it." — links to Tab 2 (Daily Protection). */
  :global(.hwf__next-step) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    padding: 0.45rem 0.7rem;
    background: linear-gradient(135deg, rgba(14, 165, 233, 0.08), rgba(6, 182, 212, 0.1));
    border: 1.5px solid rgba(14, 165, 233, 0.3);
    border-radius: 10px;
    margin-top: -0.15rem;
  }
  :global(.hwf__next-step-text) {
    flex: 1;
    margin: 0;
    font-size: 0.68rem;
    line-height: 1.4;
    color: var(--color-primary);
    font-weight: 500;
  }
  :global(.hwf__next-btn) {
    flex: 0 0 auto;
    padding: 0.35rem 0.8rem;
    background: var(--color-primary);
    border: none;
    border-radius: 999px;
    color: #ffffff;
    font-family: inherit;
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 150ms ease-out, transform 150ms ease-out;
    white-space: nowrap;
  }
  :global(.hwf__next-btn:hover) {
    background: var(--color-primary-dark, #0a1e37);
    transform: translateX(2px);
  }
  :global(.hwf__status-badge) {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    flex: 0 0 auto;
  }
  :global(.hwf__status.is-safe .hwf__status-badge) {
    background: #10b981;
    color: #ffffff;
  }
  :global(.hwf__status.is-unsafe .hwf__status-badge) {
    background: #dc2626;
    color: #ffffff;
  }
  :global(.hwf__status-text) {
    flex: 1;
    min-width: 0;
  }
  :global(.hwf__status-text strong) {
    font-weight: 800;
  }
  /* Inputs — FC + pH + CYA sliders in a 3-col grid */
  :global(.hwf__inputs) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.4rem 0.85rem;
    padding-top: 0.15rem;
    transition: opacity 220ms ease;
  }
  /* While the depletion animation is running, dim the sliders and
     disable interaction so the user can't fight the playback. */
  :global(.hwf__inputs.is-locked) {
    pointer-events: none;
    opacity: 0.45;
  }
  @media (max-width: 680px) {
    :global(.hwf__inputs) {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 440px) {
    :global(.hwf__inputs) {
      grid-template-columns: 1fr;
    }
  }

  /* ============ HOCl Time-Series Calculator (Sanitation pillar) ============ */
  :global(.hocl-calc) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--color-text);
  }
  :global(.hocl-calc__intro) {
    font-size: 0.72rem;
    line-height: 1.4;
    color: var(--color-text);
    font-weight: 500;
    margin: 0;
  }
  :global(.hocl-calc__intro em) {
    font-style: italic;
    color: var(--color-primary);
    font-weight: 700;
  }
  :global(.hocl-calc__disclaimer) {
    display: inline;
    font-style: italic;
    color: var(--color-gray-500);
    font-weight: 500;
  }

  /* ======= Top row: chem header + day/night toggle ======= */
  :global(.hocl-calc__top-row) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  :global(.hocl-calc__intro) {
    font-size: 0.65rem;
    line-height: 1.5;
    color: var(--color-gray-500);
    margin: 0 0 0.4rem;
  }
  :global(.hocl-calc__chem) {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  :global(.hocl-calc__chem-item) {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
  }
  :global(.hocl-calc__chem-label) {
    font-size: 0.55rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-500);
  }
  :global(.hocl-calc__chem-value) {
    font-family: var(--font-heading, inherit);
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--color-primary);
  }
  :global(.hocl-calc__chem-unit) {
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--color-gray-500);
  }
  /* chem-from removed — intro paragraph provides context */

  /* ======= FC IN / FC OUT budget blocks ======= */
  :global(.hocl-budget-row) {
    display: flex;
    gap: 0.4rem;
  }
  :global(.hocl-budget-row > .hocl-budget) {
    flex: 1;
    min-width: 0;
  }
  :global(.hocl-budget__sliders--stacked) {
    flex-direction: column;
    gap: 0.2rem;
  }
  :global(.hocl-budget) {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.45rem 0.6rem;
    border-radius: 8px;
    border: 1px solid rgba(10, 30, 55, 0.08);
  }
  :global(.hocl-budget--in) {
    background: rgba(16, 185, 129, 0.04);
    border-color: rgba(16, 185, 129, 0.2);
  }
  :global(.hocl-budget--out) {
    background: rgba(239, 68, 68, 0.04);
    border-color: rgba(239, 68, 68, 0.2);
  }
  :global(.hocl-budget__heading) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.4rem;
  }
  :global(.hocl-budget__heading-left) {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  :global(.hocl-budget__heading-total) {
    font-family: var(--font-heading, inherit);
    font-size: 0.72rem;
    font-weight: 800;
  }
  :global(.hocl-budget__heading-total--in) { color: #047857; }
  :global(.hocl-budget__heading-total--out) { color: #b91c1c; }
  :global(.hocl-budget__title) {
    font-size: 0.6rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  :global(.hocl-budget--in .hocl-budget__title) { color: #047857; }
  :global(.hocl-budget--out .hocl-budget__title) { color: #b91c1c; }
  :global(.hocl-budget__subtitle) {
    font-size: 0.5rem;
    font-weight: 600;
    color: var(--color-gray-400);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  :global(.hocl-budget__sliders) {
    display: flex;
    gap: 1rem;
  }
  :global(.hocl-budget__sliders .hocl-slider) {
    flex: 1;
  }
  /* total-unit is reused inside heading-total */
  :global(.hocl-budget__total-unit) {
    font-size: 0.52rem;
    font-weight: 700;
    color: var(--color-gray-500);
  }

  /* ======= Day / Night mini-pill toggle ======= */
  :global(.hocl-timeview) {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: rgba(10, 30, 55, 0.06);
    border-radius: 999px;
    padding: 2px;
    width: fit-content;
    margin: 0;
  }
  :global(.hocl-timeview__indicator) {
    position: absolute;
    top: 2px;
    bottom: 2px;
    left: 2px;
    width: calc(50% - 2px);
    background: var(--color-primary);
    border-radius: 999px;
    transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  :global(.hocl-timeview__btn) {
    position: relative;
    z-index: 1;
    padding: 0.25rem 0.65rem;
    background: transparent;
    border: none;
    font-family: inherit;
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-500);
    cursor: pointer;
    transition: color 200ms ease;
  }
  :global(.hocl-timeview__btn.is-active) {
    color: #ffffff;
  }

  /* ======= FC label on cards ======= */
  :global(.hocl-card__fc-label) {
    font-size: 0.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-500);
  }

  /* ======= Budget comparison bars (in status section) ======= */
  :global(.hocl-budget-comparison) {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-top: 0.35rem;
  }
  :global(.hocl-budget-bar) {
    height: 16px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    padding: 0 0.4rem;
    min-width: 50px;
  }
  :global(.hocl-budget-bar--in) {
    background: rgba(16, 185, 129, 0.2);
    border: 1px solid rgba(16, 185, 129, 0.4);
  }
  :global(.hocl-budget-bar--out) {
    background: rgba(239, 68, 68, 0.2);
    border: 1px solid rgba(239, 68, 68, 0.4);
  }
  :global(.hocl-budget-bar__label) {
    font-size: 0.5rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  :global(.hocl-budget-bar--in .hocl-budget-bar__label) { color: #047857; }
  :global(.hocl-budget-bar--out .hocl-budget-bar__label) { color: #b91c1c; }
  :global(.hocl-budget-net) {
    font-family: var(--font-mono, monospace);
    font-size: 0.52rem;
    font-weight: 700;
    color: var(--color-gray-500);
    text-align: right;
  }

  /* ======= Demand source rows ======= */
  :global(.hocl-demand-sources) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  :global(.hocl-demand-row) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem;
    min-height: 24px;
  }
  :global(.hocl-demand-row__left) {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex: 1;
    min-width: 0;
  }
  :global(.hocl-demand-row__icon) {
    font-size: 0.8rem;
    flex: 0 0 auto;
  }
  :global(.hocl-demand-row__label) {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-primary);
    flex: 0 0 auto;
