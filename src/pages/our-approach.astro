---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Our Approach to Pool Care | Perfect Pools"
  description="Pool care isn't guesswork — it's chemistry, consistency, and accountability. Learn how Perfect Pools keeps your water balanced year-round in coastal Georgia."
  canonicalPath="/our-approach"
>
  <section class="liquid-hero">
    <div id="liquid-hero-mount"></div>

    <!-- HTML overlay for interactive elements -->
    <div class="liquid-hero__overlay">
      <p class="liquid-hero__subtitle">
        Why clear water isn't luck — it's science, consistency, and accountability.
      </p>
      <div class="liquid-hero__buttons">
        <a href="/get-started" class="btn btn--cta btn--lg">View Service Plans</a>
        <a href="#pillars" class="btn btn--outline-white btn--lg">See How We Work</a>
      </div>
    </div>

    <div class="liquid-hero__wave">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none" fill="none">
        <path d="M0,60 C240,120 480,0 720,60 C960,120 1200,0 1440,60 L1440,120 L0,120 Z" fill="var(--color-bg)" />
      </svg>
    </div>
  </section>

  <!-- Section 2: Three Pillars Triangle (Interactive) -->
  <section class="section pillars-section" id="pillars">
    <div class="container">
      <div class="section-header">
        <h2>Three pillars of Perfect Pool care</h2>
        <p>Every visit is built on chemistry, equipment health, and transparency — working together as one system.</p>
      </div>

      <div id="pillars-mount"></div>
    </div>
  </section>

  <!-- Section 3: Industry vs Us Comparison -->
  <section class="section compare-section">
    <div class="container">
      <div class="compare-card">
        <div class="compare-card__divider"></div>

        <!-- Left: Industry Standard -->
        <div class="compare-side compare-side--industry">
          <div class="compare-side__header">
            <span class="compare-label">The Industry Standard</span>
            <h3 class="compare-title">Chaos & Reaction</h3>
          </div>
          <div class="compare-points">
            <div class="compare-point">
              <div class="compare-icon compare-icon--bad">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              </div>
              <div>
                <h4 class="compare-point__title">Reactive Treatment</h4>
                <p class="compare-point__desc">Chemicals dumped only after algae blooms or equipment fails. Constant catch-up.</p>
                <div class="compare-bar compare-bar--chaotic">
                  <span style="left: 0; width: 33%;"></span>
                  <span style="left: 50%; width: 25%;"></span>
                </div>
              </div>
            </div>
            <div class="compare-point">
              <div class="compare-icon compare-icon--bad">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              </div>
              <div>
                <h4 class="compare-point__title">Inconsistent Visits</h4>
                <p class="compare-point__desc">No proof of service duration or specific tasks completed. The "splash and dash".</p>
                <div class="compare-bar compare-bar--gaps">
                  <span></span><span class="empty"></span><span></span><span></span><span class="empty"></span>
                </div>
              </div>
            </div>
            <div class="compare-point">
              <div class="compare-icon compare-icon--bad">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              </div>
              <div>
                <h4 class="compare-point__title">Hidden Chemical Costs</h4>
                <p class="compare-point__desc">Opaque billing with sudden spikes for shock treatments and algaecides.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Our Approach -->
        <div class="compare-side compare-side--ours">
          <div class="compare-side__header">
            <span class="compare-label compare-label--accent">Our Systematic Approach</span>
            <h3 class="compare-title compare-title--dark">Structure & Perfection</h3>
          </div>
          <div class="compare-points">
            <div class="compare-point">
              <div class="compare-icon compare-icon--good">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <h4 class="compare-point__title">Proactive Asset Management</h4>
                <p class="compare-point__desc">Micro-adjustments made weekly based on precise baseline testing. Zero algae, ever.</p>
                <div class="compare-bar compare-bar--solid"></div>
              </div>
            </div>
            <div class="compare-point">
              <div class="compare-icon compare-icon--good">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <h4 class="compare-point__title">Timestamped Verification</h4>
                <p class="compare-point__desc">Digital logs of exact arrival times, chemical dosing, and photographic evidence.</p>
                <div class="compare-bar compare-bar--consistent">
                  <span></span><span></span><span></span><span></span><span></span>
                </div>
              </div>
            </div>
            <div class="compare-point">
              <div class="compare-icon compare-icon--good">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.5 3.5L13 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <h4 class="compare-point__title">Transparent Chemical Dosing</h4>
                <p class="compare-point__desc">Flat-rate predictability. We absorb the fluctuations of chemical markets, not you.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { render, h } from 'preact';
  import LiquidHero from '../components/LiquidHero.tsx';
  import PillarsTriangle from '../components/PillarsTriangle.tsx';

  const mount = document.getElementById('liquid-hero-mount');
  if (mount) {
    render(h(LiquidHero, null), mount);
  }

  const pillarsMount = document.getElementById('pillars-mount');
  if (pillarsMount) {
    render(h(PillarsTriangle, null), pillarsMount);
  }
</script>

<style>
  .liquid-hero {
    position: relative;
    min-height: 85vh;
    overflow: hidden;
    background: url('/images/pool-tile-nice.webp') center center / cover no-repeat;
    background-color: #0369a1;
  }

  #liquid-hero-mount {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .liquid-hero__overlay {
    position: absolute;
    bottom: 14%;
    left: 0;
    right: 0;
    z-index: 2;
    text-align: center;
    padding: 0 var(--container-padding);
  }

  .liquid-hero__subtitle {
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 1.8vw, 1.15rem);
    color: rgba(255, 255, 255, 0.85);
    max-width: 520px;
    margin: 0 auto var(--space-6);
    line-height: 1.6;
    text-shadow: 0 1px 8px rgba(0, 40, 60, 0.3);
  }

  .liquid-hero__buttons {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .liquid-hero__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    z-index: 1;
    line-height: 0;
  }

  .liquid-hero__wave svg {
    width: 100%;
    height: 80px;
  }

  @media (max-width: 768px) {
    .liquid-hero { min-height: 70vh; }
    .liquid-hero__overlay { bottom: 12%; }
    .liquid-hero__wave svg { height: 50px; }
  }

  /* === Comparison Section === */
  .compare-section {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
  }

  .compare-card {
    display: flex;
    flex-direction: column;
    position: relative;
    background: #fff;
    box-shadow: 0 25px 50px -12px rgba(11, 19, 32, 0.08);
    border: 1px solid #e5e5e5;
  }

  .compare-card__divider {
    display: none;
  }

  @media (min-width: 768px) {
    .compare-card {
      flex-direction: row;
    }
    .compare-card__divider {
      display: block;
      position: absolute;
      top: 0;
      bottom: 0;
      left: 50%;
      width: 1px;
      background: #e5e5e5;
      z-index: 1;
    }
  }

  .compare-side {
    flex: 1;
    padding: 2.5rem;
  }

  @media (min-width: 768px) {
    .compare-side { padding: 3.5rem; }
  }

  @media (min-width: 1024px) {
    .compare-side { padding: 4rem 5rem; }
  }

  .compare-side--industry {
    background: #fafafa;
  }

  .compare-side--ours {
    background: #fff;
  }

  .compare-side__header {
    margin-bottom: 2.5rem;
  }

  .compare-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
  }

  .compare-label--accent {
    color: var(--color-cta);
  }

  .compare-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 1.85rem);
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .compare-title--dark {
    color: #0B1320;
  }

  .compare-points {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .compare-point {
    display: flex;
    gap: 1.25rem;
  }

  .compare-icon {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.15rem;
  }

  .compare-icon--bad {
    border: 1px solid #fecaca;
    background: #fef2f2;
    color: #ef4444;
  }

  .compare-icon--good {
    border: 1px solid var(--color-cta);
    background: rgba(224, 182, 41, 0.1);
    color: var(--color-cta);
  }

  .compare-point__title {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
    margin-bottom: 0.35rem;
  }

  .compare-point__desc {
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--color-text-light);
  }

  /* Visual bars */
  .compare-bar {
    margin-top: 0.85rem;
    height: 0.4rem;
    position: relative;
    background: #e5e7eb;
    overflow: hidden;
  }

  .compare-bar--chaotic span {
    position: absolute;
    top: 0;
    bottom: 0;
    background: #ef4444;
    opacity: 0.55;
  }

  .compare-bar--gaps {
    display: flex;
    gap: 3px;
    background: transparent;
  }

  .compare-bar--gaps span {
    flex: 1;
    height: 0.4rem;
    background: #fca5a5;
  }

  .compare-bar--gaps span.empty {
    background: transparent;
  }

  .compare-bar--solid {
    background: linear-gradient(to right, rgba(224, 182, 41, 0.4), rgba(224, 182, 41, 0.8));
  }

  .compare-bar--consistent {
    display: flex;
    gap: 3px;
    background: transparent;
  }

  .compare-bar--consistent span {
    flex: 1;
    height: 0.4rem;
    background: rgba(224, 182, 41, 0.6);
  }

  /* === Pillars Section === */
  .pillars-section {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
    background: #fafafa;
  }

  /* Interactive pillars — :global() because Preact renders these */
  :global(.pillars-interactive) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    margin-top: var(--space-10);
  }

  @media (min-width: 900px) {
    :global(.pillars-interactive) {
      flex-direction: row;
      align-items: center;
      gap: 2.5rem;
    }
  }

  :global(.pillars-interactive__diagram) {
    flex-shrink: 0;
    width: 100%;
    max-width: 420px;
  }

  @media (min-width: 900px) {
    :global(.pillars-interactive__diagram) {
      flex: 0 0 55%;
      width: 55%;
      max-width: 55%;
    }
  }

  :global(.pillars-interactive__svg) {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.1));
  }

  :global(.pillars-interactive__panel) {
    flex: 1;
    background: #fff;
    border-radius: 12px;
    border: 2px solid #e5e7eb;
    padding: 2rem;
    min-height: 180px;
    animation: panelFadeIn 0.3s ease;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    transition: border-color 0.3s ease;
  }

  @keyframes panelFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  :global(.pi-panel__header) {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #f0f0f0;
  }

  :global(.pi-panel__icon) {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
  }

  :global(.pi-panel__icon img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  :global(.pi-panel__title) {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 600;
    line-height: 1.3;
  }

  :global(.pi-panel__body) {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--color-text-light);
  }

  :global(.pi-panel__body p) {
    margin-bottom: 0.75rem;
  }
</style>
