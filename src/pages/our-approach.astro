---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReviewCarousel from '../components/ReviewCarousel.astro';
const base = import.meta.env.BASE_URL;

/**
 * Our Approach — continuous-focus storytelling
 *
 * Design intent: the whole page reads as one continuous canvas, not a
 * stack of separately-boxed sections. There are no alternating section
 * backgrounds and no hard clip-path reveals. Instead, BaseLayout paints
 * fixed-position "focus vignettes" at the top and bottom of the viewport
 * that fade content into the body color as it approaches the edges. The
 * user's eye stays locked on the middle of the viewport and content
 * softly dissolves in/out at the edges as they scroll.
 *
 * Pinned sections keep their internal card-stack animations. Section
 * wrappers stay plain <section> tags — no SectionReveal gymnastics,
 * because the focus vignette handles all the visual emphasis.
 */
---

<BaseLayout
  title="Our Approach to Pool Care | Perfect Pools"
  description="Pool care isn't guesswork — it's chemistry, consistency, and accountability. Learn how Perfect Pools keeps your water balanced year-round in coastal Georgia."
  canonicalPath="/our-approach"
  focusOverlay
>
  {/* Section 1 — Problem Statement (cinematic card stack) */}
  <section class="section problem-section oa-section">
    <div class="container">
      <div id="problem-mount"></div>
    </div>
  </section>

  {/* Section 2 — Our Story (company timeline) */}
  <section class="section oa-section" id="our-story">
    <div class="container">
      <div id="timeline-mount"></div>
    </div>
  </section>

  {/* Section 3 — Three Pillars */}
  <section class="section pillars-section oa-section" id="pillars">
    <div class="container">
      <div id="pillars-mount"></div>
    </div>
  </section>

  {/* Section 4 — Industry vs Us Comparison */}
  <section class="section compare-scroll-section oa-section">
    <div class="container">
      <div id="compare-mount"></div>
    </div>
  </section>

  {/* Section 5 — Anatomy of a Visit */}
  <section class="section visit-section oa-section" id="visit">
    <div class="container">
      <div id="visit-mount"></div>
    </div>
  </section>

  {/* Section 6 — Reviews */}
  <section class="section oa-section" id="reviews">
    <div class="container">
      <div class="section-header">
        <span class="section-kicker">WHAT OUR CLIENTS SAY</span>
        <h2>Real Reviews, Real Results.</h2>
      </div>
      <ReviewCarousel />
      <div style="text-align: center; margin-top: var(--space-8);">
        <a href="https://g.page/r/CVrU0W_3-NRyEAE/review" target="_blank" rel="noopener" class="btn btn--outline">Read All Reviews on Google</a>
      </div>
    </div>
  </section>

  {/* Section 7 — Final CTA */}
  <section class="partnership-cta oa-section">
    <div class="container">
      <div class="partnership-cta__card">
        <h2>Start Your Aquatic Partnership</h2>
        <p>Experience the difference of architectural-grade maintenance. We are currently accepting new clients for our exclusive service routes.</p>
        <div class="partnership-cta__buttons">
          <a href={`${base}get-started/`} class="btn btn--cta btn--lg">Join Our Route</a>
          <a href={`${base}plans/`} class="btn btn--outline-white btn--lg">View Pricing</a>
        </div>
      </div>
    </div>
  </SectionReveal>
</BaseLayout>

<script>
  import { render, h } from 'preact';
  import ProblemScroll from '../components/ProblemScroll.tsx';
  import TimelineScroll from '../components/TimelineScroll.tsx';
  import PillarsScroll from '../components/PillarsScroll.tsx';
  import CompareScroll from '../components/CompareScroll.tsx';
  import VisitScroll from '../components/VisitScroll.tsx';

  const problemMount = document.getElementById('problem-mount');
  if (problemMount) {
    render(h(ProblemScroll, null), problemMount);
  }

  const timelineMount = document.getElementById('timeline-mount');
  if (timelineMount) {
    render(h(TimelineScroll, null), timelineMount);
  }

  const pillarsMount = document.getElementById('pillars-mount');
  if (pillarsMount) {
    render(h(PillarsScroll, null), pillarsMount);
  }

  const visitMount = document.getElementById('visit-mount');
  if (visitMount) {
    render(h(VisitScroll, null), visitMount);
  }

  // Service area carousel
  const track = document.getElementById('area-track');
  const prevBtn = document.getElementById('area-prev');
  const nextBtn = document.getElementById('area-next');
  if (track && prevBtn && nextBtn) {
    let offset = 0;
    const getCardWidth = () => {
      const card = track.querySelector('.coastal-area-card') as HTMLElement;
      if (!card) return 0;
      return card.offsetWidth + 16; // card width + gap
    };
    const getMaxOffset = () => {
      const visibleWidth = (track.parentElement as HTMLElement).offsetWidth;
      const totalWidth = track.scrollWidth;
      return Math.max(0, totalWidth - visibleWidth);
    };
    prevBtn.addEventListener('click', () => {
      offset = Math.max(0, offset - getCardWidth());
      track.style.transform = `translateX(-${offset}px)`;
    });
    nextBtn.addEventListener('click', () => {
      offset = Math.min(getMaxOffset(), offset + getCardWidth());
      track.style.transform = `translateX(-${offset}px)`;
    });
  }

  const compareMount = document.getElementById('compare-mount');
  if (compareMount) {
    render(h(CompareScroll, null), compareMount);
  }

  // After all Preact islands mount + resources load, refresh ScrollTrigger
  // so the scroll-card components see the final page height. The [data-reveal]
  // system in BaseLayout also calls refresh, but the card-stack components
  // mount asynchronously and need their own coordinated refresh.
  window.addEventListener('load', () => {
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        import('gsap/ScrollTrigger').then(({ ScrollTrigger }) => {
          ScrollTrigger.sort();
          ScrollTrigger.refresh();
        });
      });
    });
  });
</script>

<style>
  /* === Section Flow === */
  .oa-section {
    position: relative;
  }

  /* GPU compositing hints for scroll-animated cards */
  :global(.prb__card),
  :global(.ps__card),
  :global(.cs__card),
  :global(.vs__card),
  :global(.tl-card) {
    will-change: opacity, transform;
  }

  /* === Problem Scroll Section === */
  :global(.prb) {
    position: relative;
  }

  :global(.prb__header--mobile) { display: block; margin-bottom: var(--space-6); }
  :global(.prb__header--desktop) { display: none; }

  @media (min-width: 900px) {
    :global(.prb__header--mobile) { display: none; }
    :global(.prb__header--desktop) { display: block; margin-bottom: var(--space-8); }
  }

  :global(.prb__sticky) {
    min-height: 60vh;
    display: flex;
    flex-direction: column;
  }

  :global(.prb__card-stack) {
    position: relative;
    flex: 1;
  }

  :global(.prb__card) {
    border-radius: 20px;
    padding: 2.5rem;
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(.prb__card--dark) {
    background: #0B1320;
    color: #fff;
  }

  :global(.prb__card--resolve) {
    background: linear-gradient(135deg, #145BB8 0%, #1E3A5F 100%);
    color: #fff;
  }

  /* Cinematic cards — bold, centered, minimal */
  :global(.prb__cinematic) {
    text-align: center;
    max-width: 640px;
  }

  :global(.prb__cinematic-headline) {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  :global(.prb__cinematic-subline) {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 1.25rem;
  }

  :global(.prb__cinematic-body) {
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.5);
    max-width: 520px;
    margin: 0 auto;
  }

  /* Resolution card — content-rich */
  :global(.prb__resolve) {
    max-width: 560px;
  }

  :global(.prb__resolve-headline) {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  :global(.prb__resolve-body) {
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 1.5rem;
  }

  :global(.prb__resolve-bullets) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  :global(.prb__resolve-bullets li) {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
  }

  :global(.prb__resolve-bullets svg) {
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: #E28D33;
  }

  :global(.prb__spacer) {
    height: 400vh;
  }

  @media (max-width: 899px) {
    :global(.prb__card) {
      padding: 1.5rem;
      min-height: 280px;
    }
    :global(.prb__spacer) {
      height: 300vh;
    }
  }

  /* === Comparison Scroll Section === */
  .compare-scroll-section {
    padding-top: var(--space-16);
    padding-bottom: var(--space-12);
  }

  :global(.cs) {
    position: relative;
    margin-top: var(--space-10);
  }

  :global(.cs__sticky) {
    position: sticky;
    top: 100px;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
  }

  :global(.cs__header--mobile) {
    display: block;
    margin-bottom: var(--space-6);
  }

  :global(.cs__header--desktop) {
    display: none;
  }

  :global(.cs__card-stack) {
    position: relative;
  }

  :global(.cs__card) {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    pointer-events: none;
  }

  :global(.cs__card:first-child) {
    position: relative;
  }

  :global(.cs__card.is-active) {
    pointer-events: auto;
  }

  /* Each compare side gets ~100vh of scroll distance (2 sides × 100vh = 200vh) */
  :global(.cs__spacer) {
    height: 200vh;
  }

  :global(.compare-card) {
    max-width: 700px;
    margin: 0 auto;
    background: #fff;
    padding: 2.5rem;
    box-shadow: var(--shadow-md);
    border: 1px solid #e5e5e5;
    border-radius: var(--radius-lg);
    animation: cardFadeIn 0.35s ease;
  }

  :global(.compare-side__header) {
    margin-bottom: 2.5rem;
  }

  :global(.compare-label) {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
  }

  :global(.compare-label--accent) {
    color: var(--color-cta);
  }

  :global(.compare-title) {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 1.85rem);
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  :global(.compare-title--dark) {
    color: #0B1320;
  }

  :global(.compare-points) {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  :global(.compare-point) {
    display: flex;
    gap: 1.25rem;
  }

  :global(.compare-icon) {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.15rem;
  }

  :global(.compare-icon--bad) {
    border: 1px solid #fecaca;
    background: #fef2f2;
    color: #ef4444;
  }

  :global(.compare-icon--good) {
    border: 1px solid var(--color-cta);
    background: rgba(224, 182, 41, 0.1);
    color: var(--color-cta);
  }

  :global(.compare-point__title) {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
    margin-bottom: 0.35rem;
  }

  :global(.compare-point__desc) {
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--color-text-light);
  }

  :global(.compare-bar) {
    margin-top: 0.85rem;
    height: 0.4rem;
    position: relative;
    background: #e5e7eb;
    overflow: hidden;
  }

  :global(.compare-bar--chaotic span) {
    position: absolute;
    top: 0;
    bottom: 0;
    background: #ef4444;
    opacity: 0.55;
  }

  :global(.compare-bar--gaps) {
    display: flex;
    gap: 3px;
    background: transparent;
  }

  :global(.compare-bar--gaps span) {
    flex: 1;
    height: 0.4rem;
    background: #fca5a5;
  }

  :global(.compare-bar--gaps span.empty) {
    background: transparent;
  }

  :global(.compare-bar--solid) {
    background: linear-gradient(to right, rgba(224, 182, 41, 0.4), rgba(224, 182, 41, 0.8));
  }

  :global(.compare-bar--consistent) {
    display: flex;
    gap: 3px;
    background: transparent;
  }

  :global(.compare-bar--consistent span) {
    flex: 1;
    height: 0.4rem;
    background: rgba(224, 182, 41, 0.6);
  }

  .pillars-section {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
  }

  /* === Scroll-Driven Pillars (Preact-rendered, needs :global) === */

  :global(.pillars-interactive__svg) {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.1));
  }

  /* Mobile: stacked layout — diagram on top, cards below, scroll still works */
  :global(.ps) {
    margin-top: var(--space-6);
    position: relative;
  }

  :global(.ps__sticky-col) {
    position: sticky;
    top: 50px;
    z-index: 1;
    padding-bottom: 1rem;
    /* Background intentionally inherited from the parent section so the
       pinned sticky matches whatever the section's background is (white
       for Pillars). A hardcoded bg here previously leaked warm sand into
       the Pillars section even after the section bg was removed. */
  }

  /* Mobile: show the non-sticky header, hide the sticky one */
  :global(.ps__header--mobile) {
    display: block;
    margin-bottom: var(--space-6);
  }

  :global(.ps__header--desktop) {
    display: none;
  }

  :global(.ps__content-row) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  :global(.ps__diagram) {
    max-width: 220px;
    width: 100%;
  }

  :global(.ps__card) {
    padding: 1.25rem;
  }

  :global(.ps__card-header) {
    gap: 0.65rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.65rem;
  }

  :global(.ps__card-icon) {
    width: 36px;
    height: 36px;
    padding: 6px;
  }

  :global(.ps__card-title) {
    font-size: 1rem;
  }

  :global(.ps__card-body) {
    font-size: 0.85rem;
  }

  :global(.ps__mobile-diagram) {
    display: none;
  }

  /* Card stack — all cards layered, only active visible via crossfade */
  :global(.ps__card-stack) {
    position: relative;
  }

  :global(.ps__card) {
    background: #fff;
    border-radius: var(--radius-lg);
    border: 2px solid #e5e7eb;
    padding: 2rem;
    box-shadow: var(--shadow-md);
    /* GSAP controls opacity/transform — just set positioning */
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    pointer-events: none;
  }

  :global(.ps__card:first-child) {
    position: relative;
  }

  :global(.ps__card.is-active) {
    pointer-events: auto;
  }

  /* Scroll spacer — creates scroll distance for the progress calculation */
  /* Each pillar gets ~100vh of scroll distance (4 pillars × 100vh = 400vh) */
  :global(.ps__spacer) {
    height: 400vh;
  }

  :global(.ps__card-header) {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #f0f0f0;
  }

  :global(.ps__card-icon) {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
  }

  :global(.ps__card-icon img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  :global(.ps__card-title) {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-weight: 600;
    line-height: 1.3;
  }

  :global(.ps__card-body) {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--color-text-light);
  }

  :global(.ps__card-body p) {
    margin-bottom: 0.75rem;
  }

  /* Desktop: sticky left column (diagram + card), invisible scroll track right */
  @media (min-width: 900px) {
    :global(.ps) {
      display: flex;
      align-items: flex-start;
      position: relative;
    }

    :global(.ps__sticky-col) {
      top: 80px;
      /* Background intentionally inherited from the parent section
         (white for Pillars). A hardcoded warm-sand bg here leaked
         tan into the otherwise-white Pillars section on desktop. */
    }

    :global(.ps__header--mobile) {
      display: none;
    }

    :global(.ps__header--desktop) {
      display: block;
      margin-bottom: var(--space-8);
    }

    :global(.ps__content-row) {
      flex-direction: row;
      align-items: center;
      gap: 2rem;
    }

    :global(.ps__diagram) {
      flex: 0 0 50%;
      max-width: none;
    }

    :global(.ps__card-stack) {
      flex: 1;
    }

    :global(.cs__header--mobile) {
      display: none;
    }

    :global(.cs__header--desktop) {
      display: block;
      margin-bottom: var(--space-8);
    }
  }

  /* === Mobile overrides for comparison section === */
  @media (max-width: 899px) {
    :global(.cs) {
      margin-top: var(--space-6);
    }

    :global(.cs__sticky) {
      top: 50px;
    }

    /* compare headers already handled by global defaults */

    :global(.compare-card) {
      padding: 1.25rem;
    }

    :global(.compare-points) {
      gap: 1.5rem;
    }

    :global(.compare-point__title) {
      font-size: 0.85rem;
    }

    :global(.compare-point__desc) {
      font-size: 0.8rem;
    }

    :global(.cs__spacer) {
      height: 120vh;
    }
  }

  /* === Mobile overrides for pillar cards (after global card styles) === */
  @media (max-width: 899px) {
    /* ps__header visibility handled by --mobile/--desktop toggle */

    :global(.ps__card) {
      padding: 1.25rem !important;
    }

    :global(.ps__spacer) {
      height: 300vh;
    }

    :global(.ps__card-header) {
      gap: 0.65rem;
      margin-bottom: 0.75rem;
      padding-bottom: 0.65rem;
    }

    :global(.ps__card-icon) {
      width: 36px;
      height: 36px;
      padding: 6px;
    }

    :global(.ps__card-title) {
      font-size: 1rem;
    }

    :global(.ps__card-body) {
      font-size: 0.85rem;
    }

    :global(.ps__card-body p) {
      margin-bottom: 0.5rem;
    }
  }

  /* ========================================
     Coastal Expertise Section + Service Area Cards
     ======================================== */
  .coastal-wave {
    position: relative;
    z-index: 2;
    line-height: 0;
  }

  .coastal-wave svg {
    width: 100%;
    height: 64px;
    display: block;
  }

  .coastal-wave--top {
    margin-bottom: -1px;
    margin-top: var(--space-8);
  }

  .coastal-wave--bottom {
    margin-top: -1px;
    transform: rotate(180deg);
  }

  .coastal-section {
    background: #1E3A5F;
    color: #fff;
    padding: var(--space-16) 0;
    position: relative;
    z-index: 1;
    overflow: hidden;
  }

  .coastal-layout {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  @media (min-width: 900px) {
    .coastal-layout {
      flex-direction: row;
      gap: 4rem;
    }

    .coastal-wave svg {
      height: 96px;
    }
  }

  @media (min-width: 1100px) {
    .coastal-wave svg {
      height: 120px;
    }
  }

  /* Map graphic */
  .coastal-map {
    flex: 0 0 auto;
    width: 100%;
    max-width: 400px;
    position: relative;
  }

  @media (min-width: 900px) {
    .coastal-map {
      flex: 0 0 45%;
      max-width: none;
    }
  }

  .coastal-map__glow {
    position: absolute;
    inset: -10%;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 50%;
    filter: blur(40px);
  }

  .coastal-map__frame {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
    overflow: hidden;
    border: 3px solid rgba(255, 255, 255, 0.12);
    background: rgba(30, 40, 60, 0.5);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
  }

  .coastal-map__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.9;
    transition: opacity 0.7s ease;
  }

  .coastal-map__frame:hover .coastal-map__img {
    opacity: 0.75;
  }

  .coastal-map__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top right, rgba(30, 58, 95, 0.2), transparent);
  }

  .coastal-map__pin {
    position: absolute;
    top: 42%;
    left: 55%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .coastal-map__pulse {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #E28D33;
    margin-top: 2px;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.5); }
  }

  /* Content */
  .coastal-content {
    flex: 1;
  }

  .coastal-content__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: 1rem;
