---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReviewCarousel from '../components/ReviewCarousel.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Perfect Pools",
  "description": "Professional pool cleaning, maintenance, and repair services in Richmond Hill, Savannah, and the Greater Savannah area.",
  "url": "https://perfectpoolscleaning.com",
  "telephone": "(912) 459-0160",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "8989 Ford Ave",
    "addressLocality": "Richmond Hill",
    "addressRegion": "GA",
    "postalCode": "31324",
    "addressCountry": "US"
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "08:00",
    "closes": "17:00"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "127"
  }
};

/* Inline SVG icons (Lucide-style, 24x24 viewBox) */
const icons = {
  star: '<svg viewBox="0 0 24 24" fill="currentColor" stroke="none" class="icon"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>',
  droplets: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/></svg>',
  alertCircle: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>',
  arrowRight: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>',
  shield: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>',
  clock: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  testTube: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M14.5 2v17.5c0 1.4-1.1 2.5-2.5 2.5s-2.5-1.1-2.5-2.5V2"/><path d="M8.5 2h7"/><path d="M14.5 16h-5"/></svg>',
  eye: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>',
  home: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>',
  building: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>',
  thermometer: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z"/></svg>',
  settings: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>',
  cloudRain: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"/><path d="M16 14v6"/><path d="M8 14v6"/><path d="M12 16v6"/></svg>',
  zap: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>',
};
---

<BaseLayout
  title="Pool Cleaning & Maintenance in Savannah & Richmond Hill GA | Perfect Pools"
  description="Professional pool cleaning, maintenance, and repair in Richmond Hill, Savannah & Coastal Georgia. Transparent pricing, consistent visits, and real updates after every service. Call (912) 459-0160."
  canonicalPath="/"
  schema={schema}
>
  <!-- ============ HERO ============ -->
  <section class="hero hero--image">
    <img src={`${import.meta.env.BASE_URL}images/hero-pool.png`} alt="" class="hero__bg" loading="eager" />
    <div class="hero__overlay"></div>
    <div class="container">
      <div class="hero__grid">
        <!-- Left: Hero Text -->
        <div>
          <div class="hero__badge">
            <Fragment set:html={icons.star} />
            <span>Rated 4.9/5 by 500+ customers</span>
          </div>

          <h1>Pool care you can count on.</h1>
          <p>Transparent pricing. Consistent visits. Real updates after every service.</p>

          <div class="hero__buttons">
            <a href={`${import.meta.env.BASE_URL}plans`} class="btn btn--white btn--lg">View Our Services</a>
            <a href="tel:9124590160" class="btn btn--cta btn--lg">Call (912) 459-0160</a>
          </div>
        </div>

        <!-- Right: Service Route Cards -->
        <div class="hero__cards">
          <a href={`${import.meta.env.BASE_URL}plans`} class="route-card route-card--gradient">
            <div class="route-card__inner">
              <div class="route-card__icon">
                <Fragment set:html={icons.droplets} />
              </div>
              <div>
                <h3>Weekly Pool Care</h3>
                <p>Ongoing maintenance starting at $45/visit <span style="font-size: 0.75em; opacity: 0.7;">plus chemicals</span></p>
                <span class="route-card__link">
                  See Plans <Fragment set:html={icons.arrowRight} />
                </span>
              </div>
            </div>
          </a>

          <a href={`${import.meta.env.BASE_URL}repairs`} class="route-card route-card--white">
            <div class="route-card__inner">
              <div class="route-card__icon">
                <Fragment set:html={icons.alertCircle} />
              </div>
              <div>
                <h3>Equipment Repairs</h3>
                <p>Need equipment repaired, replaced or installed? We diagnose most issues within 48 hours</p>
                <span class="route-card__link">
                  Schedule Visit <Fragment set:html={icons.arrowRight} />
                </span>
              </div>
            </div>
          </a>
        </div>
      </div>

      <div class="hero__footer">
        <a href={`${import.meta.env.BASE_URL}our-approach`}>First time pool owner? Start here &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ============ TRUST BADGES ============ -->
  <section class="trust-badges">
    <div class="container">
      <div class="trust-badges__grid">
        <div class="trust-badge">
          <Fragment set:html={icons.shield} />
          <span class="trust-badge__text">Licensed & Insured</span>
        </div>
        <div class="trust-badge">
          <Fragment set:html={icons.clock} />
          <span class="trust-badge__text">500+ Pools Maintained</span>
        </div>
        <div class="trust-badge">
          <Fragment set:html={icons.star} />
          <span class="trust-badge__text">4.9&#9733; Google Rating</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ METHODOLOGY ============ -->
  <section class="methodology">
    <div class="container">
      <div class="section-header">
        <h2>Clear water isn't luck. Here's how we keep it that way.</h2>
        <p>Our methodology separates us from every other pool company</p>
      </div>

      <div class="methodology__grid">
        <div class="method-card">
          <div class="method-card__icon">
            <Fragment set:html={icons.testTube} />
          </div>
          <h3>We balance the chemistry, not just add chlorine</h3>
          <p>We test and adjust pH, alkalinity, sanitizer levels, and calcium hardness as a system—because one number out of range affects everything else.</p>
        </div>

        <div class="method-card">
          <div class="method-card__icon">
            <Fragment set:html={icons.alertCircle} />
          </div>
          <h3>We catch problems before they cost you money</h3>
          <p>Every visit includes a full equipment check. We monitor pump pressure, filter condition, and water flow to flag issues early.</p>
        </div>

        <div class="method-card">
          <div class="method-card__icon">
            <Fragment set:html={icons.eye} />
          </div>
          <h3>You see everything we do</h3>
          <p>After every visit, you get a service report with chemical readings, what was adjusted, and photos if anything needs attention.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WHAT WE DO (DARK SECTION) ============ -->
  <section class="services-dark">
    <div class="container">
      <div class="section-header">
        <h2>What We Do</h2>
        <p>Ongoing maintenance plans and on-demand repairs for residential and commercial pools.</p>
      </div>

      <div class="services-dark__grid">
        <!-- Left Column: Pool Cleaning -->
        <div>
          <div class="services-dark__col-header">
            <Fragment set:html={icons.droplets} />
            <h3>Pool Cleaning</h3>
          </div>

          <a href={`${import.meta.env.BASE_URL}plans`} class="glass-card">
            <div class="glass-card__inner">
              <div class="glass-card__icon">
                <Fragment set:html={icons.home} />
              </div>
              <div style="flex:1;">
                <div class="glass-card__header">
                  <h4>Need regular maintenance?</h4>
                  <span class="glass-card__arrow"><Fragment set:html={icons.arrowRight} /></span>
                </div>
                <p>Weekly and bi-weekly residential service</p>
                <div class="glass-card__tags">
                  <span class="glass-card__tag">Weekly</span>
                  <span class="glass-card__tag">Bi-weekly<span class="tag-badge tag-badge--winter">Winter Only</span></span>
                </div>
              </div>
            </div>
            <p class="glass-card__desc">Full service including chemical balancing, equipment checks, and detailed reports.</p>
          </a>

          <a href={`${import.meta.env.BASE_URL}contact`} class="glass-card">
            <div class="glass-card__inner">
              <div class="glass-card__icon">
                <Fragment set:html={icons.building} />
              </div>
              <div style="flex:1;">
                <div class="glass-card__header">
                  <h4>Managing a commercial property?</h4>
                  <span class="glass-card__arrow"><Fragment set:html={icons.arrowRight} /></span>
                </div>
                <p>Hotels, apartments, HOAs & public facilities</p>
                <div class="glass-card__tags">
                  <span class="glass-card__tag">Custom Schedule</span>
                </div>
              </div>
            </div>
            <p class="glass-card__desc">High-traffic pool programs with compliance documentation and proactive maintenance.</p>
          </a>

          <a href={`${import.meta.env.BASE_URL}plans`} class="btn btn--cta btn--lg btn--block" style="margin-top:1rem;">See Plans & Pricing</a>
        </div>

        <!-- Right Column: Equipment & Repair -->
        <div>
          <div class="services-dark__col-header">
            <Fragment set:html={icons.settings} />
            <h3>Equipment & Repair</h3>
          </div>

          <a href={`${import.meta.env.BASE_URL}repairs`} class="glass-card glass-card--sm">
            <div class="glass-card__inner">
              <div class="glass-card__icon glass-card__icon--sm">
                <Fragment set:html={icons.thermometer} />
              </div>
              <div style="flex:1;">
                <div class="glass-card__header">
                  <h4>Pool not heating?</h4>
                  <span class="glass-card__arrow"><Fragment set:html={icons.arrowRight} /></span>
                </div>
                <p>Heat pumps, gas heaters, solar systems</p>
              </div>
            </div>
          </a>

          <a href={`${import.meta.env.BASE_URL}repairs`} class="glass-card glass-card--sm">
            <div class="glass-card__inner">
              <div class="glass-card__icon glass-card__icon--sm">
                <Fragment set:html={icons.settings} />
              </div>
              <div style="flex:1;">
                <div class="glass-card__header">
                  <h4>Equipment making noise?</h4>
                  <span class="glass-card__arrow"><Fragment set:html={icons.arrowRight} /></span>
                </div>
                <p>Pumps, motors, filtration diagnosis</p>
              </div>
            </div>
          </a>

          <a href={`${import.meta.env.BASE_URL}repairs`} class="glass-card glass-card--sm">
            <div class="glass-card__inner">
              <div class="glass-card__icon glass-card__icon--sm">
                <Fragment set:html={icons.cloudRain} />
              </div>
              <div style="flex:1;">
                <div class="glass-card__header">
                  <h4>Water won't clear up?</h4>
                  <span class="glass-card__arrow"><Fragment set:html={icons.arrowRight} /></span>
                </div>
                <p>Chemistry, filtration, circulation issues</p>
              </div>
            </div>
          </a>

          <a href={`${import.meta.env.BASE_URL}repairs`} class="glass-card glass-card--sm">
            <div class="glass-card__inner">
              <div class="glass-card__icon glass-card__icon--sm">
                <Fragment set:html={icons.zap} />
              </div>
              <div style="flex:1;">
                <div class="glass-card__header">
                  <h4>Ready for an upgrade?</h4>
                  <span class="glass-card__arrow"><Fragment set:html={icons.arrowRight} /></span>
                </div>
                <p>Variable-speed pumps, automation, LED lighting</p>
              </div>
            </div>
          </a>

          <a href={`${import.meta.env.BASE_URL}repairs`} class="btn btn--outline-white btn--lg btn--block" style="margin-top:1rem;">Schedule a Diagnosis</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ A TRUE SERVICE PARTNER ============ -->
  <section class="partner-section">
    <div class="container max-w-4xl mx-auto text-center">
      <h2>Complete Pool Care. Built on Local Trust.</h2>

      <p>We brought together the best local pool professionals in coastal Georgia — and gave them the resources to do even more. From weekly maintenance to full equipment service, one team that knows your pool inside and out.</p>

      <p>The result is a dedicated service company with the technical depth to handle equipment, the local presence to know your pool, and the operational foundation to deliver consistent care year after year.</p>

      <p class="highlight">Your pool is a 15–20 year asset. It deserves a true service partner.</p>

      <div style="margin-top:2rem;">
        <a href={`${import.meta.env.BASE_URL}our-approach/#our-story`} class="btn btn--primary btn--lg">Read Our Story</a>
      </div>
    </div>
  </section>

  <!-- ============ MARKETS WE SERVE ============ -->
  <section class="section service-area-section" id="service-area">
    <div class="container">
      <div class="section-header">
        <h2>Markets We Serve</h2>
        <p>Serving coastal Georgia and the Lowcountry</p>
      </div>

      <!-- Checker + Map card -->
      <div class="service-area__card">
        <div class="service-area__layout">
          <div class="service-area__checker">
            <h3>Check Your Address</h3>
            <p>Enter your address to see if you're within our service area.</p>
            <div id="service-area-checker"></div>
          </div>
          <div class="service-area__map" id="service-area-map"></div>
        </div>
      </div>

      <!-- City cards carousel -->
      <div class="home-cities">
        <div class="home-cities__track">
          <a href={`${import.meta.env.BASE_URL}service-areas/richmond-hill/`} class="home-city-card">
            <img src={`${import.meta.env.BASE_URL}images/city-richmond-hill.jpg`} alt="Richmond Hill" />
            <div class="home-city-card__overlay"></div>
            <div class="home-city-card__content"><span>GA</span><strong>Richmond Hill</strong></div>
          </a>
          <a href={`${import.meta.env.BASE_URL}service-areas/savannah/`} class="home-city-card">
            <img src={`${import.meta.env.BASE_URL}images/city-savannah.jpg`} alt="Savannah" />
            <div class="home-city-card__overlay"></div>
            <div class="home-city-card__content"><span>GA</span><strong>Savannah</strong></div>
          </a>
          <a href={`${import.meta.env.BASE_URL}service-areas/pooler/`} class="home-city-card">
            <img src={`${import.meta.env.BASE_URL}images/city-pooler.webp`} alt="Pooler" />
            <div class="home-city-card__overlay"></div>
            <div class="home-city-card__content"><span>GA</span><strong>Pooler</strong></div>
          </a>
          <a href={`${import.meta.env.BASE_URL}service-areas/hinesville/`} class="home-city-card">
            <img src={`${import.meta.env.BASE_URL}images/city-hinesville.jpeg`} alt="Hinesville" />
            <div class="home-city-card__overlay"></div>
            <div class="home-city-card__content"><span>GA</span><strong>Hinesville</strong></div>
          </a>
          <a href={`${import.meta.env.BASE_URL}service-areas/tybee-island/`} class="home-city-card">
            <img src={`${import.meta.env.BASE_URL}images/city-tybee-island.webp`} alt="Tybee Island" />
            <div class="home-city-card__overlay"></div>
            <div class="home-city-card__content"><span>GA</span><strong>Tybee Island</strong></div>
          </a>
          <a href={`${import.meta.env.BASE_URL}service-areas/bluffton/`} class="home-city-card">
            <img src={`${import.meta.env.BASE_URL}images/city-bluffton.webp`} alt="Bluffton" />
            <div class="home-city-card__overlay"></div>
            <div class="home-city-card__content"><span>SC</span><strong>Bluffton</strong></div>
          </a>
        </div>
        <div class="home-cities__nav">
          <button class="home-cities__btn" id="cities-prev" aria-label="Previous">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <button class="home-cities__btn" id="cities-next" aria-label="Next">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SOCIAL PROOF ============ -->
  <section class="reviews-home">
    <div class="container">
      <div class="section-header">
        <h2>What our customers say</h2>
      </div>
      <ReviewCarousel />
      <div class="text-center" style="margin-top:2rem;">
        <a href="https://g.page/r/CVrU0W_3-NRyEAE/review" target="_blank" rel="noopener" class="btn btn--outline">Read All Reviews on Google</a>
      </div>
    </div>
  </section>

  <!-- ============ FINAL CTA WITH IMAGE ============ -->
  <section class="cta-image">
    <img src={`${import.meta.env.BASE_URL}images/coastal-pool.png`} alt="" class="cta-image__bg" loading="lazy" />
    <div class="cta-image__overlay"></div>
    <div class="container cta-image__content">
      <h2>Ready for worry-free pool care?</h2>
      <p>This is coastal pool service built for Georgia. Not a franchise playbook.</p>
      <p class="sub">Salt air, humidity, and storms put unique stress on Georgia pools. We know how the marsh air affects your equipment and how fast algae blooms after a week of rain.</p>
      <div class="cta-image__buttons">
        <a href={`${import.meta.env.BASE_URL}plans`} class="btn btn--cta btn--lg">See Maintenance Plans</a>
        <a href={`${import.meta.env.BASE_URL}repairs`} class="btn btn--outline-white btn--lg">Schedule a Repair</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { render, h } from 'preact';
  import ServiceAreaChecker from '../components/ServiceAreaChecker.tsx';

  const checkerMount = document.getElementById('service-area-checker');
  if (checkerMount) render(h(ServiceAreaChecker, null), checkerMount);

  // Render Google Map in the map container
  async function initMap() {
    const mapEl = document.getElementById('service-area-map');
    if (!mapEl || !(window as any).google?.maps) return;
    const google = (window as any).google;
    const center = { lat: 31.6, lng: -81.35 };
    const map = new google.maps.Map(mapEl, {
      center, zoom: 9,
      disableDefaultUI: true,
      zoomControl: true,
      styles: [
        { featureType: 'water', elementType: 'geometry.fill', stylers: [{ color: '#c8e3f5' }] },
        { featureType: 'water', elementType: 'labels', stylers: [{ visibility: 'off' }] },
        { featureType: 'landscape', elementType: 'geometry.fill', stylers: [{ color: '#eef2ee' }] },
        { featureType: 'landscape.natural', elementType: 'geometry.fill', stylers: [{ color: '#e8efe8' }] },
        { featureType: 'road.highway', elementType: 'geometry', stylers: [{ color: '#dde4dd' }, { visibility: 'simplified' }] },
        { featureType: 'road.highway', elementType: 'labels', stylers: [{ visibility: 'off' }] },
        { featureType: 'road.arterial', elementType: 'geometry', stylers: [{ color: '#e8ece8' }, { visibility: 'simplified' }] },
        { featureType: 'road.arterial', elementType: 'labels', stylers: [{ visibility: 'off' }] },
        { featureType: 'road.local', elementType: 'geometry', stylers: [{ color: '#f0f4f0' }, { visibility: 'simplified' }] },
        { featureType: 'road.local', elementType: 'labels', stylers: [{ visibility: 'off' }] },
        { featureType: 'poi', stylers: [{ visibility: 'off' }] },
        { featureType: 'transit', stylers: [{ visibility: 'off' }] },
        { featureType: 'administrative.locality', elementType: 'labels.text.fill', stylers: [{ color: '#4a5568' }] },
        { featureType: 'administrative.locality', elementType: 'labels.text.stroke', stylers: [{ color: '#ffffff' }, { weight: 3 }] },
        { featureType: 'administrative.neighborhood', stylers: [{ visibility: 'off' }] },
      ],
    });
    // Fetch heatmap data from Supabase
    const SUPABASE_URL = 'https://vvprodiuwraceabviyes.supabase.co';
    const SUPABASE_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ2cHJvZGl1d3JhY2VhYnZpeWVzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTY5MDU4MTYsImV4cCI6MjA3MjQ4MTgxNn0.HOFTUrInpmzhxTJDSp1xKp81noC7jMuTcdxr9JqC3z0';
    try {
      const res = await fetch(`${SUPABASE_URL}/functions/v1/heatmap-data`, {
        headers: { apikey: SUPABASE_ANON },
      });
      if (res.ok) {
        const data = await res.json();
        if (data.points?.length > 0) {
          const points = data.points as { lat: number; lng: number }[];
          const areas = [
            { name: 'Savannah', lat: 32.065, lng: -81.09 },
            { name: 'Pooler', lat: 32.12, lng: -81.25 },
            { name: 'Richmond Hill', lat: 31.94, lng: -81.30 },
            { name: 'Wilmington Is.', lat: 31.99, lng: -80.97 },
            { name: 'Tybee Island', lat: 32.00, lng: -80.85 },
            { name: 'Skidaway Is.', lat: 31.94, lng: -81.06 },
            { name: 'Hinesville', lat: 31.84, lng: -81.60 },
            { name: 'Midway', lat: 31.81, lng: -81.43 },
            { name: 'Brunswick', lat: 31.16, lng: -81.49 },
            { name: 'St. Simons Is.', lat: 31.17, lng: -81.37 },
          ];
          const counts = new Map<string, number>();
          areas.forEach(a => counts.set(a.name, 0));
          points.forEach(p => {
            let nearest = areas[0];
            let minD = Infinity;
            areas.forEach(a => {
              const d = (p.lat - a.lat) ** 2 + (p.lng - a.lng) ** 2;
              if (d < minD) { minD = d; nearest = a; }
            });
            counts.set(nearest.name, (counts.get(nearest.name) || 0) + 1);
          });
          areas.forEach(area => {
            const count = counts.get(area.name) || 0;
            if (count < 3) return;
            const scale = Math.min(count / 80, 1);
            new google.maps.Circle({ center: { lat: area.lat, lng: area.lng }, radius: 5000 + scale * 9000, map, fillColor: '#22d3ee', fillOpacity: 0.08 + scale * 0.04, strokeWeight: 0, clickable: false, zIndex: 0 });
            new google.maps.Circle({ center: { lat: area.lat, lng: area.lng }, radius: 3000 + scale * 5500, map, fillColor: '#06b6d4', fillOpacity: 0.12 + scale * 0.06, strokeWeight: 0, clickable: false, zIndex: 1 });
            new google.maps.Circle({ center: { lat: area.lat, lng: area.lng }, radius: 1200 + scale * 2800, map, fillColor: '#0891b2', fillOpacity: 0.17 + scale * 0.09, strokeWeight: 0, clickable: false, zIndex: 2 });
          });
        }
      }
    } catch {};

    // Listen for address check — zoom in and drop pin
    let marker: any = null;
    window.addEventListener('address-checked', ((e: CustomEvent) => {
      const { lat, lng, inArea } = e.detail;
      if (marker) marker.setMap(null);
      map.panTo({ lat, lng });
      map.setZoom(13);
      marker = new google.maps.Marker({
        position: { lat, lng },
        map,
        icon: {
          path: google.maps.SymbolPath.CIRCLE,
          scale: 10,
          fillColor: inArea ? '#059669' : '#d97706',
          fillOpacity: 1,
          strokeColor: '#fff',
          strokeWeight: 3,
        },
        animation: google.maps.Animation.DROP,
      });
    }) as EventListener);
  }
  // Wait for Google Maps to load (already loaded by ServiceAreaChecker)
  const checkMaps = setInterval(() => {
    if ((window as any).google?.maps) { clearInterval(checkMaps); initMap(); }
  }, 200);

  // City cards carousel
  const citiesTrack = document.querySelector('.home-cities__track') as HTMLElement;
  const citiesPrev = document.getElementById('cities-prev');
  const citiesNext = document.getElementById('cities-next');
  if (citiesTrack && citiesPrev && citiesNext) {
    let cityOffset = 0;
    const getCardWidth = () => {
      const card = citiesTrack.querySelector('.home-city-card') as HTMLElement;
      return card ? card.offsetWidth + 16 : 0;
    };
    const getMax = () => Math.max(0, citiesTrack.scrollWidth - (citiesTrack.parentElement as HTMLElement).offsetWidth);
    citiesPrev.addEventListener('click', () => {
      cityOffset = Math.max(0, cityOffset - getCardWidth());
      citiesTrack.style.transform = `translateX(-${cityOffset}px)`;
    });
    citiesNext.addEventListener('click', () => {
      cityOffset = Math.min(getMax(), cityOffset + getCardWidth());
      citiesTrack.style.transform = `translateX(-${cityOffset}px)`;
    });
  }
</script>
