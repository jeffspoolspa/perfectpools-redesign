---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Perfect Pools",
  "url": "https://perfectpoolscleaning.com",
  "telephone": "(912) 459-0160",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "8989 Ford Ave",
    "addressLocality": "Richmond Hill",
    "addressRegion": "GA",
    "postalCode": "31324",
    "addressCountry": "US"
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "08:00",
    "closes": "17:00"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+1-912-459-0160",
    "contactType": "customer service",
    "areaServed": "US",
    "availableLanguage": "English"
  }
};
---

<BaseLayout
  title="Contact Perfect Pools | Savannah & Richmond Hill GA Pool Service"
  description="Contact Perfect Pools for a free quote. Call (912) 459-0160 or fill out our contact form. Located at 8989 Ford Ave, Richmond Hill, GA. Serving the Greater Savannah area."
  canonicalPath="/contact/"
  schema={schema}
>
  <section class="hero">
    <div class="container">
      <h1>Contact Us</h1>
      <p>Ready for a cleaner pool? We'd love to hear from you.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>Get in Touch</h2>

          <div class="contact-item">
            <h3>Phone</h3>
            <a href="tel:9124590160" class="contact-phone">(912) 459-0160</a>
          </div>

          <div class="contact-item">
            <h3>Address</h3>
            <address>
              8989 Ford Ave<br />
              Richmond Hill, GA 31324
            </address>
          </div>

          <div class="contact-item">
            <h3>Hours</h3>
            <p>Monday – Friday: 8:00 AM – 5:00 PM</p>
          </div>

          <div class="contact-item">
            <h3>Service Area</h3>
            <p>Serving Richmond Hill, Savannah, Pooler, Hinesville, and the Greater Savannah area.</p>
          </div>

          <button
            type="button"
            class="btn btn--primary btn--lg"
            data-open-intake
            style="margin-top: var(--space-6);"
          >
            Get a Free Quote
          </button>
        </div>

        <div class="contact-form-wrap">
          <h2>Send Us a Message</h2>
          <!-- TODO: Connect form action to Supabase/Windmill endpoint -->
          <form class="contact-form" action="#" method="POST">
            <div class="form-group">
              <label for="name" class="form-label">Name</label>
              <input type="text" id="name" name="name" class="form-input" required />
            </div>
            <div class="form-group">
              <label for="email" class="form-label">Email</label>
              <input type="email" id="email" name="email" class="form-input" required />
            </div>
            <div class="form-group">
              <label for="phone" class="form-label">Phone</label>
              <input type="tel" id="phone" name="phone" class="form-input" />
            </div>
            <div class="form-group">
              <label for="service" class="form-label">Service Interest</label>
              <select id="service" name="service" class="form-select">
                <option value="">Select a service...</option>
                <option value="residential-cleaning">Residential Pool Cleaning</option>
                <option value="commercial-cleaning">Commercial Pool Cleaning</option>
                <option value="green-pool">Green Pool Recovery</option>
                <option value="inspection">Pool Inspection</option>
                <option value="commercial-repair">Commercial Repair & Install</option>
                <option value="residential-repair">Residential Repair & Install</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message" class="form-label">Message</label>
              <textarea id="message" name="message" class="form-textarea" rows="5"></textarea>
            </div>
            <button type="submit" class="btn btn--primary btn--lg" style="width: 100%;">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Google Maps embed -->
  <section class="section section--alt">
    <div class="container">
      <h2 class="text-center">Find Us</h2>
      <div class="map-wrap">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3399.0!2d-81.3!3d31.94!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzHCsDU2JzI0LjAiTiA4McKwMTgnMDAuMCJX!5e0!3m2!1sen!2sus!4v1234567890"
          width="100%"
          height="400"
          style="border:0; border-radius: var(--radius-lg);"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Perfect Pools location on Google Maps"
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-item {
    margin-bottom: var(--space-6);
  }

  .contact-item h3 {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-500);
    margin-bottom: var(--space-1);
  }

  .contact-phone {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-primary);
  }

  .contact-item address {
    font-style: normal;
    font-size: var(--text-lg);
  }

  .contact-item p {
    font-size: var(--text-lg);
  }

  .map-wrap {
    margin-top: var(--space-6);
  }
</style>
