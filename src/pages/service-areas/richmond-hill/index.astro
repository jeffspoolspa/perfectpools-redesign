---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReviewCarousel from '../../../components/ReviewCarousel.astro';
const base = import.meta.env.BASE_URL;

const city = {
  name: 'Richmond Hill',
  state: 'GA',
  tagline: "YOUR HOMETOWN POOL PARTNER",
  heroHeading: 'Professional Pool Service in Richmond Hill, GA',
  heroSubtext: "As Richmond Hill's only locally headquartered pool service, we know every neighborhood — from Waterways to Ford Plantation. No drive time, no excuses, just precision care from your neighbors.",
  heroImage: `${base}images/city-richmond-hill.jpg`,
  localImage: `${base}images/city-richmond-hill-local.png`,
  localExpertise: {
    kicker: '',
    heading: 'Built for Bryan County Living.',
    paragraphs: [
      "Richmond Hill sits at the intersection of coastal humidity and pine-heavy landscapes. The combination of Savannah-adjacent salt air, dense loblolly pine canopy, and sandy soil creates a unique chemical demand that generic pool companies consistently miss.",
      "Our home base at 8989 Ford Ave means we're minutes from every neighborhood in town. We understand the seasonal pollen dumps from the surrounding forests, the iron-rich well water common in newer subdivisions, and the specific algae strains that thrive in Bryan County's microclimate."
    ]
  },
  services: [
    {
      icon: 'calendar',
      iconFile: 'icon-weekly-care.svg',
      title: 'Weekly Maintenance',
      desc: 'Our signature meticulous service. Full panel testing, debris removal, and equipment monitoring to keep your pool perfect year round.',
      color: '#145BB8',
      bg: '#e7f0ff',
      href: `${base}our-approach/`,
    },
    {
      icon: 'wrench',
      iconFile: 'icon-repair.svg',
      title: 'Equipment Service',
      desc: 'Everything from small repairs to full equipment pad upgrades. Backed by expert diagnosis to ensure we get it right the first time.',
      color: '#E28D33',
      bg: '#ffebcc',
      href: `${base}services/residential-repair-install/`,
    },
    {
      icon: 'leaf',
      iconFile: 'icon-green-pool.svg',
      title: 'Green Recovery',
      desc: 'Complete algae remediation and water restoration — from swamp green back to crystal clear in days.',
      color: '#059669',
      bg: '#d1fae5',
      href: `${base}services/green-pool-recovery/`,
    },
  ],
  stats: [
    { value: '4.9/5', label: 'Google Rating', icon: 'star' },
    { value: '45-Min', label: 'Protocol Minimum', icon: 'clock' },
    { value: 'Real-Time', label: 'Digital Reports', icon: 'chart' },
  ],
  testimonials: [
    {
      quote: "Erin and Jackie of Perfect Pools have managed the maintenance of our pool, deck and lanai for over 8 years and are a credit to their profession. The quality of work is always exceptional. Their professionalism and attention to detail is unmatched. Matthew, our pool tech is highly skilled and efficient. Perfect Pools maintains exceptional communications: timely, full-disclosure, team-focused and courteous.",
      name: 'Scott Lopez',
      stars: 5,
    },
    {
      quote: "After calling about 6 different companies, Perfect Pools was the ONLY pool service that we could find that would come out to Midway, GA. So happy we found them. Our pool was green and full of algae when we first bought this house... they had it cleaned up and sparkling blue in no time. They have helped us with some energy saving ideas as well.",
      name: 'Katie S.',
      stars: 5,
    },
    {
      quote: "After dealing with other companies in the area, Perfect Pools is by far the most responsive, fairly priced, and experienced company. I had damage after one of the recent hurricanes and they came in quick to measure and replace my liner. They kept in constant communication and provided timely updates. Any issue they ran into during the process they were open about and provided a solution.",
      name: 'Josh Anderson',
      stars: 5,
    },
    {
      quote: "Our pool is sparkling clean! Erin, the owner, and her staff are very professional and do excellent work. We have Perfect Pools come every two weeks and they take care of everything. They leave a checklist of all services performed. We have had zero issues and our pool is pristine. Anytime we have had questions, they are quick to respond. We are completely satisfied with Perfect Pools and absolutely recommend them.",
      name: 'Terry & Pete H.',
      stars: 5,
    },
    {
      quote: "We are so pleased with Erin and her wonderful staff. They are not only efficient and knowledgeable but very courteous and helpful. We had large stains in our pool after the hurricane came through this year. We tried everything known to get them out. Erin analyzed the stains and she and her crew worked diligently to get them out. Our pool looks like it did when we first got it. We also had a pump issue come up and they came out the next day and fixed it.",
      name: 'Susan Keen',
      stars: 5,
    },
  ],
  pricing: {
    weekly: { price: 200, features: ['Weekly Chemical Balancing', 'Full Surface Skimming & Brushing', 'Vacuuming as Needed', 'Digital Visit Reports & Photos', 'Equipment Health Audit'] },
    biweekly: { price: 125, features: ['Every-Other-Week Balancing', 'Surface Skimming & Brushing', 'Digital Visit Reports', 'Basket & Filter Clearing'] },
  },
};
---

<BaseLayout
  title={`Pool Service in ${city.name}, ${city.state} | Perfect Pools`}
  description={`Professional pool cleaning, maintenance, and repair in ${city.name}, ${city.state}. Weekly and bi-weekly plans with digital reporting. Locally headquartered.`}
  canonicalPath={`/service-areas/richmond-hill`}
>

  <!-- Hero -->
  <section class="city-hero">
    <div class="container">
      <div class="city-hero__grid">
        <div class="city-hero__content">
          <span class="city-kicker">{city.tagline}</span>
          <h1>{city.heroHeading}</h1>
          <p class="city-hero__sub">{city.heroSubtext}</p>
          <div class="city-hero__buttons">
            <a href={`${base}get-started/`} class="btn btn--cta btn--lg">Get a Quote</a>
          </div>
        </div>
        <div class="city-hero__image">
          <img src={city.heroImage} alt={`Pool service in ${city.name}`} />
        </div>
      </div>
    </div>
    <div class="city-hero__glow"></div>
  </section>

  <!-- Stats Bar -->
  <section class="city-stats">
    <div class="container">
      <div class="city-stats__grid">
        {city.stats.map((stat) => (
          <div class="city-stat">
            <span class="city-stat__value">{stat.value}</span>
            <span class="city-stat__label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section city-services">
    <div class="container">
      <span class="city-kicker">CORE OFFERINGS</span>
      <h2>Pool Care Made Simple.</h2>
      <div class="city-services__carousel">
        <div class="city-services__track" id="services-track">
          {city.services.map((svc) => (
            <a href={svc.href} class="city-service-card">
              <div class="city-service-card__icon" style={`background: ${svc.bg};`}>
                <span class="city-service-card__svg" style={`background-color: ${svc.color}; -webkit-mask-image: url('${base}images/${svc.iconFile}'); mask-image: url('${base}images/${svc.iconFile}');`}></span>
              </div>
              <h3>{svc.title}</h3>
              <p>{svc.desc}</p>
              <div class="city-service-card__accent"></div>
              <span class="city-service-card__link" style={`color: ${svc.color};`}>
                Learn more
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          ))}
        </div>
        <div class="city-services__dots" id="services-dots">
          {city.services.map((_, i) => (
            <button class={`city-services__dot ${i === 0 ? 'city-services__dot--active' : ''}`} data-index={i} aria-label={`Card ${i + 1}`}></button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Local Expertise -->
  <section class="city-local">
    <div class="container">
      <div class="city-local__grid">
        <div class="city-local__content">
          <span class="city-kicker city-kicker--light">{city.localExpertise.kicker}</span>
          <h2 class="city-local__heading">{city.localExpertise.heading}</h2>
          {city.localExpertise.paragraphs.map((p) => (
            <p class="city-local__text">{p}</p>
          ))}
        </div>
        <div class="city-local__image">
          <div class="city-local__frame">
            <img src={city.localImage} alt={`${city.name} water tower`} />
          </div>
        </div>
      </div>
    </div>
    <div class="city-local__gradient"></div>
  </section>

  <!-- Testimonials -->
  <section class="section city-testimonial">
    <div class="container">
      <div class="text-center" style="margin-bottom: var(--space-12);">
        <span class="city-kicker">WHAT OUR CLIENTS SAY</span>
        <h2>Real Reviews, Real Results.</h2>
      </div>
      <ReviewCarousel />
      <div class="text-center" style="margin-top: var(--space-8);">
        <a href="https://g.page/r/CVrU0W_3-NRyEAE/review" target="_blank" rel="noopener" class="btn btn--outline">Read All Reviews on Google</a>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section section--alt city-pricing" id="pricing-section">
    <div class="container">
      <div class="text-center">
        <span class="city-kicker">PRICING STRUCTURE</span>
        <h2>Transparent Investments.</h2>
        <p style="color: var(--color-text-light); max-width: 540px; margin: 0.5rem auto 0;">No contracts. Month-to-month service with 2 weeks notice to cancel.</p>
      </div>

      <!-- Tab Switcher -->
      <div class="pricing-tabs">
        <button class="pricing-tab pricing-tab--active" data-tab="weekly">Weekly</button>
        <button class="pricing-tab pricing-tab--winter" data-tab="biweekly">
          Bi-Weekly
          <span class="pricing-tab__badge">❄ Winter Only</span>
        </button>
      </div>

      <!-- Pricing Card -->
      <div class="pricing-card">
        <!-- Weekly Content -->
        <div class="pricing-card__content pricing-card__content--active" data-content="weekly">
          <div class="pricing-card__layout">
            <!-- Left: Plan configurator (Preact island) -->
            <div class="pricing-card__plan" id="pricing-config-weekly"></div>

            <!-- Right: Cost Plus Chemicals -->
            <div class="pricing-card__chemicals">
              <div class="chem-header">
                <span class="chem-kicker">HOW CHEMICALS WORK</span>
                <h4>True Cost Pricing</h4>
                <p>Your bill reflects your pool, not an average.</p>
              </div>

              <!-- Chemical cost chart (Preact island — same as quote form) -->
              <div id="chem-chart-weekly"></div>
            </div>
          </div>
        </div>

        <!-- Bi-Weekly Content -->
        <div class="pricing-card__content" data-content="biweekly">
          <div class="pricing-card__layout">
            <div class="pricing-card__plan" id="pricing-config-biweekly"></div>

            <!-- Right: Weekly vs Bi-Weekly comparison -->
            <div class="pricing-card__chemicals">
              <div class="chem-header">
                <span class="chem-kicker">WHY WINTER ONLY</span>
                <h4>Weekly vs. Bi-Weekly</h4>
                <p style="color: #1E3A5F; font-weight: 700;">Anyone who's maintained a pool in coastal weather knows — two weeks is too long in the heat.</p>
              </div>

              <!-- Lawn analogy — illustrated -->
              <div class="biweekly-story">
                <div class="biweekly-story__row">
                  <div class="biweekly-story__icon">🌿</div>
                  <div>
                    <div class="biweekly-story__label">Weekly = a well-kept lawn</div>
                    <div class="biweekly-story__bar biweekly-story__bar--good"></div>
                    <p class="biweekly-story__desc">Mowed every week — stays level, healthy, no surprises. Easy to maintain because you never let it get ahead of you.</p>
                  </div>
                </div>
                <div class="biweekly-story__row">
                  <div class="biweekly-story__icon">🌾</div>
                  <div>
                    <div class="biweekly-story__label">Bi-weekly = fighting to catch up</div>
                    <div class="biweekly-story__bar biweekly-story__bar--warn"></div>
                    <p class="biweekly-story__desc">Two weeks of growth means tall grass, weeds taking hold, and a harder cut. You might need a different blade height just to get through it.</p>
                  </div>
                </div>
                <div class="biweekly-story__row">
                  <div class="biweekly-story__icon">🟢</div>
                  <div>
                    <div class="biweekly-story__label">A green pool = the overgrown yard</div>
                    <div class="biweekly-story__bar biweekly-story__bar--bad"></div>
                    <p class="biweekly-story__desc">You can't mow it anymore — you need specialized equipment to bring it back. Algae is your weeds, and it establishes fast in coastal heat.</p>
                  </div>
                </div>
                <p class="biweekly-story__kicker">Just like grass grows slower in winter and you can stretch the mowing interval, algae slows down in cooler months — which is why bi-weekly can work September through March.</p>
              </div>

              <!-- Chemical evidence -->
              <div class="biweekly-compare" style="margin-top: 0.75rem;">
                <div class="biweekly-compare__title">The Data Shows the Strain</div>
                <div class="biweekly-compare__bars">
                  <div class="biweekly-compare__row">
                    <span class="biweekly-compare__label">Weekly</span>
                    <div class="biweekly-compare__bar-track">
                      <div class="biweekly-compare__bar biweekly-compare__bar--weekly" style="width: 80%;"></div>
                    </div>
                    <span class="biweekly-compare__value">$25/visit</span>
                  </div>
                  <div class="biweekly-compare__row">
                    <span class="biweekly-compare__label">Bi-Weekly</span>
                    <div class="biweekly-compare__bar-track">
                      <div class="biweekly-compare__bar biweekly-compare__bar--biweekly" style="width: 100%;"></div>
                    </div>
                    <span class="biweekly-compare__value" style="color: #d97706; font-weight: 800;">$31/visit</span>
                  </div>
                </div>
                <p class="biweekly-compare__note">We no longer take bi-weekly customers in summer. This data is from customers who refused to switch last year — 24% more chemicals per visit just to play catch-up. Two weeks is enough for chlorine to bottom out, debris to break down into phosphates, and equipment failures to go undetected.</p>
                <p class="chem-data-note" style="margin-top: 0.5rem;">Per-visit chemical data from 234 bi-weekly and 721 weekly summer invoices.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center" style="margin-top: 2rem;">
        <a href={`${base}get-started/`} class="btn btn--cta btn--lg">Get Started</a>
        <p style="margin-top: 1rem; color: var(--color-text-light); font-size: 0.85rem;">
          Chemicals billed separately at transparent cost-plus pricing. <a href={`${base}plans/`} style="color: var(--color-primary); text-decoration: underline;">See full pricing details</a>
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section city-cta">
    <div class="container container--narrow text-center">
      <h2>Ready to fix your pool?</h2>
      <p class="city-cta__sub">Choose the path that fits your needs. Our assessments are complimentary and comprehensive.</p>
      <div class="city-hero__buttons" style="justify-content: center;">
        <a href={`${base}get-started/`} class="btn btn--cta btn--lg">Book Assessment</a>
        <a href={`${base}plans/`} class="btn btn--outline btn--lg">See Full Pricing</a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // Mobile swipe dots for service cards
  const track = document.getElementById('services-track');
  const dots = document.querySelectorAll('.city-services__dot');
  if (track && dots.length) {
    track.addEventListener('scroll', () => {
      const scrollLeft = track.scrollLeft;
      const cardWidth = (track.firstElementChild as HTMLElement)?.offsetWidth || 1;
      const gap = 24;
      const index = Math.round(scrollLeft / (cardWidth + gap));
      dots.forEach((dot, i) => {
        dot.classList.toggle('city-services__dot--active', i === index);
      });
    });
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = Number((dot as HTMLElement).dataset.index);
        const cardWidth = (track.firstElementChild as HTMLElement)?.offsetWidth || 0;
        const gap = 24;
        track.scrollTo({ left: index * (cardWidth + gap), behavior: 'smooth' });
      });
    });
  }

  // Pricing tabs
  const tabs = document.querySelectorAll('.pricing-tab');
  const contents = document.querySelectorAll('.pricing-card__content');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab;
      tabs.forEach((t) => t.classList.remove('pricing-tab--active'));
      tab.classList.add('pricing-tab--active');
      contents.forEach((c) => {
        c.classList.toggle('pricing-card__content--active', (c as HTMLElement).dataset.content === target);
      });
    });
  });

  // Mount PricingConfigurator + ChemicalCostChart
  async function mountChemCharts() {
    const { render, h } = await import('preact');
    const { default: PricingConfigurator } = await import('../../../components/PricingConfigurator.tsx');
    const { default: ChemicalCostChart } = await import('../../../components/ChemicalCostChart.tsx');

    // Mount pricing configurators
    const weeklyConfig = document.getElementById('pricing-config-weekly');
    if (weeklyConfig) {
      render(h(PricingConfigurator, { frequency: 'weekly', ctaHref: '/get-started/' }), weeklyConfig);
    }
    const biweeklyConfig = document.getElementById('pricing-config-biweekly');
    if (biweeklyConfig) {
      render(h(PricingConfigurator, { frequency: 'biweekly', ctaHref: '/get-started/' }), biweeklyConfig);
    }

    const SUPABASE_URL = 'https://vvprodiuwraceabviyes.supabase.co';
    const SUPABASE_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ2cHJvZGl1d3JhY2VhYnZpeWVzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTY5MDU4MTYsImV4cCI6MjA3MjQ4MTgxNn0.HOFTUrInpmzhxTJDSp1xKp81noC7jMuTcdxr9JqC3z0';

    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/chemical_cost_estimates?select=*`, {
        headers: { apikey: SUPABASE_ANON, Accept: 'application/json' }
      });
      const allData = await res.json();
      if (!Array.isArray(allData)) { console.error('Chem data not array:', JSON.stringify(allData)); return; }
      const weeklyData = allData.filter((d: any) => d.service_frequency === 'weekly');

      const weeklyMount = document.getElementById('chem-chart-weekly');
      if (weeklyMount && weeklyData.length) {
        render(h(ChemicalCostChart, { data: weeklyData, serviceMonthly: 217, competitorFlat: 350, compact: true }), weeklyMount);
      }

      // Bi-weekly tab now uses static comparison section instead of chart
    } catch (err) {
      console.error('Failed to load chemical cost data:', err);
    }
  }
  mountChemCharts();
</script>

<style>
  /* === City Page Styles === */

  .city-kicker {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #E28D33;
    margin-bottom: 1rem;
  }

  .city-kicker--light {
    color: #E28D33;
  }

  /* --- Hero --- */
  .city-hero {
    position: relative;
    padding: var(--space-16) 0 var(--space-12);
    overflow: hidden;
  }

  .city-hero__grid {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 900px) {
    .city-hero {
      padding: var(--space-24) 0;
    }
    .city-hero__grid {
      flex-direction: row;
      gap: 4rem;
    }
    .city-hero__content {
      flex: 0 0 58%;
    }
    .city-hero__image {
      flex: 1;
    }
  }

  .city-hero__content h1 {
    margin-bottom: 1.25rem;
  }

  .city-hero__sub {
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    color: var(--color-text-light);
    max-width: 600px;
    margin-bottom: 2.5rem;
  }

  .city-hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .city-hero__image {
    position: relative;
  }

  .city-hero__image img {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    aspect-ratio: 4/5;
    object-fit: cover;
    width: 100%;
  }

  .city-hero__glow {
    position: absolute;
    top: 0;
    right: 0;
    width: 40%;
    height: 100%;
    background: linear-gradient(to left, rgba(20, 91, 184, 0.06), transparent);
    pointer-events: none;
    z-index: -1;
  }

  /* --- Stats --- */
  .city-stats {
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: #fff;
  }

  .city-stats__grid {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  @media (min-width: 768px) {
    .city-stats__grid {
      gap: 0;
    }
    .city-stat {
      padding-inline: 3rem;
    }
    .city-stat + .city-stat {
      border-left: 1px solid var(--color-border);
    }
  }

  .city-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.25rem;
  }

  .city-stat__value {
    font-weight: 800;
    font-size: 1.25rem;
    color: var(--color-primary);
  }

  .city-stat__label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* --- Services --- */
  .city-services {
    background: #fff;
  }

  .city-services__carousel {
    margin-top: 2.5rem;
  }

  .city-services__track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
  }

  .city-services__track::-webkit-scrollbar {
    display: none;
  }

  /* Mobile: full-width single card */
  .city-services__track .city-service-card {
    flex: 0 0 100%;
    scroll-snap-align: start;
  }

  /* Dots — mobile only */
  .city-services__dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }

  .city-services__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-border);
    border: none;
    cursor: pointer;
    transition: all 0.25s ease;
    padding: 0;
  }

  .city-services__dot--active {
    background: var(--color-primary);
    width: 24px;
    border-radius: 4px;
  }

  @media (min-width: 768px) {
    .city-services__track {
      overflow: visible;
      scroll-snap-type: none;
    }
    .city-services__track .city-service-card {
      flex: 1;
    }
    .city-services__dots {
      display: none;
    }
  }

  .city-service-card {
    background: #fff;
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(226, 141, 51, 0.12);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.3s ease;
  }

  .city-service-card:hover {
    box-shadow: var(--shadow-lg);
  }

  .city-service-card__icon {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: transform 0.3s ease;
    padding: 10px;
  }

  .city-service-card__svg {
    display: block;
    width: 100%;
    height: 100%;
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
  }

  .city-service-card:hover .city-service-card__icon {
    transform: scale(1.1);
  }

  .city-service-card h3 {
    margin-bottom: 0.75rem;
  }

  .city-service-card p {
    flex: 1;
    font-size: 0.95rem;
  }

  .city-service-card__accent {
    width: 48px;
    height: 3px;
    background: #E28D33;
    margin-top: 1.5rem;
    border-radius: 2px;
  }

  .city-service-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    margin-top: 0.75rem;
    transition: gap 0.2s ease;
  }

  .city-service-card:hover .city-service-card__link {
    gap: 0.6rem;
  }

  /* --- Local Expertise --- */
  .city-local {
    background: var(--color-primary);
    color: #fff;
    padding: var(--space-20) 0;
    position: relative;
    overflow: hidden;
  }

  .city-local__grid {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 900px) {
    .city-local__grid {
      flex-direction: row;
      gap: 4rem;
    }
    .city-local__content {
      flex: 1;
    }
    .city-local__image {
      flex: 0 0 40%;
    }
  }

  .city-local__heading {
    color: #fff;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 1.5rem;
  }

  .city-local__text {
    font-size: 1.1rem;
    line-height: 1.7;
    color: rgba(200, 215, 240, 0.85);
    font-weight: 300;
  }

  .city-local__frame {
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid rgba(226, 141, 51, 0.25);
    aspect-ratio: 1;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
  }

  .city-local__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .city-local__gradient {
    position: absolute;
    top: 0;
    right: 0;
    width: 50%;
    height: 100%;
    background: linear-gradient(to left, rgba(20, 91, 184, 0.1), transparent);
    pointer-events: none;
  }

  /* --- Testimonials Grid --- */
  .city-testimonial__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .city-testimonial__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .city-testimonial__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .city-testimonial__card {
    position: relative;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 24px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    box-shadow: 0 10px 40px rgba(30, 58, 95, 0.06);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .city-testimonial__card:hover {
    box-shadow: 0 20px 60px rgba(30, 58, 95, 0.1);
    transform: translateY(-2px);
  }

  .city-testimonial__stars {
    display: flex;
    gap: 2px;
    margin-bottom: 1rem;
  }

  .city-testimonial__card blockquote {
    font-size: 0.95rem;
    line-height: 1.7;
    color: #2c3e50;
    margin-bottom: 1.5rem;
    flex: 1;
  }

  .city-testimonial__author {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    border-top: 1px solid #f0f0f0;
    padding-top: 1rem;
  }

  .city-testimonial__author strong {
    font-size: 1rem;
    color: var(--color-text);
  }

  .city-testimonial__author span {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* --- Pricing --- */
  /* --- Pricing Tabs --- */
  .pricing-tabs {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin: 2.5rem auto 0;
  }

  .pricing-tab {
    padding: 0.75rem 2rem;
    border: 2px solid var(--color-border, #e5e7eb);
    background: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-text-light);
    cursor: pointer;
    border-radius: 12px;
    transition: all 0.25s ease;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .pricing-tab:hover {
    border-color: var(--color-primary);
    color: var(--color-text);
  }

  .pricing-tab--active {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: rgba(20, 91, 184, 0.04);
    box-shadow: 0 2px 8px rgba(20, 91, 184, 0.1);
  }

  .pricing-tab--winter {
    border-color: #93c5fd;
  }

  .pricing-tab--winter.pricing-tab--active {
    border-color: #60a5fa;
    background: rgba(219, 234, 254, 0.3);
    color: #1e40af;
    box-shadow: 0 2px 8px rgba(59, 130, 246, 0.1);
  }

  .pricing-tab__badge {
    position: absolute;
    top: -10px;
    right: -8px;
    font-size: 0.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: #dbeafe;
    color: #1e40af;
    padding: 0.2rem 0.5rem;
    border-radius: 99px;
    white-space: nowrap;
    border: 2px solid #93c5fd;
    line-height: 1.2;
  }

  /* --- Pricing Card --- */
  .pricing-card {
    background: #fff;
    border-radius: 24px;
    border: 1px solid var(--color-border, #e5e7eb);
    box-shadow: 0 10px 40px rgba(30, 58, 95, 0.06);
    margin-top: 1.5rem;
    overflow: hidden;
  }

  .pricing-card__content {
    display: none;
    padding: 2.5rem;
  }

  .pricing-card__content--active {
    display: block;
  }

  .pricing-card__layout {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .pricing-card__content {
      padding: 3rem;
    }
    .pricing-card__layout {
      flex-direction: row;
      gap: 3rem;
    }
    .pricing-card__plan {
      flex: 1;
    }
    .pricing-card__chemicals {
      flex: 1;
      border-left: 1px solid var(--color-gray-100, #f0f0f0);
      padding-left: 3rem;
    }
  }

  .pricing-card__plan h3 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .pricing-card__subtitle {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .pricing-card__headline {
    margin-bottom: 1.25rem;
  }

  .pricing-card__price-line {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .pricing-card__amount {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-text);
    line-height: 1;
    white-space: nowrap;
  }

  .pricing-card__period {
    display: block;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.15rem;
  }

  .pricing-card__basis {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  /* Pricing Table */
  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1rem;
  }

  .pricing-table th {
    text-align: left;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    padding: 0.75rem 0;
    border-bottom: 2px solid var(--color-gray-100, #f0f0f0);
  }

  .pricing-table td {
    padding: 0.85rem 0;
    font-size: 0.95rem;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-gray-100, #f0f0f0);
  }

  .pricing-table td:not(:first-child) {
    font-weight: 700;
    text-align: left;
    padding-left: 1rem;
  }

  .pricing-table__addon td {
    color: var(--color-text-light);
    font-style: italic;
  }

  .pricing-card__note {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: 0.75rem;
    line-height: 1.5;
  }

  /* --- Pricing Configurator --- */
  .pricing-config__types {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .pricing-config__type {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 2px solid var(--color-border, #e5e7eb);
    background: #fff;
    border-radius: 10px;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-light);
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: center;
  }

  .pricing-config__type:hover {
    border-color: var(--color-primary);
    color: var(--color-text);
  }

  .pricing-config__type--active {
    border-color: var(--color-primary);
    background: rgba(20, 91, 184, 0.04);
    color: var(--color-primary);
    box-shadow: 0 2px 6px rgba(20, 91, 184, 0.1);
  }

  .pricing-config__visit {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-gray-100, #f0f0f0);
    margin-bottom: 0.75rem;
  }

  .pricing-config__visit-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .pricing-config__visit-amount {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-text);
  }

  .pricing-config__addon {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.75rem;
    background: var(--color-light-bg, #f9f6f0);
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.75rem;
    transition: background 0.2s ease;
  }

  .pricing-config__addon:hover {
    background: #f0ede6;
  }

  .pricing-config__addon input[type="checkbox"] {
    width: 18px;
    height: 18px;
    accent-color: var(--color-cta);
    cursor: pointer;
  }

  .pricing-card__plus-chem {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: var(--color-cta);
  }

  /* Base pricing label */
  .pricing-card__base-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.4rem;
    margin-top: 0.25rem;
  }

  /* Compact base pricing table — matches screenshot */
  .pricing-table--base {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0.75rem;
  }
  .pricing-table--base td {
    padding: 0.35rem 0;
    font-size: 0.8rem;
    color: var(--color-text-light);
    line-height: 1.3;
  }
  .pricing-table--base td:first-child {
    color: var(--color-text);
    padding-right: 2rem;
  }
  .pricing-table--base td:nth-child(2) {
    font-weight: 700;
    color: var(--color-text);
    white-space: nowrap;
  }
  .pricing-table--base td:nth-child(3) {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    padding-left: 0.75rem;
    white-space: nowrap;
  }

  /* Includes list — single column, original card style */
  .pricing-card__includes {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    margin-bottom: 0.5rem;
    padding-top: 0;
  }
  .pricing-card__includes li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-text);
  }
  .pricing-card__includes li svg {
    flex-shrink: 0;
  }

  .pricing-card__green-guarantee {
    color: #059669;
    font-weight: 600;
  }

  .tooltip-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #d1fae5;
    color: #059669;
    font-size: 0.65rem;
    font-weight: 700;
    cursor: help;
    margin-left: 0.35rem;
    position: relative;
    vertical-align: middle;
  }

  .tooltip {
    display: none;
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-text, #1E3A5F);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 400;
    line-height: 1.5;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    width: 260px;
    z-index: 10;
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }

  .tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: var(--color-text, #1E3A5F);
  }

  .tooltip-trigger:hover .tooltip {
    display: block;
  }

  /* === Bi-Weekly Comparison === */
  .biweekly-compare {
    background: #f9fafb;
    border-radius: 10px;
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .biweekly-compare__title {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #1E3A5F;
    margin-bottom: 0.6rem;
  }

  .biweekly-compare__bars {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }

  .biweekly-compare__row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .biweekly-compare__label {
    flex: 0 0 65px;
    font-size: 0.75rem;
    font-weight: 600;
    color: #374151;
  }

  .biweekly-compare__bar-track {
    flex: 1;
    height: 12px;
    background: #e5e7eb;
    border-radius: 6px;
    overflow: hidden;
  }

  .biweekly-compare__bar {
    height: 100%;
    border-radius: 6px;
  }

  .biweekly-compare__bar--weekly {
    background: linear-gradient(to right, #93c5fd, #3b82f6);
  }

  .biweekly-compare__bar--biweekly {
    background: linear-gradient(to right, #fcd34d, #f59e0b);
  }

  .biweekly-compare__value {
    flex: 0 0 60px;
    font-size: 0.8rem;
    font-weight: 700;
    color: #374151;
    text-align: right;
  }

  .biweekly-compare__note {
    font-size: 0.72rem;
    color: #6b7280;
    line-height: 1.45;
  }

  .biweekly-compare__points {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .biweekly-compare__point {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }

  .biweekly-compare__point svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .biweekly-compare__point strong {
    display: block;
    font-size: 0.8rem;
    color: #1E3A5F;
    margin-bottom: 0.1rem;
  }

  .biweekly-compare__point span {
    font-size: 0.72rem;
    color: #6b7280;
    line-height: 1.45;
  }

  /* === Bi-Weekly Story === */
  .biweekly-story {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .biweekly-story__row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .biweekly-story__icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .biweekly-story__label {
    font-size: 0.82rem;
    font-weight: 700;
    color: #1E3A5F;
    margin-bottom: 0.3rem;
  }

  .biweekly-story__bar {
    height: 4px;
    border-radius: 2px;
    margin-bottom: 0.3rem;
  }

  .biweekly-story__bar--good {
    width: 100%;
    background: linear-gradient(to right, #86efac, #22c55e);
  }

  .biweekly-story__bar--warn {
    width: 70%;
    background: linear-gradient(to right, #fcd34d, #f59e0b);
  }

  .biweekly-story__bar--bad {
    width: 40%;
    background: linear-gradient(to right, #fca5a5, #ef4444);
  }

  .biweekly-story__desc {
    font-size: 0.75rem;
    color: #6b7280;
    line-height: 1.5;
    margin: 0;
  }

  .biweekly-story__kicker {
    font-size: 0.78rem;
    font-weight: 600;
    color: #2563eb;
    line-height: 1.5;
    padding-top: 0.5rem;
    border-top: 1px solid #e5e7eb;
    margin: 0;
  }

  /* === True Cost Pricing === */
  .pricing-card__chemicals {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .chem-header {}
  .chem-kicker {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-cta);
    margin-bottom: 0.4rem;
  }
  .chem-header h4 {
    font-size: 1.25rem;
    margin-bottom: 0.4rem;
  }
  .chem-header p {
    font-size: 0.85rem;
    color: var(--color-text-light);
    line-height: 1.5;
  }

  /* Number line / range */
  .chem-range {
    background: var(--color-light-bg, #f9f6f0);
    border-radius: 12px;
    padding: 1.25rem;
  }
  .chem-range__label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }
  .chem-range__track {
    position: relative;
    height: 8px;
    background: #e5e7eb;
    border-radius: 4px;
    margin-bottom: 2rem;
  }
  .chem-range__bar {
    position: absolute;
    left: 10%;
    right: 10%;
    top: 0;
    bottom: 0;
    background: linear-gradient(to right, var(--color-primary), var(--color-cta));
    border-radius: 4px;
    opacity: 0.7;
  }
  .chem-range__marker {
    position: absolute;
    top: 16px;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .chem-range__marker--low { left: 10%; transform: translateX(-50%); }
  .chem-range__marker--mid { left: 50%; transform: translateX(-50%); }
  .chem-range__marker--high { right: 10%; transform: translateX(50%); }
  .chem-range__tag {
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-cta);
    margin-bottom: 2px;
  }
  .chem-range__labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }

  /* Flat rate comparison bars */
  .chem-compare {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .chem-compare__row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
  }
  .chem-compare__label {
    flex: 0 0 120px;
    font-weight: 500;
    color: var(--color-text-light);
    font-size: 0.75rem;
  }
  .chem-compare__bar {
    flex: 1;
    height: 10px;
    border-radius: 5px;
  }
  .chem-compare__row--them .chem-compare__bar {
    background: #ef4444;
    opacity: 0.3;
  }
  .chem-compare__row--us .chem-compare__bar {
    background: linear-gradient(to right, var(--color-primary), var(--color-cta));
    opacity: 0.6;
  }
  .chem-compare__value {
    flex: 0 0 100px;
    font-weight: 700;
    font-size: 0.8rem;
    color: var(--color-text);
    text-align: right;
  }

  /* === Seasonal Chemical Data === */
  .chem-seasons {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .chem-season__header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
  }

  .chem-season__icon {
    font-size: 1rem;
  }

  .chem-season__name {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text);
  }

  .chem-season__track {
    position: relative;
    height: 10px;
    background: #f0f0f0;
    border-radius: 5px;
    margin-bottom: 0.4rem;
  }

  .chem-season__bar {
    position: absolute;
    top: 0;
    bottom: 0;
    border-radius: 5px;
  }

  .chem-season__bar--winter {
    background: linear-gradient(to right, #93c5fd, #3b82f6);
  }

  .chem-season__bar--summer {
    background: linear-gradient(to right, #fbbf24, #f59e0b);
  }

  .chem-season__flatline {
    position: absolute;
    top: -3px;
