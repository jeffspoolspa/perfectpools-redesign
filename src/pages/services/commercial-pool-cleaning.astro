---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';

const base = import.meta.env.BASE_URL;

const faqs = [
  { question: 'What types of commercial pools do you service?', answer: 'We maintain pools for HOA communities, hotels and motels, apartment complexes, fitness centers, and short-term rental properties throughout the Greater Savannah area.' },
  { question: 'Do you handle health department compliance?', answer: 'Yes. We maintain chemical logs, testing schedules, and service documentation formatted exactly how Georgia DPH inspectors expect to see them. When they show up, you hand them our logs.' },
  { question: 'Can you work around our facility hours?', answer: 'Absolutely. We offer flexible scheduling including early morning, evening, and weekend service times to minimize disruption to your guests and residents.' },
  { question: 'How do you handle high-traffic pools?', answer: 'Higher bather loads mean more contaminants. We adjust testing frequency and chemical dosing based on your actual usage patterns—not a one-size-fits-all schedule.' },
  { question: 'What happens if our regular tech is unavailable?', answer: 'Someone else on the team covers the route—same day, same service standards. Commercial properties can\'t wait, and we don\'t make you.' },
  { question: 'How does commercial pricing work?', answer: 'Pricing is based on pool size, visit frequency, and specific compliance requirements. Contact us for a consultation and custom quote for your property.' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Commercial Pool Cleaning",
    "provider": { "@type": "LocalBusiness", "name": "Perfect Pools" },
    "areaServed": "Savannah, Richmond Hill, Coastal Georgia",
    "priceRange": "Contact for pricing"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": { "@type": "Answer", "text": f.answer }
    }))
  }
];
---

<BaseLayout
  title="Commercial Pool Cleaning in Savannah & Richmond Hill GA | Perfect Pools"
  description="Professional commercial pool maintenance for HOAs, hotels, apartments, and short-term rentals. Health department compliant documentation, 24hr response time. Serving Coastal Georgia."
  canonicalPath="/services/commercial-pool-cleaning/"
  schema={schema}
>
  <!-- Hero -->
  <section class="comm-hero">
    <div class="comm-hero__bg"></div>
    <div class="container comm-hero__content">
      <h1 class="comm-hero__title">Commercial pool care that keeps you compliant and covered.</h1>
      <p class="comm-hero__subtitle">
        Health department documentation, reliable service, and one point of contact. So you can focus on your property, not your pool.
      </p>
      <button type="button" class="btn btn--accent btn--lg" data-open-intake>Schedule a Consultation</button>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="comm-stats">
    <div class="container">
      <div class="comm-stats__grid">
        <div class="comm-stats__item">
          <span class="comm-stats__number">50+</span>
          <span class="comm-stats__label">Properties Serviced</span>
        </div>
        <div class="comm-stats__item">
          <span class="comm-stats__number">100%</span>
          <span class="comm-stats__label">Inspection Ready</span>
        </div>
        <div class="comm-stats__item">
          <span class="comm-stats__number">24hr</span>
          <span class="comm-stats__label">Response Time</span>
        </div>
        <div class="comm-stats__item">
          <span class="comm-stats__number">15+</span>
          <span class="comm-stats__label">Years Experience</span>
        </div>
      </div>
    </div>
  </section>

  <!-- What Commercial Pools Require — Image + Callouts -->
  <section class="section comm-require">
    <div class="container">
      <div class="comm-require__layout">
        <div class="comm-require__image">
          <img src={`${base}images/tech-testing-poolside.jpg`} alt="Pool technician testing water at a commercial property" loading="lazy" width="640" height="480" />
        </div>
        <div class="comm-require__content">
          <span class="section-label">Built for commercial</span>
          <h2>What commercial pools require differently</h2>
          <p class="comm-require__intro">
            Commercial pools aren't just bigger residential pools—they have different regulations, higher bather loads, and stricter documentation requirements. We understand that world.
          </p>

          <div class="comm-callouts">
            <div class="comm-callout">
              <div class="comm-callout__icon comm-callout__icon--blue">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="5" x="8" y="2" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg>
              </div>
              <div>
                <strong>Health department compliance</strong>
                <p>We follow Georgia DPH requirements exactly and maintain records that pass inspections.</p>
              </div>
            </div>

            <div class="comm-callout">
              <div class="comm-callout__icon comm-callout__icon--purple">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <div>
                <strong>Higher bather load management</strong>
                <p>We adjust testing frequency and chemical dosing based on your actual usage patterns.</p>
              </div>
            </div>

            <div class="comm-callout">
              <div class="comm-callout__icon comm-callout__icon--green">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
              </div>
              <div>
                <strong>Inspection-ready documentation</strong>
                <p>Every test, adjustment, and visit—logged, timestamped, and formatted for county inspectors.</p>
              </div>
            </div>

            <div class="comm-callout">
              <div class="comm-callout__icon comm-callout__icon--orange">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
              </div>
              <div>
                <strong>Equipment at commercial scale</strong>
                <p>We monitor systems built to handle continuous use and flag issues early.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Every Visit Includes -->
  <section class="section visit-section">
    <div class="container">
      <h2 class="visit-headline">What every visit includes:</h2>

      <div class="visit-grid">
        <div class="visit-item">
          <img src={`${base}images/icons/test-tubes.svg`} width="48" height="48" alt="" />
          <h3>Water Testing</h3>
          <p>pH, free/combined chlorine, alkalinity, stabilizer, hardness—tested and logged every visit.</p>
        </div>

        <div class="visit-item">
          <img src={`${base}images/icons/chemical.svg`} width="48" height="48" alt="" />
          <h3>Chemistry Adjustment</h3>
          <p>Dosed to exact readings with commercial-grade chemicals. Quantities and costs documented.</p>
        </div>

        <div class="visit-item">
          <img src={`${base}images/icons/motor.svg`} width="48" height="48" alt="" />
          <h3>Equipment Monitoring</h3>
          <p>Pumps, filters, heaters, feeders, automation systems—checked for proper operation.</p>
        </div>

        <div class="visit-item">
          <img src={`${base}images/icons/skimmer-net.svg`} width="48" height="48" alt="" />
          <h3>Surface Cleaning</h3>
          <p>Skim, brush tile line, empty baskets. Your pool looks maintained before guests arrive.</p>
        </div>

        <div class="visit-item">
          <img src={`${base}images/icons/pool-brush.svg`} width="48" height="48" alt="" />
          <h3>Brush Walls & Tile</h3>
          <p>Thorough brushing to prevent algae buildup and calcium deposits on commercial surfaces.</p>
        </div>

        <div class="visit-item">
          <img src={`${base}images/icons/vacuum.svg`} width="48" height="48" alt="" />
          <h3>Vacuum</h3>
          <p>Vacuum pool floor and walls to remove dirt, debris, and settled contaminants.</p>
        </div>

        <div class="visit-item">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="5" x="8" y="2" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg>
          <h3>Chemical Log</h3>
          <p>Date, time, readings, adjustments—formatted for health department inspections.</p>
        </div>

        <div class="visit-item">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 12h4"/><path d="M10 16h4"/></svg>
          <h3>Digital Report</h3>
          <p>Photos, notes, and readings sent to your property manager portal or email.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Compliance Documentation -->
  <section class="section compliance-section" style="background: linear-gradient(135deg, #f0fdf4, #ecfdf5);">
    <div class="container">
      <div class="compliance-layout">
        <div class="compliance-layout__content">
          <span class="compliance-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
            Inspection Ready
          </span>
          <h2>Compliance documentation that actually works</h2>
          <p class="compliance-layout__text">
            When the health department shows up, you hand them our logs. That's it. We maintain chemical records, testing schedules, and service documentation formatted exactly how inspectors expect to see them.
          </p>

          <div class="compliance-checks">
            <div class="compliance-check">
              <div class="compliance-check__dot"></div>
              <div>
                <strong>Georgia DPH format</strong>
                <span>Chemical logs match state requirements exactly</span>
              </div>
            </div>
            <div class="compliance-check">
              <div class="compliance-check__dot"></div>
              <div>
                <strong>Timestamped records</strong>
                <span>Every test and adjustment logged with date/time</span>
              </div>
            </div>
            <div class="compliance-check">
              <div class="compliance-check__dot"></div>
              <div>
                <strong>Instant access</strong>
                <span>Download reports anytime for inspections or audits</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Mock Chemical Log -->
        <div class="chem-log">
          <div class="chem-log__header">
            <span class="chem-log__property">Property: Seaside HOA</span>
            <span class="chem-log__title">Chemical Log - March 2026</span>
          </div>
          <div class="chem-log__body">
            <div class="chem-log__entry">
              <div class="chem-log__entry-header">
                <span class="chem-log__date">March 9, 2026 - 8:15 AM</span>
                <span class="chem-log__status">Compliant</span>
              </div>
              <div class="chem-log__readings">
                <div><span class="chem-log__label">FC</span><span class="chem-log__value">2.8 ppm</span></div>
                <div><span class="chem-log__label">pH</span><span class="chem-log__value">7.4</span></div>
                <div><span class="chem-log__label">TA</span><span class="chem-log__value">105 ppm</span></div>
              </div>
              <span class="chem-log__note">Added: 3.5 gal liquid chlorine</span>
            </div>

            <div class="chem-log__entry">
              <div class="chem-log__entry-header">
                <span class="chem-log__date">March 6, 2026 - 9:00 AM</span>
                <span class="chem-log__status">Compliant</span>
              </div>
              <div class="chem-log__readings">
                <div><span class="chem-log__label">FC</span><span class="chem-log__value">3.1 ppm</span></div>
                <div><span class="chem-log__label">pH</span><span class="chem-log__value">7.6</span></div>
                <div><span class="chem-log__label">TA</span><span class="chem-log__value">98 ppm</span></div>
              </div>
              <span class="chem-log__note">Added: 2 lbs pH decreaser</span>
            </div>

            <div class="chem-log__entry">
              <div class="chem-log__entry-header">
                <span class="chem-log__date">March 2, 2026 - 8:30 AM</span>
                <span class="chem-log__status">Compliant</span>
              </div>
              <div class="chem-log__readings">
                <div><span class="chem-log__label">FC</span><span class="chem-log__value">2.9 ppm</span></div>
                <div><span class="chem-log__label">pH</span><span class="chem-log__value">7.3</span></div>
                <div><span class="chem-log__label">TA</span><span class="chem-log__value">100 ppm</span></div>
              </div>
              <span class="chem-log__note">Added: 3.0 gal liquid chlorine</span>
            </div>
          </div>
          <div class="chem-log__footer">
            <span>Ready for inspection</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- We Handle Everything — Photo Carousel -->
  <section class="section manage-section">
    <div class="container">
      <div class="section-header" style="max-width: 720px; margin-bottom: var(--space-12);">
        <span class="section-label">Full-service management</span>
        <h2 style="font-size: clamp(2rem, 4vw, 2.75rem); margin-bottom: var(--space-4);">We handle everything so you don't have to</h2>
        <p style="font-size: var(--text-lg); color: var(--color-gray-600); line-height: 1.7;">Commercial pool management goes beyond weekly cleaning. We take the entire operation off your plate.</p>
      </div>

      <div class="manage-carousel" id="manageCarousel">
        <div class="manage-carousel__track" id="carouselTrack">
          <!-- Slide 1: Bulk Chemicals -->
          <div class="manage-slide" data-slide="0">
            <div class="manage-slide__image">
              <img src={`${base}images/pool-cleaning.jpg`} alt="Bulk chemical delivery for commercial pools" loading="lazy" width="640" height="480" />
            </div>
            <div class="manage-slide__content">
              <span class="manage-slide__badge manage-slide__badge--blue">Save up to 30%</span>
              <h3>Bulk chemical delivery</h3>
              <p>We monitor your levels and deliver in bulk before you run low. No emergency runs, no retail markup—just commercial pricing and hands-free inventory management.</p>
              <ul class="manage-slide__points">
                <li>Bulk pricing saves up to 30% vs. store-bought</li>
                <li>We deliver, store, and manage inventory</li>
                <li>Never run out mid-season again</li>
              </ul>
            </div>
          </div>

          <!-- Slide 2: Equipment Rooms -->
          <div class="manage-slide" data-slide="1">
            <div class="manage-slide__image">
              <img src={`${base}images/checking-over-equipment.jpg`} alt="Clean and organized pool equipment room" loading="lazy" width="640" height="480" />
            </div>
            <div class="manage-slide__content">
              <span class="manage-slide__badge manage-slide__badge--green">Inspection Ready</span>
              <h3>Equipment rooms kept clean & organized</h3>
              <p>Your pump room reflects your property. We keep chemical storage organized, equipment labeled, and the space clean—ready for any walkthrough.</p>
              <ul class="manage-slide__points">
                <li>Chemical storage organized and labeled</li>
                <li>No cluttered shelves or leaking jugs</li>
                <li>Professional appearance for inspectors</li>
              </ul>
            </div>
          </div>

          <!-- Slide 3: DPH Handling -->
          <div class="manage-slide" data-slide="2">
            <div class="manage-slide__image">
              <img src={`${base}images/pool-water-testing.jpg`} alt="Water testing for health department compliance" loading="lazy" width="640" height="480" />
            </div>
            <div class="manage-slide__content">
              <span class="manage-slide__badge manage-slide__badge--purple">Full Compliance</span>
              <h3>We deal with the health department</h3>
              <p>When DPH shows up, you hand them our logs—that's it. We maintain all documentation, handle follow-ups, and keep your property in compliance.</p>
              <ul class="manage-slide__points">
                <li>Georgia DPH-formatted chemical logs</li>
                <li>We handle inspector questions directly</li>
                <li>Zero compliance headaches for you</li>
              </ul>
            </div>
          </div>

          <!-- Slide 4: Reliable Coverage -->
          <div class="manage-slide" data-slide="3">
            <div class="manage-slide__image">
              <img src={`${base}images/pool-cleaning-action.jpg`} alt="Pool technician providing reliable service" loading="lazy" width="640" height="480" />
            </div>
            <div class="manage-slide__content">
              <span class="manage-slide__badge manage-slide__badge--orange">Never Missed</span>
              <h3>Reliable coverage, every time</h3>
              <p>Tech calls in sick? Someone else covers the route—same day, same standards. One point of contact, full backup coverage, no gaps in service.</p>
              <ul class="manage-slide__points">
                <li>Same-day backup if your tech is out</li>
                <li>Supervisor oversight on every route</li>
                <li>One dedicated point of contact</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Navigation -->
        <div class="manage-carousel__nav">
          <button class="manage-carousel__arrow manage-carousel__arrow--prev" id="carouselPrev" aria-label="Previous slide">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <div class="manage-carousel__dots" id="carouselDots">
            <button class="manage-carousel__dot active" data-slide="0" aria-label="Slide 1"></button>
            <button class="manage-carousel__dot" data-slide="1" aria-label="Slide 2"></button>
            <button class="manage-carousel__dot" data-slide="2" aria-label="Slide 3"></button>
            <button class="manage-carousel__dot" data-slide="3" aria-label="Slide 4"></button>
          </div>
          <button class="manage-carousel__arrow manage-carousel__arrow--next" id="carouselNext" aria-label="Next slide">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <script>
    (function() {
      const track = document.getElementById('carouselTrack');
      const dots = document.querySelectorAll('#carouselDots .manage-carousel__dot');
      const prev = document.getElementById('carouselPrev');
      const next = document.getElementById('carouselNext');
      const slides = track.querySelectorAll('.manage-slide');
      let current = 0;

      function goTo(index) {
        if (index < 0) index = slides.length - 1;
        if (index >= slides.length) index = 0;
        current = index;
        track.style.transform = `translateX(-${current * 100}%)`;
        dots.forEach((d, i) => d.classList.toggle('active', i === current));
      }

      prev.addEventListener('click', () => goTo(current - 1));
      next.addEventListener('click', () => goTo(current + 1));
      dots.forEach(dot => {
        dot.addEventListener('click', () => goTo(parseInt(dot.dataset.slide)));
      });

      // Auto-advance every 6 seconds
      let autoplay = setInterval(() => goTo(current + 1), 6000);
      const carousel = document.getElementById('manageCarousel');
      carousel.addEventListener('mouseenter', () => clearInterval(autoplay));
      carousel.addEventListener('mouseleave', () => {
        autoplay = setInterval(() => goTo(current + 1), 6000);
      });

      // Touch/swipe support
      let touchStartX = 0;
      track.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
      track.addEventListener('touchend', (e) => {
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) goTo(current + (diff > 0 ? 1 : -1));
      }, { passive: true });
    })();
  </script>

  <!-- Properties We Service -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2>Properties we service</h2>
        <p class="section-header__subtitle">From HOA community pools to hotel resorts, we handle commercial properties of all types</p>
      </div>

      <div class="property-grid">
        <div class="property-card">
          <div class="property-card__icon property-card__icon--blue">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>
          </div>
          <h3>HOAs</h3>
          <p>Community pools for homeowners associations and neighborhoods</p>
        </div>

        <div class="property-card">
          <div class="property-card__icon property-card__icon--purple">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21V5a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v16"/><path d="M22 21H2"/><path d="M9 7h1"/><path d="M9 11h1"/><path d="M14 7h1"/><path d="M14 11h1"/><path d="M9 15v6"/><path d="M15 15v6"/></svg>
          </div>
          <h3>Hotels</h3>
          <p>Resort and hotel pools with high guest turnover</p>
        </div>

        <div class="property-card">
          <div class="property-card__icon property-card__icon--green">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3>Apartment Complexes</h3>
          <p>Multi-family residential properties with shared amenities</p>
        </div>

        <div class="property-card">
          <div class="property-card__icon property-card__icon--orange">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
          </div>
          <h3>Short-Term Rentals</h3>
          <p>Vacation rental properties with frequent guest turnover</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>What property managers say</h2>
        <p class="section-header__subtitle">Real feedback from commercial clients</p>
      </div>

      <div class="reviews-grid reviews-grid--2col">
        <div class="review-card review-card--alt">
          <div class="review-card__stars">
