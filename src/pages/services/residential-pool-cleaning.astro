---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';

const base = import.meta.env.BASE_URL;

const faqs = [
  { question: 'How often should I have my pool cleaned?', answer: 'For most residential pools in the Savannah area, weekly service is recommended due to our warm climate and high pollen counts. Bi-weekly service is available for pools with less usage.' },
  { question: 'What does a typical cleaning visit include?', answer: 'Each visit includes skimming the surface, brushing walls and tile, vacuuming the floor, testing and balancing chemicals, checking the filter, and inspecting all equipment.' },
  { question: 'Do you bring your own chemicals and equipment?', answer: 'Yes, our technicians arrive fully equipped with professional-grade chemicals, testing kits, and cleaning tools. Chemicals are billed separately at transparent, itemized pricing.' },
  { question: 'What if I need service outside the regular schedule?', answer: 'We offer one-time cleanings and can adjust schedules for parties, storms, or special events. Just call us to arrange additional visits.' },
  { question: 'What is the Green Free Guarantee?', answer: 'If your pool turns green while you\'re on weekly service, we handle the recovery at no charge. Period. It\'s our promise that your pool stays swim-ready.' },
  { question: 'How does billing work?', answer: 'Service is billed monthly at a flat rate ($200/mo for weekly). Chemicals used are billed separately and fully itemized so you see exactly what was added and why.' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Residential Pool Cleaning",
    "provider": { "@type": "LocalBusiness", "name": "Perfect Pools" },
    "areaServed": "Savannah, Richmond Hill, Coastal Georgia",
    "priceRange": "From $50/visit"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": { "@type": "Answer", "text": f.answer }
    }))
  }
];
---

<BaseLayout
  title="Residential Pool Cleaning in Savannah & Richmond Hill GA | Perfect Pools"
  description="Weekly residential pool cleaning at $200/month. Professional water testing, chemical balancing, cleaning, and digital reports every visit. Serving Richmond Hill, Savannah & Coastal Georgia."
  canonicalPath="/services/residential-pool-cleaning/"
  schema={schema}
>
  <!-- Hero -->
  <section class="res-hero">
    <div class="res-hero__bg"></div>
    <div class="container res-hero__content">
      <h1 class="res-hero__title">Your pool, handled.<br>Every week.</h1>
      <p class="res-hero__subtitle">
        Water testing, chemistry, cleaning, and reports—every visit. So you can actually enjoy your backyard.
      </p>
      <button type="button" class="btn btn--accent btn--lg" data-open-intake>Get a Quote</button>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section hiw-section">
    <div class="container">
      <div class="hiw-header">
        <span class="section-label">How it works</span>
        <h2 class="hiw-headline">Clear pricing. Easy signup. Better results.</h2>
      </div>

      <div class="steps-grid">
        <div class="step-card">
          <div class="step-card__icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3>View our pricing</h3>
          <p>Clear, itemized pricing for weekly service. See exactly what weekly maintenance costs, plus transparent pricing on chemicals and extras like filter cleans.</p>
        </div>

        <div class="step-card">
          <div class="step-card__icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3l7.07 16.97 2.51-7.39 7.39-2.51L3 3z"/><path d="m13 13 6 6"/></svg>
          </div>
          <h3>Sign up online</h3>
          <p>Quick online signup in minutes. Tell us about your pool, pick your start date, and we'll handle the rest. No waiting for callbacks or home visits.</p>
        </div>

        <div class="step-card">
          <div class="step-card__icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
          </div>
          <h3>Enjoy your pool</h3>
          <p>We show up every week, test and balance your water, clean and report. You get crystal-clear water without lifting a finger.</p>
        </div>
      </div>

      <div class="text-center">
        <button type="button" class="btn btn--accent btn--lg" data-open-intake>Get Started Today</button>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="section section--alt" id="pricing-section">
    <div class="container">
      <div class="text-center">
        <span class="section-label">PRICING STRUCTURE</span>
        <h2>Transparent Investments.</h2>
        <p style="color: var(--color-text-light); max-width: 540px; margin: 0.5rem auto 0;">No contracts. Month-to-month service with 2 weeks notice to cancel.</p>
      </div>

      <!-- Tab Switcher -->
      <div class="pricing-tabs">
        <button class="pricing-tab pricing-tab--active" data-tab="weekly">Weekly</button>
        <button class="pricing-tab pricing-tab--winter" data-tab="biweekly">
          Bi-Weekly
          <span class="pricing-tab__badge">❄ Winter Only</span>
        </button>
      </div>

      <!-- Pricing Card -->
      <div class="pricing-card">
        <div class="pricing-card__content pricing-card__content--active" data-content="weekly">
          <div class="pricing-card__layout">
            <div class="pricing-card__plan" id="res-pricing-config-weekly"></div>
            <div class="pricing-card__chemicals">
              <div class="chem-header">
                <span class="chem-kicker">HOW CHEMICALS WORK</span>
                <h4>True Cost Pricing</h4>
                <p>Your bill reflects your pool, not an average.</p>
              </div>
              <div id="res-chem-chart-weekly"></div>
            </div>
          </div>
        </div>
        <div class="pricing-card__content" data-content="biweekly">
          <div class="pricing-card__layout">
            <div class="pricing-card__plan" id="res-pricing-config-biweekly"></div>
            <div class="pricing-card__chemicals">
              <div class="chem-header">
                <span class="chem-kicker">WHY WINTER ONLY</span>
                <h4>Weekly vs. Bi-Weekly</h4>
                <p style="color: #1E3A5F; font-weight: 700;">Anyone who's maintained a pool in coastal weather knows — two weeks is too long in the heat.</p>
              </div>
              <div class="biweekly-section__title">The Lawn Analogy</div>
              <div class="biweekly-cards">
                <div class="biweekly-card biweekly-card--good"><span class="biweekly-card__emoji">🌿</span><strong>Weekly</strong><span>Like mowing every week — stays level, no surprises.</span></div>
                <div class="biweekly-card biweekly-card--warn"><span class="biweekly-card__emoji">🌾</span><strong>Bi-weekly</strong><span>Tall grass, weeds taking hold, harder to cut through.</span></div>
                <div class="biweekly-card biweekly-card--bad"><span class="biweekly-card__emoji">🟢</span><strong>Green pool</strong><span>The overgrown yard — needs specialized equipment to recover.</span></div>
              </div>
              <p class="biweekly-story__kicker">Algae slows in winter just like grass — which is why bi-weekly works September through March.</p>
              <div class="biweekly-section__title">The Data Shows the Strain</div>
              <div class="biweekly-compare">
                <div class="biweekly-compare__bars">
                  <div class="biweekly-compare__row"><span class="biweekly-compare__label">Weekly</span><div class="biweekly-compare__bar-track"><div class="biweekly-compare__bar biweekly-compare__bar--weekly" style="width: 80%;"></div></div><span class="biweekly-compare__value">$25/visit</span></div>
                  <div class="biweekly-compare__row"><span class="biweekly-compare__label">Bi-Weekly</span><div class="biweekly-compare__bar-track"><div class="biweekly-compare__bar biweekly-compare__bar--biweekly" style="width: 100%;"></div></div><span class="biweekly-compare__value" style="color: #d97706; font-weight: 800;">$31/visit</span></div>
                </div>
                <p class="biweekly-compare__note">24% more chemicals per visit just to play catch-up — which is why we no longer offer bi-weekly in summer.</p>
              </div>
              <div class="biweekly-section__title">What Happens in Two Weeks</div>
              <div class="biweekly-cards">
                <div class="biweekly-card biweekly-card--bad"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><path d="M12 2v10M12 22a10 10 0 0 1 0-20"/><circle cx="12" cy="12" r="2" fill="#ef4444"/></svg><strong>Chlorine bottoms out</strong><span>Degrades to zero in 10–14 days.</span></div>
                <div class="biweekly-card biweekly-card--warn"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M12 6v6l4 2"/></svg><strong>Phosphate buildup</strong><span>Debris breaks down into algae food.</span></div>
                <div class="biweekly-card biweekly-card--warn"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><path d="M12 9v4M12 17h.01"/></svg><strong>Equipment unmonitored</strong><span>Failures run 12+ days undetected.</span></div>
              </div>
              <p class="chem-data-note" style="margin-top: 0.5rem;">Chemical data from customers who remained on bi-weekly last summer.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center" style="margin-top: 2rem;">
        <a href={`${base}get-started/`} class="btn btn--cta btn--lg">Get Started</a>
        <p style="margin-top: 1rem; color: var(--color-text-light); font-size: 0.85rem;">
          Chemicals billed separately at transparent cost-plus pricing. <a href={`${base}plans/`} style="color: var(--color-primary); text-decoration: underline;">See full pricing details</a>
        </p>
      </div>
    </div>
  </section>

  <!-- What We Do Every Week -->
  <section class="section weekly-section">
    <div class="container">
      <h2 class="weekly-headline">Your weekly service includes:</h2>

      <div class="weekly-grid">
        <div class="weekly-item">
          <img src={`${base}images/icons/test-tubes.svg`} width="48" height="48" alt="" />
          <h3>Water Testing</h3>
          <p>Full panel test: chlorine, pH, alkalinity, hardness, stabilizer, salt, and phosphates.</p>
        </div>

        <div class="weekly-item">
          <img src={`${base}images/icons/chemical.svg`} width="48" height="48" alt="" />
          <h3>Chemical Dosing</h3>
          <p>Adjust chemistry based on test results—liquid chlorine, pH adjusters, and stabilizer as needed.</p>
        </div>

        <div class="weekly-item">
          <img src={`${base}images/icons/pool-brush.svg`} width="48" height="48" alt="" />
          <h3>Brush Walls & Steps</h3>
          <p>Thorough brushing to remove algae buildup and prevent stains on surfaces.</p>
        </div>

        <div class="weekly-item">
          <img src={`${base}images/icons/skimmer-net.svg`} width="48" height="48" alt="" />
          <h3>Skim & Net</h3>
          <p>Remove leaves, debris, and surface contaminants to keep water clear.</p>
        </div>

        <div class="weekly-item">
          <img src={`${base}images/icons/basket.svg`} width="48" height="48" alt="" />
          <h3>Empty Baskets</h3>
          <p>Clear skimmer and pump baskets so your circulation system runs efficiently.</p>
        </div>

        <div class="weekly-item">
          <img src={`${base}images/icons/motor.svg`} width="48" height="48" alt="" />
          <h3>Check Equipment</h3>
          <p>Check pressure to make sure equipment has proper flow, clean filters if not, and look for leaks, cracks, and wear.</p>
        </div>

        <div class="weekly-item">
          <img src={`${base}images/icons/vacuum.svg`} width="48" height="48" alt="" />
          <h3>Vacuum</h3>
          <p>Vacuum the pool floor and walls to remove dirt, debris, and settled algae.</p>
        </div>

        <div class="weekly-item">
          <img src={`${base}images/icons/water-tap.svg`} width="48" height="48" alt="" />
          <h3>Check Water Level</h3>
          <p>Verify water level is at the correct height and add fresh water if needed.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Green Free Guarantee -->
  <section class="section section--alt">
    <div class="container">
      <div class="guarantee-banner">
        <div class="guarantee-banner__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
        </div>
        <h3>Green Free Guarantee</h3>
        <p>If your pool turns green while you're on weekly service, we handle the recovery at no charge. Period.</p>
      </div>
    </div>
  </section>

  <!-- Why Perfect Pools -->
  <section class="section">
    <div class="container">
      <div class="benefits-layout">
        <div class="benefits-layout__image">
          <img src={`${base}images/pool-cleaning-action.jpg`} alt="Perfect Pools technician cleaning a residential pool with a skimmer" loading="lazy" />
        </div>

        <div class="benefits-layout__content">
          <h2>Why Perfect Pools?</h2>

          <div class="benefit-row">
            <div class="benefit-row__icon benefit-row__icon--blue">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>
            </div>
            <div>
              <h3>Chemistry done right</h3>
              <p>We test your water every visit and dose to the exact reading—not a pre-packaged treatment plan. That's how we keep your water balanced, prevent algae, and avoid over-dosing that causes cloudy water.</p>
            </div>
          </div>

          <div class="benefit-row">
            <div class="benefit-row__icon benefit-row__icon--orange">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 18v-1"/><path d="M14 18v-3"/><path d="M10 13v-1"/></svg>
            </div>
            <div>
              <h3>No surprise bills</h3>
              <p>Chemicals and extras like salt cell or filter cleans are billed separately and itemized. We ask before performing extras—so you see exactly what's added and why, with <strong>transparent pricing</strong> every time.</p>
            </div>
          </div>

          <div class="benefit-row">
            <div class="benefit-row__icon benefit-row__icon--green">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
            </div>
            <div>
              <h3>Expert support</h3>
              <p>Weekly service customers get preferred access to our repair department. Whether it's equipment troubleshooting or a pump replacement, same transparent pricing and same reliable service.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Banner -->
  <section class="stats-banner">
    <div class="container stats-banner__content">
      <h2>Simplifying pool care for <em>hundreds of homeowners</em> in the southeast.</h2>
    </div>
  </section>

  <!-- Coastal Georgia Expertise -->
  <section class="section">
    <div class="container container--narrow text-center">
      <div class="expertise-icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
      </div>
      <h2>Built for coastal Georgia pools</h2>
      <p class="text-lg">
        Salt air accelerates corrosion. Summer rain brings algae blooms. And the season never really ends here—your pool needs attention year-round.
      </p>
      <p>
        We've been maintaining pools in coastal Georgia long enough to know what works. That's why we dose liquid chlorine (not tablets), monitor stabilizer levels closely, and keep phosphate removers on the truck during algae season.
      </p>
    </div>
  </section>

  <!-- Social Proof -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2>What homeowners say</h2>
        <p class="section-header__subtitle">Real feedback from residential customers</p>
      </div>

      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-card__stars">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <p class="review-card__text">"We switched from our old pool company and immediately noticed the difference. The reports are detailed, the water has never looked better, and I actually understand what they're doing now."</p>
          <div class="review-card__author">
            <strong>Jennifer M.</strong>
            <span>Homeowner, Richmond Hill</span>
          </div>
        </div>

        <div class="review-card">
          <div class="review-card__stars">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <p class="review-card__text">"First-time pool owner, totally overwhelmed. Perfect Pools handled everything and explained it in a way I could understand. Haven't had to call them once with an issue—it just works."</p>
          <div class="review-card__author">
            <strong>David K.</strong>
            <span>Homeowner, Savannah</span>
          </div>
        </div>

        <div class="review-card">
          <div class="review-card__stars">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <p class="review-card__text">"The billing transparency is what sold me. I can see exactly what they added and what it cost. No mystery charges, no weird line items. It's refreshing."</p>
          <div class="review-card__author">
            <strong>Sarah T.</strong>
            <span>Homeowner, Pooler</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQ items={faqs} />

  <!-- Final CTA -->
  <section class="section">
    <div class="container container--narrow text-center">
      <h2>Get a quote for your pool</h2>
      <p class="text-lg">Tell us about your pool and we'll send you a custom quote within 24 hours. Weekly service starts at $200/month.</p>
      <div class="cta-buttons">
