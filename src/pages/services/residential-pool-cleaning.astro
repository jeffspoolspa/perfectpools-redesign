<script>
  // Pricing tabs
  const tabs = document.querySelectorAll('.pricing-tab');
  const contents = document.querySelectorAll('.pricing-card__content');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab;
      tabs.forEach((t) => t.classList.remove('pricing-tab--active'));
      tab.classList.add('pricing-tab--active');
      contents.forEach((c) => {
        c.classList.toggle('pricing-card__content--active', (c as HTMLElement).dataset.content === target);
      });
    });
  });

  // Mount Preact islands
  async function mountPricingIslands() {
    const { render, h } = await import('preact');
    const { default: PricingConfigurator } = await import('../../components/PricingConfigurator.tsx');
    const { default: ChemicalCostChart } = await import('../../components/ChemicalCostChart.tsx');

    const weeklyConfig = document.getElementById('res-pricing-config-weekly');
    if (weeklyConfig) render(h(PricingConfigurator, { frequency: 'weekly', ctaHref: '/get-started/' }), weeklyConfig);

    const biweeklyConfig = document.getElementById('res-pricing-config-biweekly');
    if (biweeklyConfig) render(h(PricingConfigurator, { frequency: 'biweekly', ctaHref: '/get-started/' }), biweeklyConfig);

    const SUPABASE_URL = 'https://vvprodiuwraceabviyes.supabase.co';
    const SUPABASE_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ2cHJvZGl1d3JhY2VhYnZpeWVzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTY5MDU4MTYsImV4cCI6MjA3MjQ4MTgxNn0.HOFTUrInpmzhxTJDSp1xKp81noC7jMuTcdxr9JqC3z0';

    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/chemical_cost_estimates?select=*`, {
        headers: { apikey: SUPABASE_ANON, Accept: 'application/json' }
      });
      const allData = await res.json();
      if (!Array.isArray(allData)) return;
      const weeklyData = allData.filter((d: any) => d.service_frequency === 'weekly');

      const weeklyChart = document.getElementById('res-chem-chart-weekly');
      if (weeklyChart && weeklyData.length) {
        render(h(ChemicalCostChart, { data: weeklyData, serviceMonthly: 217, competitorFlat: 350, compact: true }), weeklyChart);
      }
    } catch (err) {
      console.error('Failed to load chemical cost data:', err);
    }
  }
  mountPricingIslands();
</script>

