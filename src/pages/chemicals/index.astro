---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { chemicals, sanitizerIds, balancerIds, preventativeIds, type Chemical } from '../../data/chemicals';

const base = import.meta.env.BASE_URL;

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Pool Chemicals",
  "description": "Professional-grade pool chemicals with transparent cost-plus pricing. Every chemical we use, what it does, and what it costs.",
  "itemListElement": Object.values(chemicals).map((chem, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": chem.name,
    "url": `https://perfectpoolscleaning.com/chemicals/${chem.id}/`
  }))
};

const sanitizers = sanitizerIds.map(id => chemicals[id]);
const balancers = balancerIds.map(id => chemicals[id]);
const preventative = preventativeIds.map(id => chemicals[id]);
const allChemicals = Object.values(chemicals);

const checkSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="icon icon--sm"><polyline points="20 6 9 17 4 12"/></svg>';
---

<BaseLayout
  title="Pool Chemicals We Use & Their Costs | Perfect Pools"
  description="Every chemical we use in your pool, what it does, why it matters, and what it costs. Transparent cost-plus pricing on professional-grade chemicals."
  canonicalPath="/chemicals"
  schema={schema}
>
  <!-- Hero -->
  <section class="chem-hero">
    <div class="container">
      <div class="chem-hero__content">
        <h1>Pool chemistry is complicated.<br/><span class="chem-hero__accent">Your bill shouldn't be.</span></h1>
        <p class="chem-hero__sub">Formulations that provide sustained water quality using transparent, cost-plus pricing on professional-grade chemicals.</p>
        <div class="chem-hero__note">
          <svg class="chem-hero__shield" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <p>We test your water every visit. What we add depends entirely on what we find.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sanitizers -->
  <section class="chem-section">
    <div class="container">
      <div class="chem-section__header">
        <h2>Sanitizers</h2>
        <p>What keeps your water safe</p>
      </div>
      <div class="chem-grid chem-grid--3">
        {sanitizers.map(chem => (
          <button type="button" class="chem-card" data-open-panel={chem.id}>
            <div class="chem-card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h4l2 3h4a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2z"/><path d="M11 12h4"/><path d="M13 10v4"/></svg>
            </div>
            <div class="chem-card__badges">
              {chem.badge && <span class="chem-badge">{chem.badge}</span>}
              {chem.timing && <span class="chem-badge chem-badge--outline">{chem.timing}</span>}
            </div>
            <h3>{chem.name}</h3>
            <p class="chem-card__sci">{chem.scientificName}</p>
            <p class="chem-card__desc">{chem.description}</p>
            <div class="chem-card__footer">
              <span class="chem-card__cta">Learn More</span>
              <span class="chem-card__price">{chem.price}</span>
            </div>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Balancers -->
  <section class="chem-section">
    <div class="container">
      <div class="chem-section__header">
        <h2>Balancers</h2>
        <p>What makes sanitizers work</p>
      </div>
      <div class="chem-grid chem-grid--3">
        {balancers.map(chem => (
          <button type="button" class="chem-card" data-open-panel={chem.id}>
            <div class="chem-card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h4l2 3h4a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2z"/><path d="M11 12h4"/><path d="M13 10v4"/></svg>
            </div>
            <div class="chem-card__badges">
              {chem.badge && <span class="chem-badge">{chem.badge}</span>}
              {chem.timing && <span class="chem-badge chem-badge--outline">{chem.timing}</span>}
            </div>
            <h3>{chem.name}</h3>
            <p class="chem-card__sci">{chem.scientificName}</p>
            <p class="chem-card__desc">{chem.description}</p>
            <div class="chem-card__footer">
              <span class="chem-card__cta">Learn More</span>
              <span class="chem-card__price">{chem.price}</span>
            </div>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Preventative Care -->
  <section class="chem-section">
    <div class="container">
      <div class="chem-section__header">
        <h2>Preventative Care</h2>
        <p>Preventing problems before they start</p>
      </div>
      <div class="chem-grid chem-grid--4">
        {preventative.map(chem => (
          <button type="button" class="chem-card" data-open-panel={chem.id}>
            <div class="chem-card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h4l2 3h4a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2z"/><path d="M11 12h4"/><path d="M13 10v4"/></svg>
            </div>
            <div class="chem-card__badges">
              {chem.badge && <span class="chem-badge">{chem.badge}</span>}
              {chem.timing && <span class="chem-badge chem-badge--outline">{chem.timing}</span>}
            </div>
            <h3>{chem.name}</h3>
            <p class="chem-card__sci">{chem.scientificName}</p>
            <p class="chem-card__desc">{chem.description}</p>
            <div class="chem-card__footer">
              <span class="chem-card__cta">Learn More</span>
              <span class="chem-card__price">{chem.price}</span>
            </div>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom Cards -->
  <section class="chem-section chem-section--last">
    <div class="container">
      <div class="chem-bottom-grid">
        <div class="chem-bottom-card chem-bottom-card--amber">
          <span class="chem-badge chem-badge--amber">Specialty</span>
          <h3>Advanced Treatments</h3>
          <p>Aggressive algae outbreaks, metal staining, phosphate loading, and tile cleaning require diagnosis and targeted treatment plans. Quoted separately and scheduled as needed.</p>
          <button type="button" class="chem-bottom-card__link" data-open-intake>Get a Quote <span>&rarr;</span></button>
        </div>
        <div class="chem-bottom-card chem-bottom-card--cyan">
          <svg class="chem-bottom-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <h3>What did my tech add this visit?</h3>
          <p>Every service report includes a complete breakdown of chemicals added, their quantities, and costs. You'll receive a digital report after each visit.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Slide-in Panels (one per chemical) -->
  <div class="panel-overlay" id="panel-overlay" hidden></div>

  {allChemicals.map(chem => (
    <aside class="panel" id={`panel-${chem.id}`} aria-hidden="true" role="dialog" aria-label={chem.name}>
      <div class="panel__inner">
        <!-- Panel Header -->
        <div class="panel__header">
          <div>
            <p class="panel__category">{chem.category}</p>
            <h2 class="panel__title">{chem.name}</h2>
            <p class="panel__sci">{chem.scientificName}</p>
          </div>
          <button type="button" class="panel__close" data-close-panel aria-label="Close panel">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>

        <div class="panel__price-row">
          <span class="panel__price">{chem.price}</span>
          <div class="panel__badges">
            {chem.badge && <span class="chem-badge">{chem.badge}</span>}
            {chem.timing && <span class="chem-badge chem-badge--outline">{chem.timing}</span>}
          </div>
        </div>

        <p class="panel__verdict">{chem.verdict}</p>

        <!-- Panel Body (scrollable) -->
        <div class="panel__body">

          <!-- What It Does -->
          <div class="panel-section">
            <button type="button" class="panel-section__trigger" aria-expanded="true">
              <div class="panel-section__icon panel-section__icon--blue">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
              </div>
              <span>What it does</span>
              <svg class="panel-section__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="panel-section__content">
              <p>{chem.whatItDoes}</p>
            </div>
          </div>

          <!-- When You'll See This -->
          <div class="panel-section">
            <button type="button" class="panel-section__trigger" aria-expanded="false">
              <div class="panel-section__icon panel-section__icon--purple">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </div>
              <span>When you'll see this</span>
              <svg class="panel-section__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="panel-section__content" hidden>
              <span class="frequency-badge">{chem.whenYouWillSeeThis.frequency}</span>
              <p>{chem.whenYouWillSeeThis.explanation}</p>
            </div>
          </div>

          <!-- Key Benefits -->
          <div class="panel-section">
            <button type="button" class="panel-section__trigger" aria-expanded="false">
              <div class="panel-section__icon panel-section__icon--green">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
              <span>Key benefits</span>
              <svg class="panel-section__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="panel-section__content" hidden>
              <ul class="panel-benefits">
                {chem.benefits.map(b => {
                  const parts = b.split(" — ");
                  return (
                    <li>
                      <Fragment set:html={checkSvg} />
                      <div>
                        <strong>{parts[0]}</strong>
                        {parts[1] && <span> — {parts[1]}</span>}
                      </div>
                    </li>
                  );
                })}
              </ul>
            </div>
          </div>

          <!-- What If We Skip It -->
          <div class="panel-section">
            <button type="button" class="panel-section__trigger" aria-expanded="false">
              <div class="panel-section__icon panel-section__icon--red">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </div>
              <span>What if we skip it?</span>
              <svg class="panel-section__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="panel-section__content" hidden>
              <div class="panel-warning">
                <p>{chem.whatIfWeSkipIt}</p>
              </div>
            </div>
          </div>

          <!-- Pricing -->
          <div class="panel-section">
            <button type="button" class="panel-section__trigger" aria-expanded="false">
              <div class="panel-section__icon panel-section__icon--blue">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </div>
              <span>Pricing</span>
              <svg class="panel-section__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="panel-section__content" hidden>
              {chem.pricing.model === "per-use" && chem.pricing.perUseDetails && (
                <div class="panel-pricing">
                  <p>We carry {chem.name.toLowerCase()} on the truck and bill by the {chem.pricing.perUseDetails.billingIncrement === 0.5 ? `half ${chem.pricing.perUseDetails.unit}` : chem.pricing.perUseDetails.unit}. You're only charged for what goes in your pool.</p>
                  <div class="panel-pricing__highlight">
                    <span class="panel-pricing__label">Price</span>
                    <span class="panel-pricing__value">{chem.price}</span>
                  </div>

                  {chem.pricing.perUseDetails.calculatorFormula && (
                    <div class="dosing-calc"
                      data-divider={chem.pricing.perUseDetails.calculatorFormula.divider}
                      data-round-to={chem.pricing.perUseDetails.calculatorFormula.roundTo}
                      data-price-per-unit={chem.pricing.perUseDetails.pricePerUnit}
                      data-unit={chem.pricing.perUseDetails.unit}
                    >
                      <p class="dosing-calc__heading">Estimate your dose</p>

                      <div class="dosing-calc__field">
                        <p class="dosing-calc__label">Pool size (gallons)</p>
                        <div class="dosing-calc__size-grid">
                          <button type="button" class="dosing-calc__size" data-pool-size="5000">5,000</button>
                          <button type="button" class="dosing-calc__size" data-pool-size="10000">10,000</button>
                          <button type="button" class="dosing-calc__size is-active" data-pool-size="15000">15,000</button>
                          <button type="button" class="dosing-calc__size" data-pool-size="20000">20,000</button>
                          <button type="button" class="dosing-calc__size" data-pool-size="25000">25,000</button>
                          <button type="button" class="dosing-calc__size" data-pool-size="30000">30,000</button>
                        </div>
                      </div>

                      <div class="dosing-calc__field">
                        <div class="dosing-calc__slider-header">
                          <p class="dosing-calc__label">FC adjustment needed</p>
                          <span class="dosing-calc__slider-value">2.0 ppm</span>
                        </div>
                        <input type="range" min="0" max="10" step="0.5" value="2" class="dosing-calc__range" />
                      </div>

                      <div class="dosing-calc__result">
                        <div class="dosing-calc__result-row">
                          <span class="dosing-calc__amount">—</span>
                          <span class="dosing-calc__unit">{chem.pricing.perUseDetails.unit}s</span>
                        </div>
                        <div class="dosing-calc__result-row dosing-calc__result-row--cost">
                          <span>Estimated cost</span>
                          <span class="dosing-calc__cost">—</span>
                        </div>
                      </div>
                    </div>
                  )}
                </div>
              )}
              {chem.pricing.model === "left-on-site" && chem.pricing.leftOnSiteDetails && (
                <div class="panel-pricing panel-pricing--onsite">
                  <div class="panel-pricing__row">
                    <div>
                      <span class="panel-pricing__label">Restock price</span>
                      <span class="panel-pricing__value">${chem.pricing.leftOnSiteDetails.pricePerRestock.toFixed(2)}</span>
                    </div>
                    <div>
                      <span class="panel-pricing__label">Typical duration</span>
                      <span class="panel-pricing__duration">{chem.pricing.leftOnSiteDetails.typicalDuration}</span>
                    </div>
                  </div>
                  <p>We keep a {chem.pricing.leftOnSiteDetails.unit} at your pool. Your tech uses what's needed and restocks when empty — you're only billed at restock.</p>
                </div>
              )}
            </div>
          </div>

          <!-- FAQ -->
          <div class="panel-section">
            <button type="button" class="panel-section__trigger" aria-expanded="false">
              <div class="panel-section__icon panel-section__icon--gray">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </div>
              <span>Common questions</span>
              <svg class="panel-section__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="panel-section__content" hidden>
              <div class="panel-faqs">
                {chem.faqs.map(faq => (
                  <div class="panel-faq">
                    <button type="button" class="panel-faq__trigger" aria-expanded="false">
                      <span>{faq.question}</span>
                      <svg class="panel-faq__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="panel-faq__answer" hidden>
                      <p>{faq.answer}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Alternatives -->
          {chem.alternatives && chem.alternatives.length > 0 && (
            <div class="panel-section">
              <button type="button" class="panel-section__trigger" aria-expanded="false">
                <div class="panel-section__icon panel-section__icon--gray">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
                </div>
                <span>Alternatives</span>
                <svg class="panel-section__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="panel-section__content" hidden>
                {chem.alternatives.map(alt => (
                  <button type="button" class="panel-alt" data-switch-panel={alt.id}>
                    <div>
                      <p class="panel-alt__name">{alt.name}</p>
                      <p class="panel-alt__desc">{alt.description}</p>
                    </div>
                    <span class="panel-alt__arrow">&rarr;</span>
                  </button>
                ))}
              </div>
            </div>
          )}

          <!-- Contact CTA -->
          <div class="panel-cta">
            <p>Questions about a charge on your bill?</p>
            <button type="button" class="btn btn--cta btn--sm" data-open-intake>Contact Us</button>
          </div>
        </div>
      </div>
    </aside>
  ))}
</BaseLayout>

<style>
  /* Dark hero, light body */
  .chem-hero {
    background: var(--color-dark-blue, #0c4a6e);
    color: var(--color-white);
  }

  .chem-section {
    background: var(--color-white);
  }

  .chem-section:nth-child(even) {
    background: var(--color-light-bg, #f8f9fa);
  }

  /* Hero */
  .chem-hero {
    padding: var(--space-16) 0 var(--space-12);
  }

  .chem-hero__content {
    max-width: 720px;
  }

  .chem-hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    line-height: 1.1;
    margin-bottom: var(--space-6);
    letter-spacing: -0.02em;
    color: var(--color-white);
  }

  .chem-hero__accent {
    color: var(--color-cyan, #22d3ee);
  }

  .chem-hero__sub {
    font-size: var(--text-xl);
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    margin-bottom: var(--space-8);
  }

  .chem-hero__note {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: rgba(255, 255, 255, 0.6);
  }

  .chem-hero__shield {
    width: 20px;
    height: 20px;
    color: var(--color-cyan, #22d3ee);
    flex-shrink: 0;
  }

  /* Section Headers */
  .chem-section {
    padding: var(--space-12) 0;
  }

  .chem-section--last {
    padding-bottom: var(--space-16);
  }

  .chem-section__header {
    margin-bottom: var(--space-10);
  }

  .chem-section__header h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--color-gray-900);
    margin-bottom: var(--space-2);
  }

  .chem-section__header p {
    font-size: var(--text-xl);
    color: var(--color-gray-500);
  }

  /* Grid */
  .chem-grid {
    display: grid;
    gap: var(--space-6);
  }

  .chem-grid--3 { grid-template-columns: 1fr; }
  .chem-grid--4 { grid-template-columns: 1fr; }

  @media (min-width: 640px) {
    .chem-grid--3 { grid-template-columns: repeat(2, 1fr); }
    .chem-grid--4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .chem-grid--3 { grid-template-columns: repeat(3, 1fr); }
    .chem-grid--4 { grid-template-columns: repeat(4, 1fr); }
  }

  /* Chemical Card (now a button) */
  .chem-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    text-decoration: none;
    text-align: left;
    color: var(--color-gray-900);
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    transition: all var(--transition-base);
    box-shadow: var(--shadow-sm);
  }

  .chem-card:hover {
    border-color: var(--color-primary);
    background: var(--color-white);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .chem-card__icon {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, var(--color-primary), var(--color-cyan, #06b6d4));
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-6);
  }

  .chem-card__icon svg {
