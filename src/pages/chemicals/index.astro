  .dosing-calc__result-row--cost {
    justify-content: space-between;
    margin-top: var(--space-2);
    padding-top: var(--space-2);
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    font-size: var(--text-sm);
    opacity: 0.9;
  }

  .dosing-calc__amount {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
  }

  .dosing-calc__unit {
    font-size: var(--text-sm);
    opacity: 0.9;
  }

  .dosing-calc__cost {
    font-weight: 700;
    font-size: var(--text-lg);
  }
</style>

<script>
  const overlay = document.getElementById('panel-overlay');

  function openPanel(id: string) {
    // Close any already-open panel
    closeAllPanels();

    const panel = document.getElementById(`panel-${id}`);
    if (!panel || !overlay) return;

    overlay.hidden = false;
    // Force reflow before adding class so transition works
    void overlay.offsetWidth;
    overlay.classList.add('is-visible');

    panel.setAttribute('aria-hidden', 'false');
    panel.classList.add('is-open');

    document.body.style.overflow = 'hidden';

    // Reset scroll position
    const body = panel.querySelector('.panel__body');
    if (body) body.scrollTop = 0;
  }

  function closeAllPanels() {
    document.querySelectorAll('.panel.is-open').forEach(p => {
      p.classList.remove('is-open');
      p.setAttribute('aria-hidden', 'true');
    });
    if (overlay) {
      overlay.classList.remove('is-visible');
      // Hide after transition
      setTimeout(() => { overlay.hidden = true; }, 300);
    }
    document.body.style.overflow = '';
  }

  // Open panel from card click
  document.querySelectorAll<HTMLElement>('[data-open-panel]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-open-panel');
      if (id) openPanel(id);
    });
  });

  // Close panel
  document.querySelectorAll('[data-close-panel]').forEach(btn => {
    btn.addEventListener('click', closeAllPanels);
  });

  // Close on overlay click
  overlay?.addEventListener('click', closeAllPanels);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeAllPanels();
  });

  // Switch to a different panel (alternatives)
  document.querySelectorAll<HTMLElement>('[data-switch-panel]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-switch-panel');
      if (id) openPanel(id);
    });
  });

  // Panel section accordion toggles
  document.querySelectorAll('.panel-section__trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const content = btn.nextElementSibling as HTMLElement;
      btn.setAttribute('aria-expanded', String(!expanded));
      if (content) content.hidden = expanded;
    });
  });

  // Panel FAQ toggles
  document.querySelectorAll('.panel-faq__trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const content = btn.nextElementSibling as HTMLElement;
      btn.setAttribute('aria-expanded', String(!expanded));
      if (content) content.hidden = expanded;
    });
  });

  // ========================
  // DOSING CALCULATOR
  // ========================
  document.querySelectorAll<HTMLElement>('.dosing-calc').forEach(calc => {
    const divider = parseFloat(calc.dataset.divider || '1');
    const roundTo = parseFloat(calc.dataset.roundTo || '1');
    const pricePerUnit = parseFloat(calc.dataset.pricePerUnit || '0');
    const unit = calc.dataset.unit || '';

    let poolSize = 15000;
    let adjustment = 2.0;

    const amountEl = calc.querySelector('.dosing-calc__amount') as HTMLElement;
    const costEl = calc.querySelector('.dosing-calc__cost') as HTMLElement;
    const sliderValueEl = calc.querySelector('.dosing-calc__slider-value') as HTMLElement;
    const rangeInput = calc.querySelector('.dosing-calc__range') as HTMLInputElement;

    function recalc() {
      if (adjustment === 0) {
        amountEl.textContent = '0';
        costEl.textContent = '$0.00';
        return;
      }
      const raw = (poolSize * adjustment) / divider;
      const rounded = Math.ceil(raw / roundTo) * roundTo;
      const cost = rounded * pricePerUnit;

      // Format amount — show decimals only if needed
      const amountStr = rounded % 1 === 0 ? rounded.toString() : rounded.toFixed(1);
      amountEl.textContent = amountStr;
      costEl.textContent = `$${cost.toFixed(2)}`;
    }

    // Pool size buttons
    calc.querySelectorAll<HTMLElement>('.dosing-calc__size').forEach(btn => {
      btn.addEventListener('click', () => {
        calc.querySelectorAll('.dosing-calc__size').forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        poolSize = parseInt(btn.dataset.poolSize || '15000', 10);
        recalc();
      });
    });

    // Slider
    if (rangeInput) {
      rangeInput.addEventListener('input', () => {
        adjustment = parseFloat(rangeInput.value);
        if (sliderValueEl) sliderValueEl.textContent = `${adjustment.toFixed(1)} ppm`;
        recalc();
      });
    }

    // Initial calc
    recalc();
  });
</script>
