---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { chemicals, type Chemical } from '../../data/chemicals';

const base = import.meta.env.BASE_URL;

export function getStaticPaths() {
  return Object.keys(chemicals).map(id => ({
    params: { slug: id },
    props: { chemical: chemicals[id] }
  }));
}

const { chemical } = Astro.props as { chemical: Chemical };

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": chemical.name,
  "description": chemical.description,
  "category": chemical.category,
  "offers": {
    "@type": "Offer",
    "price": chemical.price,
    "priceCurrency": "USD"
  }
};

const checkSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="icon icon--sm"><polyline points="20 6 9 17 4 12"/></svg>';
---

<BaseLayout
  title={`${chemical.name} — What It Does & What It Costs | Perfect Pools`}
  description={`${chemical.verdict} Learn about ${chemical.name.toLowerCase()}, how we use it in your pool, and our transparent pricing.`}
  canonicalPath={`/chemicals/${chemical.id}`}
  schema={schema}
>
  <!-- Breadcrumb -->
  <section class="chem-detail-breadcrumb">
    <div class="container">
      <a href={`${base}chemicals/`}>&larr; All Chemicals</a>
    </div>
  </section>

  <!-- Header -->
  <section class="chem-detail-header">
    <div class="container">
      <div class="chem-detail-header__inner">
        <div class="chem-detail-header__left">
          <p class="chem-detail-header__category">{chemical.category}</p>
          <h1>{chemical.name}</h1>
          <p class="chem-detail-header__sci">{chemical.scientificName}</p>
        </div>
        <div class="chem-detail-header__right">
          <p class="chem-detail-header__price">{chemical.price}</p>
        </div>
      </div>
      <p class="chem-detail-header__verdict">{chemical.verdict}</p>
    </div>
  </section>

  <!-- Content -->
  <section class="section chem-detail-body">
    <div class="container chem-detail-container">

      <!-- What It Does -->
      <div class="detail-card detail-card--blue">
        <div class="detail-card__header">
          <div class="detail-card__icon detail-card__icon--blue">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
          </div>
          <h2>What it does</h2>
        </div>
        <p>{chemical.whatItDoes}</p>
      </div>

      <!-- When You'll See This -->
      <div class="detail-card">
        <div class="detail-card__header">
          <div class="detail-card__icon detail-card__icon--purple">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h2>When you'll see this</h2>
        </div>
        <span class="frequency-badge">{chemical.whenYouWillSeeThis.frequency}</span>
        <p>{chemical.whenYouWillSeeThis.explanation}</p>
      </div>

      <!-- Benefits -->
      <div class="detail-card">
        <div class="detail-card__header">
          <div class="detail-card__icon detail-card__icon--green">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h2>Key benefits</h2>
        </div>
        <div class="benefits-list">
          {chemical.benefits.map(benefit => {
            const parts = benefit.split(" — ");
            return (
              <div class="benefit-item">
                <div class="benefit-item__check">
                  <Fragment set:html={checkSvg} />
                </div>
                <div>
                  <p class="benefit-item__title">{parts[0]}</p>
                  {parts[1] && <p class="benefit-item__desc">{parts[1]}</p>}
                </div>
              </div>
            );
          })}
        </div>
      </div>

      <!-- What If We Skip It -->
      <div class="detail-card detail-card--warning">
        <div class="detail-card__header">
          <div class="detail-card__icon detail-card__icon--red">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <h2>What if we skip it?</h2>
        </div>
        <p>{chemical.whatIfWeSkipIt}</p>
      </div>

      <!-- Pricing -->
      <div class="detail-card">
        <div class="detail-card__header">
          <div class="detail-card__icon detail-card__icon--blue">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h2>{chemical.pricing.model === "per-use" ? "Pricing" : "How we sell it"}</h2>
        </div>
        {chemical.pricing.model === "per-use" && chemical.pricing.perUseDetails && (
          <div class="pricing-info">
            <p>We carry {chemical.name.toLowerCase()} on the truck and bill by the {chemical.pricing.perUseDetails.billingIncrement === 0.5 ? `half ${chemical.pricing.perUseDetails.unit}` : chemical.pricing.perUseDetails.unit}. You're only charged for what goes in your pool.</p>
            <div class="pricing-info__highlight">
              <span class="pricing-info__label">Price</span>
              <span class="pricing-info__value">{chemical.price}</span>
            </div>
          </div>
        )}
        {chemical.pricing.model === "left-on-site" && chemical.pricing.leftOnSiteDetails && (
          <div class="pricing-info pricing-info--onsite">
            <div class="pricing-info__row">
              <div>
                <span class="pricing-info__label">Restock price</span>
                <span class="pricing-info__value">${chemical.pricing.leftOnSiteDetails.pricePerRestock.toFixed(2)}</span>
              </div>
              <div>
                <span class="pricing-info__label">Typical duration</span>
                <span class="pricing-info__duration">{chemical.pricing.leftOnSiteDetails.typicalDuration}</span>
              </div>
            </div>
            <p class="pricing-info__explain">We keep a {chemical.pricing.leftOnSiteDetails.unit} at your pool. Your tech uses what's needed and restocks when empty -- you're only billed at restock.</p>
          </div>
        )}
      </div>

      <!-- FAQ -->
      <div class="detail-card">
        <h2 class="detail-card__faq-title">Common questions</h2>
        <div class="faq-list">
          {chemical.faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-item__trigger" aria-expanded="false">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-item__content" hidden>
                <p>{faq.answer}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Alternatives -->
      {chemical.alternatives && chemical.alternatives.length > 0 && (
        <div class="detail-card">
          <h2 class="detail-card__faq-title">Alternatives</h2>
          <div class="alternatives-list">
            {chemical.alternatives.map(alt => (
              <a href={`${base}chemicals/${alt.id}/`} class="alternative-link">
                <div>
                  <p class="alternative-link__name">{alt.name}</p>
                  <p class="alternative-link__desc">{alt.description}</p>
                </div>
                <span class="alternative-link__arrow">&rarr;</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- CTA -->
      <div class="detail-cta">
        <p>Questions about a charge on your bill?</p>
        <button type="button" class="btn btn--cta btn--sm" data-open-intake>Contact Us</button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Breadcrumb */
  .chem-detail-breadcrumb {
    background: var(--color-light-bg, #f8f9fa);
    padding: var(--space-3) 0;
  }

  .chem-detail-breadcrumb a {
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: 500;
  }

  .chem-detail-breadcrumb a:hover {
    text-decoration: underline;
  }

  /* Header */
  .chem-detail-header {
    background: var(--color-white);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-8) 0;
  }

  .chem-detail-header__inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-6);
    margin-bottom: var(--space-4);
  }

  .chem-detail-header__category {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-500);
    margin-bottom: var(--space-2);
  }

  .chem-detail-header h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: var(--space-1);
  }

  .chem-detail-header__sci {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
  }

  .chem-detail-header__price {
    font-size: var(--text-lg);
    font-weight: 600;
    white-space: nowrap;
  }

  .chem-detail-header__verdict {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-gray-700);
    line-height: 1.5;
  }

  /* Body */
  .chem-detail-body {
    background: var(--color-light-bg, #f8f9fa);
  }

  .chem-detail-container {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* Detail Card */
  .detail-card {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    border: 1px solid var(--color-border);
  }

  .detail-card--blue {
    background: linear-gradient(135deg, #eff6ff, #ecfeff);
    border-color: #bfdbfe;
  }

  .detail-card--warning {
    background: linear-gradient(135deg, #fef2f2, #fff7ed);
    border-left: 4px solid #ef4444;
  }

  .detail-card__header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .detail-card__header h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
  }

  .detail-card--warning .detail-card__header h2 {
    color: #991b1b;
  }

  .detail-card__icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .detail-card__icon svg {
    width: 20px;
    height: 20px;
  }

  .detail-card__icon--blue {
    background: #dbeafe;
    color: #2563eb;
  }

  .detail-card__icon--purple {
    background: #ede9fe;
    color: #7c3aed;
  }

  .detail-card__icon--green {
    background: #dcfce7;
    color: #16a34a;
  }

  .detail-card__icon--red {
    background: #fee2e2;
    color: #dc2626;
  }

  .detail-card p {
    color: var(--color-gray-600);
    line-height: 1.7;
  }

  .detail-card--warning p {
    color: #991b1b;
  }

  /* Frequency Badge */
  .frequency-badge {
    display: inline-flex;
    align-items: center;
    background: #dbeafe;
    color: #1e3a8a;
    font-size: var(--text-sm);
    font-weight: 600;
    padding: var(--space-2) var(--space-4);
    border-radius: 999px;
    margin-bottom: var(--space-3);
  }

  /* Benefits */
  .benefits-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .benefit-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-3);
    background: var(--color-light-bg, #f8f9fa);
    border-radius: var(--radius-md);
  }

  .benefit-item__check {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .benefit-item__check :global(.icon--sm) {
    width: 14px;
    height: 14px;
    color: var(--color-white);
  }

  .benefit-item__title {
    font-weight: 600;
    color: var(--color-gray-900);
    margin-bottom: 2px;
  }

  .benefit-item__desc {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
  }

  /* Pricing Info */
  .pricing-info {
    background: linear-gradient(135deg, #eff6ff, #ecfeff);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    border: 1px solid #bfdbfe;
  }

  .pricing-info p {
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .pricing-info__highlight {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .pricing-info__label {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
  }

  .pricing-info__value {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .pricing-info__row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid #bfdbfe;
  }

  .pricing-info__row div {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .pricing-info__duration {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-primary);
  }

  .pricing-info__explain {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    margin-bottom: 0;
  }

  /* FAQ */
  .detail-card__faq-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .faq-item {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .faq-item__trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-gray-900);
    transition: background-color var(--transition-fast);
  }

  .faq-item__trigger:hover {
    background: var(--color-light-bg, #f8f9fa);
  }

  .faq-item__chevron {
    width: 20px;
    height: 20px;
    color: var(--color-gray-400);
    flex-shrink: 0;
    transition: transform var(--transition-fast);
  }

  .faq-item__trigger[aria-expanded="true"] .faq-item__chevron {
    transform: rotate(180deg);
  }

  .faq-item__content {
    padding: var(--space-4);
    background: var(--color-light-bg, #f8f9fa);
    border-top: 1px solid var(--color-border);
  }

  .faq-item__content p {
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  /* Alternatives */
  .alternatives-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .alternative-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5);
    background: var(--color-white);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-fast);
  }

  .alternative-link:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }

  .alternative-link__name {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-gray-900);
    margin-bottom: var(--space-2);
  }

  .alternative-link__desc {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    line-height: 1.6;
  }

  .alternative-link__arrow {
    font-size: 1.25rem;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  /* CTA */
  .detail-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--color-white);
    border-radius: var(--radius-lg);
    padding: var(--space-4) var(--space-6);
    border: 1px solid var(--color-border);
  }

  .detail-cta p {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
  }

  @media (max-width: 480px) {
    .chem-detail-header__inner {
      flex-direction: column;
    }
    .detail-cta {
      flex-direction: column;
      gap: var(--space-3);
      text-align: center;
    }
  }
</style>

<script>
  // FAQ toggles
  document.querySelectorAll('.faq-item__trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const content = btn.nextElementSibling;
      btn.setAttribute('aria-expanded', String(!expanded));
      if (content) content.hidden = expanded;
    });
  });
</script>
